@prefix anclass: <https://w3id.org/tabulae/id/codes/annotationClass/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tbl: <https://w3id.org/tabulae#> .


anclass:BlankPage a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Page not completed, regardless of its nature. This class can be used in addition of other classes to describe the page in more detail."@en,
        "Page non complétée, indépendament de sa nature. Cette classe peut-être utilisée avec d'autres classes pour décrire la page plus précisément."@fr ;
    skos:hiddenLabel "ets_blank" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Blank page"@en,
        "Page vide"@fr ;
    skos:related anclass:Page .

anclass:CrossedOut a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:TextStyles ;
    skos:definition "Indicates that the text in a page area is crossed out."@en,
        "Indique que le texte d'une zone de page est barré."@fr ;
    skos:hiddenLabel "~~~~" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Crossed-out text"@en,
        "Texte barré/rayé"@fr .

anclass:DocumentType a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:definition "Types of documents or fields contained in cadastral archive documents, relating to a task of detecting/locating content within images."@en,
        "Types de documents ou de zones contenues dans les documents d'archives du cadastre, relatif à une tâche de détection/localisation de contenu dans des images."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Type of document"@en,
        "Type de document"@fr .

anclass:DoublePage a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image showing a scanned double-page from a register."@en,
        "Image correspondant à la numérisation d'une double page de registre."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Double-page"@en,
        "Double page"@fr .

anclass:ETSCover a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Cover page preceding the main table describing the plots in a given section within a section register."@en,
        "Page de couverture qui précéde le tableau principal décrivant les parcelles d'une section donnée dans un registre d'état de section."@fr ;
    skos:hiddenLabel "ets_couv" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Section page cover"@en,
        "Couverture décrivant une section dans un registre d'états de sections"@fr ;
    skos:related anclass:Page .

anclass:ETSIntermediateSummary a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Intermediate summary page visible in an initial register."@en,
        "Page de récapitulatif intermédiaire dans un registre d'états de sections."@fr ;
    skos:hiddenLabel "ets_recap_inter" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Intermediate summary"@en,
        "Récapitulatif intermédiaire"@fr ;
    skos:related anclass:Page .

anclass:ETSSummary a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Final summary page located at the end of a section of an initial register, more precisly at the end of the decsription of the plots of a given section."@en,
        "Page de résumé situé à la fin d'une partie d'un registre d'états de sections décrivant les parcelles d'une section donnée."@fr ;
    skos:hiddenLabel "ets_resume" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Summary"@en,
        "Résumé final d'une section"@fr ;
    skos:related anclass:Page .

anclass:ETSTabP2 a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Last page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822."@en,
        "Seconde page du tableau principal d'un registre d'état de sections contenant la description des parcelles listées dans l'ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822."@fr ;
    skos:hiddenLabel "ets_tab_p2" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Second page of a main table in an initial register"@en,
        "Tableau principal d'état de section (seconde page si double page)"@fr ;
    skos:related anclass:Page .

anclass:MATAlphabeticTable a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Page from a mutation register containing an alphabetical list of taxpayers."@en,
        "Page d'une matrice cadastrale correspondant à une liste alphabétique des contribuables."@fr ;
    skos:hiddenLabel "mat_alpha_tab" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Alphabetical table"@en,
        "Table alphabétique"@fr ;
    skos:related anclass:Page .

anclass:MATPropertyTaxAccount a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to a list of 1 to n taxpayers associated with the same property taxes account."@en,
        "Zone d'image correspond à une liste de 1..n contribuables associés au même compte foncier."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "List of successive taxpayers"@en,
        "Liste de contribuables successifs"@fr .

anclass:MATCompteFoncier a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:altLabel "Ligne de tableau décrivant un état de parcelle"@fr ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to a group of lines delineating parcels associated with a list of 1 to n taxpayers located in a folio of a register."@en,
        "Zone d'une image correspondant à un groupe de lignes décrivant des parcelles associé à une liste de 1..n contribuable situé dans un folio d'une matrice."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Area corresponding to a property tax account"@en,
        "Zone correspondant à un compte foncier"@fr .

anclass:MATMainTable a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Main table page of a mutation register containing one or more property tax account."@en,
        "Page du tableau principal d'une matrice cadastrale contenant un ou plusieurs comptes fonciers."@fr ;
    skos:hiddenLabel "mat_main_tab" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Page containing property accounts"@en,
        "Page correspondant à un ou plusieurs folios"@fr ;
    skos:related anclass:Page .

anclass:NEEndTime a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value indicating the expiry date of a parcel statement."@en,
        "Valeur de colonne indiquant la date de fin de validité d'un état de parcelle."@fr ;
    skos:hiddenLabel "date_sortie" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : End date"@en,
        "Entité nommée : Date de sortie"@fr .

anclass:NENature a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value containing the plot nature."@en,
        "Valeur de colonne relative à la nature de la parcelle."@fr ;
    skos:hiddenLabel "nature" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Nature"@en,
        "Entité nommée : Nature"@fr .

anclass:NEPassedTo a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "A column value indicating either one (or more) folio numbers where the following status of the parcel is recorded, or a special value providing information about that status."@en,
        "Valeur de colonne indiquant soit un (ou plusieurs) numéro.s de folio.s où est inscrit l'état suivant de la parcelle soit une valeur spéciale renseignant sur cet état."@fr ;
    skos:hiddenLabel "porte_a" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Next folio or status"@en,
        "Entité nommée : Porté à"@fr .

anclass:NEPlotAddress a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value corresponding to the plot address."@en,
        "Valeur de colonne correspondant à l'adresse de la parcelle."@fr ;
    skos:hiddenLabel "lieu_dit" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Address"@en,
        "Entité nommée : Lieu-dit ou adresse"@fr .

anclass:NEPlotNumber a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value corresponding to the plot number."@en,
        "Valeur de colonne correspondant au numéro de la parcelle."@fr ;
    skos:hiddenLabel "numero_parcelle" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Number"@en,
        "Entité nommée : Numéro de parcelle"@fr .

anclass:NEPreviousNature a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value specific to the initial register of the revised Seine land registry (1835–1845), indicating the plot nature in the previous section list."@en,
        "Valeur de colonne spécifique aux états de sections du cadastre rénové de la Seine (1835-1845), décrit la nature de la parcelle dans l'état de sections précédent."@fr ;
    skos:hiddenLabel "ancienne_nature" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Former Plot Nature"@en,
        "Entité nommée : Ancienne nature de la parcelle"@fr .

anclass:NEPreviousPlotNumber a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value specific to the initial register of the revised Seine land registry (1835–1845), indicating the plot number in the previous section list."@en,
        "Valeur de colonne spécifique aux états de sections du cadastre rénové de la Seine (1835-1845), indique le numéro de la parcelle dans l'état de sections précédent."@fr ;
    skos:hiddenLabel "ancien_numero_parcelle" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Former Plot Number"@en,
        "Entité nommée : Ancien numéro de parcelle"@fr .

anclass:NESectionIdentifier a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value containing the ID of the section in which the plot is located."@en,
        "Valeur d'une colonne contenant l'identifiant de la section dans laquelle se trouve la parcelle."@fr ;
    skos:hiddenLabel "section" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Section Identifier"@en,
        "Entité nommée : Identifiant de section"@fr .

anclass:NEStartTime a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value indicating the start date of validity for a parcel record."@en,
        "Valeur de colonne indiquant la date de début de validité d'un état de parcelle."@fr ;
    skos:hiddenLabel "date_entree" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Start date"@en,
        "Entité nommée : Date d'entrée"@fr .

anclass:NETakenFrom a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "A column value indicating either the folio number where the previous status of the parcel was recorded, or a special value providing information about that status."@en,
        "Valeur de colonne indiquant soit le numéro de folio où était décrit l'état précédent de la parcelle soit une valeur spéciale renseignant sur cet état."@fr ;
    skos:hiddenLabel "tire_de" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Previous folio or status"@en,
        "Entité nommée : Tiré de"@fr .

anclass:NETaxpayerActivity a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
        "Entité nommée identifiable dans une valeur de la colonne relative au contribuable."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Activity"@en,
        "Entité nommée : Activité"@fr ;
    skos:related anclass:NETaxpayer .

anclass:NETaxpayerAddress a owl:NamedIndividual,
