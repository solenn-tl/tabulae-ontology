anclass:NETaxpayerLastName a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
