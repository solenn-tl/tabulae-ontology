    skos:related anclass:NETaxpayer .

anclass:NETaxpayerNumber a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value containing the folio number or the alphabetical number of a taxpayer in the following mutation register."@en,
        "Valeur de colonne correspondant au numéro désignant le numéro de folio ou d'index dans la table alphabétique d'un contribuable dans la matrice suivant immédiatement l'état de sections."@fr ;
    skos:hiddenLabel "numero_proprietaire" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Folio Number"@en,
        "Entité nommée : Numéro de folio du propriétaire"@fr .

anclass:NETaxpayerOrganisationName a owl:NamedIndividual,
