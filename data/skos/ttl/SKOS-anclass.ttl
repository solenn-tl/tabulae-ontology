    skos:related anclass:NETaxpayer .

anclass:TableHeader a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to the header of a table."@en,
        "Zone d'une image correspondant à l'entête d'un tableau."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Table header"@en,
        "En-tête de tableau"@fr .

anclass:TableRow a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to a row of a table."@en,
        "Zone d'une image correspondant à une ligne de tableau"@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Table row"@en,
        "Ligne de tableau"@fr .

anclass:ETSTab a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:closeMatch anclass:ETSTabP1 ;
    skos:definition "Main table page of an initial register containing a description of the plots listed in ascending order by number."@en,
        "Page du tableau principal d'un registre d'états de sections contenant la description des parcelles listées dans l'ordre croissant des numéros."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Main table in an initial register"@en,
        "Tableau principal d'état de section"@fr ;
    skos:related anclass:Page .

anclass:ETSTabP1 a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:closeMatch anclass:ETSTab ;
    skos:definition "First page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822."@en,
        "Première page (sur deux) du tableau principal d'un registre d'état de sections contenant la description des parcelles listées dans l'ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822."@fr ;
    skos:hiddenLabel "ets_tab_p1" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "First page of a main table in an initial register"@en,
        "Tableau principal d'état de section (première page si double page)"@fr ;
    skos:related anclass:Page .

anclass:TextStyles a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Text style"@en,
        "Entité nommée : Style du texte"@fr .

anclass:NETaxpayer a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value corresponding to the taxpayer."@en,
        "Valeur de colonne correspondant au contribuable."@fr ;
    skos:hiddenLabel "identite" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Taxpayer"@en,
        "Entité nommée : Contribuable"@fr .

anclass:PageClasses a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:definition "List of classes that can be assigned to a single registry page in relation to a classification task."@en,
        "Liste des classes pouvant être attribuées à une page simple de registre, relatif à une tâche de classification."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Types of simple pages"@en,
        "Types de pages"@fr ;
    skos:related anclass:Page .

anclass:Page a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image showing a scanned single page from a register."@en,
        "Image correspondant à la numérisation d'une page simple de registre."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Simple-page"@en,
        "Page simple"@fr .

anclass:NamedEntityTypes a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:definition "Types of named entities that can be identified in land registry documents."@en,
        "Types d'entités nommées pouvant être reconnues dans les documents cadastraux."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Types of named entities"@en,
        "Types d'entités nommées"@fr .

