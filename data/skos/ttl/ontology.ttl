######## ---- Classes ---- ###########
######################################
## ---- Classes defined in the TABULAE ontology ----
tbl:AnnotationClass a owl:Class ;
    rdfs:label "Classe issue d'un processus d'annotation"@fr, "Class provided by an annotation process"@en;
    skos:prefLabel "Classe issue d'un processus d'annotation"@fr, "Class provided by an annotation process"@en ;
    skos:altLabel "Classe d'annotation"@fr, "Annotation class"@en ;
    rdfs:comment "Une classe d'annotation est utilisée pour caractériser pour un document ou un texte. Son attribution résulte d'un processus d'annotation automatique ou manuel."@fr,
        "An annotation class is used to characterise a document or text. It is assigned as a result of an automatic or manual annotation process."@en ;
    owl:disjointWith tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceType, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:AnnotationClassType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type de classe d'annotation"@fr, 
                "Type of annotation class"@en;
    skos:prefLabel "Type de classe d'annotation"@fr, "Type of annotation class"@en ;
    rdfs:comment "Cette classe permet de décrire les différents types de classes attribuées lors de processus d'annotation."@fr,
                "This class is used to describe the different types of classes assigned during annotation processes."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:EventType, tbl:SourceEvent, tbl:SourceType, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:EventType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type d'évènement"@fr, "Type of event"@en ;
    skos:prefLabel "Type d'évènement"@fr, "Type of event"@en ;
    rdfs:comment "Cette classe permet de décrire les différents types d'évènements."@fr,
                "This class allows describing different types of events."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:SourceEvent, tbl:SourceType, tbl:SourceChange,tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:SourceEvent a owl:Class ;
    rdfs:label "Evènement dans une source"@fr, "Event in a source"@en ;
    skos:prefLabel "Evènement dans une source"@fr, "Event in a source"@en ;
    rdfs:comment "Cette classe représente tout évènement spécifiquement associé à une source et impliquant un changement dans celle-ci."@fr,
                "This class represents any event that is specifically associated with a source and involves a change to that source."@en ;;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceType, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:SourceType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type de source"@fr, "Type of source"@en;
    skos:prefLabel "Type de source"@fr, "Type of source"@en ;
    rdfs:comment "Cette classe permet de décrire les différents types de sources."@fr, 
                "This class allows describing different types of sources."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:SourceChange a owl:Class ;
    rdfs:label "Changement dans une source"@fr ,
               "Source change"@en ;
    rdfs:comment "Cette classe représente tout changement qui implique un source."@fr,
                 "This class represents any change within a source."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:SourceChangeType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type de changement dans une source"@fr, "Type of change in a source"@en ;
    skos:prefLabel "Type de changement dans une source"@fr, "Type of change in a source"@en ;
    rdfs:comment "Cette classe permet de décrire les différents types de changements affectant une source."@fr,
                "This class allows describing different types of changes affecting a source."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:LandRegistryChangeType a owl:Class ;
    rdfs:subClassOf tbl:SourceChangeType ;
    skos:prefLabel "Type de changement sur un document cadastral"@fr, "Type of change on a land registry document"@en ;
    rdfs:label "Type de changement sur un document cadastral"@fr, "Type of change on a land registry document"@en ;
    rdfs:comment "Cette classe permet de décrire les différents types de changements affectant un document du corpus cadastral."@fr,
                "This class allows describing different types of changes affecting a document in the land registry corpus."@en ;
    rdfs:isDefinedBy tbl: .

tbl:NamedEntity a owl:Class ;
    rdfs:label "Named entity"@en, "Entité nommée"@fr ;
    skos:prefLabel "Named entity"@en, "Entité nommée"@fr ;
    rdfs:comment "Une entité nommée est correspond à une chaîne de caractères qui fait référence à une entité. Elle est identifiée par un processus manuel ou automatique d'annotation. Une entité nommée peut contenir d'autres entités nommées imbriquées."@fr,
                "A named entity is a string of characters that refers to an entity. It is identified through a manual or automatic annotation process. A named entity may contain other nested named entities."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:SourceChangeType, tbl:Nature, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:Nature a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Plot nature"@en, "Nature de parcelle"@fr ;
    skos:prefLabel "Plot nature"@en, "Nature de parcelle"@fr ;
    rdfs:comment "Une nature de parcelle correspond à une occupation ou un usage du sol."@fr ,
                "A plot nature corresponds to a land use or occupation."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:SpecialCellValue, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:SpecialCellValue a owl:Class;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Valeur spéciale des tables cadastrales"@fr, "Special value of cadastral tables"@en ;
    skos:prefLabel "Special cell value"@en, "Valeur spéciale"@fr ;
    rdfs:comment "Une valeur spéciale de cellule est liée au fonctionnement des documents cadastraux. Elles sont principalement observées dans les colonnes 'Tiré de' et 'Porté à' des matrices cadastrales, par exemple pour mentionner les actions de construction, destruction, augmentation de bâtiments."@fr,
                 "A specific cell value relates to the functioning of cadastral documents. These are mainly found in the ‘Taken from’ and ‘Updated to’ columns of cadastral registers, for example to record construction, demolition or extensions to buildings."@en;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:Taxpayer;
    rdfs:isDefinedBy tbl: .

tbl:Taxpayer a owl:Class;
    rdfs:label "Taxpayer"@en, "Contribuable"@fr ;
    skos:prefLabel "Taxpayer"@en, "Contribuable"@fr ;
    skos:altLabel "Owner"@en, "Propriétaire ou usufruitier"@fr ;
    rdfs:comment "Un contribuable est une personne physique ou morale redevable de l'impôt foncier pour les terres dont elle a la pleine propriété ou l'usufruit."@fr ,
                "A taxpayer is a natural or legal person liable for property tax for land for which they have full ownership or usufruct."@en ;
    owl:disjointWith tbl:AnnotationClass, tbl:AnnotationClassType, tbl:EventType, tbl:SourceEvent, tbl:SourceChange, tbl:SourceChangeType, tbl:NamedEntity, tbl:Nature, tbl:SpecialCellValue ;
    rdfs:isDefinedBy tbl: .

## ------ Imported classes ------
skos:Concept a owl:Class ;
    rdfs:isDefinedBy skos: ;
    rdfs:label "Concept" .

skos:ConceptScheme a owl:Class ;
    rdfs:isDefinedBy skos: ;
    rdfs:label "Concept scheme"@en , "Schéma de concepts"@fr .

### PROV-O classes
prov:Agent a owl:Class ;
    rdfs:isDefinedBy prov: ;
    rdfs:label "Agent" .

prov:SoftwareAgent a owl:Class ;
    rdfs:isDefinedBy prov: ;
    rdfs:label "SoftwareAgent" ;
    rdfs:subClassOf prov:Agent  .

prov:Activity a owl:Class ;
    rdfs:isDefinedBy prov: ;
    rdfs:label "Activity" ;
    owl:disjointWith prov:Entity .

### PeGazUs classes
peg:Address a owl:Class ;
    rdfs:label "Address"@en ,
            "Adresse"@fr ;
    rdfs:comment "Une adresse définit une référence spatiale indirecte d'un lieu qui est la cible de l'adresse. La manière dont ce lieu est décrit se fait comme étant une séquence de segments d'adresse étant chacun une description de relations entre entités."@fr,
    "An address defines an indirect spatial reference to a location that is the target of the address. This location is described as a sequence of address segments, each of which describes the relationships between entities."@en ;
    rdfs:isDefinedBy peg: .

peg:AttributeType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type d'attribut"@fr, "Attribute type"@en ;
    rdfs:comment "Un type d'attribut est une catégorie d'attributs définie par des caractéristiques communes."@fr,
                "An attribute type is a category of attributes defined by common characteristics."@en ;
    rdfs:isDefinedBy peg: .

peg:AttributeVersion a owl:Class ;
    rdfs:label "Attribute version"@en ,
                "Version de l'attribut"@fr ;
    rdfs:comment "Une version d'attribut est une version reliée à un attribut qui possède est définie par une valeur."@fr,
                "An attribute version is a version of an attribute which has a specific value."@en ;
    rdfs:isDefinedBy peg: .

peg:Event a owl:Class ;
    rdfs:comment "Un événément décrit une évolution impliquant une ou plusieurs ressources à un instant donné."@fr,
                "Event describing a development involving one or more resources at a given time."@en ;
    rdfs:label "Event"@en ,
                "Événément"@fr ;
    rdfs:isDefinedBy peg: .

peg:Landmark rdf:type owl:Class ;
          rdfs:label "Landmark"@en ,
                     "Repère"@fr ,
                     "Landmark"@en ;
          skos:altLabel "Entité géographique"@fr ,
                        "Entité spatiale"@fr ,
                        "Geographic entity"@en ,
                        "Spatial entity"@en ;
          rdfs:comment "Un repère est une entité géographique. Elle peut être une rue, un bâtiment, un pays ou tout autre point de référence dans l'espace."@fr,
          "A landmark is a geographic entity. It can be a street, a building, a country, or any other point of reference in space."@en ;
          rdfs:isDefinedBy peg: .

peg:LandmarkType a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Type de repère"@fr ,
        "Type of landmark"@en ;
    rdfs:comment "Un type de repère est une catégorie qui permet de classer les différents types de repères."@fr,
        "A type of landmark is a category that allows classifying the different types of landmarks."@en ;
    rdfs:isDefinedBy peg: .

peg:LandmarkRelation a owl:Class ;
    rdfs:label "Landmark relation"@en ,
                "Relation entre repères"@fr ;
    rdfs:comment """Il s'agit d'une relation qui représente un lien existant entre un ou plusieurs repères.
    Ces relations peuvent prendre diverses formes, notamment :
    - des relations géographiques, par exemple lorsqu'un point de repère est situé à l'angle de deux autres points de repère ;
    - des relations hiérarchiques, par exemple lorsqu'un point de repère est la capitale d'une autre entité administrative ;
    - d'autres relations spécifiques."""@fr ,
                    """It is a relation that represents a relation existing between one or more landmarks.
    Such relations may take various forms, including:
    - geographic relations, for example when a landmark is located at the corner of two other landmarks;
    - hierarchical relations, for example when a landmark is the capital of another administrative entity;
    - as well as other domain-specific or contextual relations depending on the application needs.
    """@en ;
    rdfs:isDefinedBy peg: .

### RiC-O classes
rico:RecordResource a owl:Class ;
    rdfs:label "Record Resource"@en,
        "Ressource archivistique"@fr ;
    rdfs:comment """Information produced or acquired and retained by an Agent in the
         course of life or work activity."""@en ;
    rdfs:isDefinedBy rico: .

rico:RecordSet a owl:Class ;
    rdfs:label "Record Set"@en, "Ensemble d’objets informationnels"@fr ;
    rdfs:comment """One or more records that are grouped together by an Agent based on
         the records sharing one or more attributes or relations."""@en ;
    rdfs:isDefinedBy rico: ;
    rdfs:subClassOf rico:RecordResource .

rico:Record a owl:Class ;
    rdfs:label "Record"@en,
        "Objet informationnel"@fr ;
    rdfs:comment """Discrete information content formed and inscribed, at least once,
         by any method on any carrier in any persistent, recoverable form by an Agent in the course
         of life or work activity."""@en ;
    rdfs:isDefinedBy rico: ;
    rdfs:subClassOf rico:RecordResource .

rico:RecordPart a owl:Class ;
    rdfs:label "Record Part"@en,
        "Partie d’objet informationnel"@fr ;
    rdfs:comment """Component of a Record with independent information content that
         contributes to the intellectual completeness of the Record."""@en ;
    rdfs:isDefinedBy rico: ;
    rdfs:subClassOf rico:RecordResource .

rico:Instantiation a owl:Class ;
    rdfs:label "Instantiation"@en,
        "Instanciation"@fr ;
    rdfs:comment """The inscription of information made by an Agent on a physical
         carrier in any persistent, recoverable form as a means of communicating information through
         time and space."""@en ;
    rdfs:isDefinedBy rico: .

#################################################################
#    Object Properties
#################################################################

## ------- Object Properties defined in the TABULAE ontology --------
tbl:hasPlotNature a owl:ObjectProperty ;
    rdfs:domain peg:AttributeVersion ;
    rdfs:range tbl:Nature ;
    rdfs:label "a pour nature de parcelle"@fr ,
        "has plot nature"@en;
    owl:inverseOf tbl:isPlotNatureOf;
    rdfs:comment "Relie une version d'attribut à une nature de parcelle (correspondant à une occupation ou à un usage du sol)."@fr ,
                    "Links an attribute version to a plot nature (corresponding to a land use or occupation)."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isPlotNatureOf a owl:ObjectProperty ;
    rdfs:domain tbl:Nature ;
    rdfs:range peg:AttributeVersion ;
    rdfs:label "est une nature de la parcelle"@fr ,
                "is nature of plot"@en;
    owl:inverseOf tbl:hasPlotNature;
    rdfs:comment "Relie une nature de parcelle (correspondant à une occupation ou à un usage du sol) à une version d'attribut."@fr ,
                    "Links a plot nature (corresponding to a land use or occupation) to an attribute version."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasTaxpayer a owl:ObjectProperty ;
    rdfs:domain peg:AttributeVersion ;
    rdfs:range tbl:Taxpayer ;
    rdfs:label "a pour contribuable"@fr ,
                "has taxpayer"@en ;
    owl:inverseOf tbl:isTaxpayerOf;
    rdfs:comment "Relie une version d'attribut d'une parcelle à un contribuable."@fr ,
                "Links an attribute version of a plot to a taxpayer."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isTaxpayerOf a owl:ObjectProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range peg:AttributeVersion ;
    rdfs:label "est le contribuable associé à"@fr ,
                "is associated taxpayer of"@en ;
    skos:altLabel "est le contribuable associé à la version d'attribut"@fr, 
                    "is taxpayer of attribute version"@en ;
    owl:inverseOf tbl:hasTaxpayer;
    rdfs:comment "Relie un contribuable à une version d'attribut d'une parcelle."@fr ,
                "Links a taxpayer to an attribute version of a plot."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasPlotAddress a owl:ObjectProperty ;
    rdfs:domain peg:AttributeVersion ;
    rdfs:range [ a owl:Class ;
                    owl:unionOf ( peg:Address
                                  peg:LandmarkRelation
                                  peg:Landmark
                                )
                  ] ;
    rdfs:label "parcelle a pour adresse"@fr ,
               "has plot address"@en ;
    skos:prefLabel "parcelle a pour adresse"@fr, "plot has address"@en ;
    skos:altLabel "has address of plot"@en, "a pour adresse de parcelle"@fr ;
    owl:inverseOf tbl:isPlotAddressOf;
    rdfs:comment "Relie une version d'attribut d'une parcelle à une adresse ou une relation spatiale ou un repère géographique."@fr ,
                    "Links an attribute version of a plot to an address or a spatial relation or a landmark."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isPlotAddressOf a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( peg:Address
                                  peg:LandmarkRelation
                                  peg:Landmark
                                )
                  ] ;
    rdfs:range peg:AttributeVersion ;
    rdfs:label "est l'adresse associée à"@fr ,
               "is plot address of"@en ;
    owl:inverseOf tbl:hasPlotAddress;
    rdfs:comment "Relie une adresse ou une relation spatiale ou un repère géographique à une version d'attribut d'une parcelle."@fr ,
                "Links an address, a spatial relationship or a geographical reference to an attribute version of a plot."@en ;
    rdfs:isDefinedBy tbl: .

tbl:taxpayerHasAddressEntity a owl:ObjectProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range owl:Thing ;
    rdfs:label "contribuable a pour adresse (entité)"@fr ,
               "taxpayer has address (entity)"@en ;
    owl:inverseOf tbl:isAddressEntityOfTaxpayer;
    rdfs:comment "Relie un contribuable à une adresse ou à un repère géographique. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress."@fr ,
                    "Links a taxpayer to an address or a landmark. For the addresses provided as strings, see tbl:taxpayerAddress."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isAddressEntityOfTaxpayer a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range tbl:Taxpayer ;
    rdfs:label "adresse (entité) du contribuable"@fr ,
               "is address (entity) of a taxpayer"@en ;
    owl:inverseOf tbl:taxpayerHasAddressEntity;
    rdfs:comment "Relie une adresse ou un repère géographique à un contribuable. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress."@fr ,
                "Links an address or a landmark to a taxpayer. For the addresses provided as strings, see tbl:taxpayerAddress."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasEquivalentFolio a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    rdfs:range [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    rdfs:label "a pour folio équivalent"@fr ,
               "has equivalent folio"@en ;
    rdfs:comment "Cette propriété associe deux folios issus d'une ou deux matrices du cadastre d'une une même commune existant sucessivement ou parallèlement."@fr,
                "This property links two folios from one or two mutation registers of a same municipality – whether they existed successively or in parallel."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:deprecated true .

tbl:isSourceType a owl:ObjectProperty ;
    rdfs:domain owl:Thing  ;
    rdfs:range tbl:SourceType ;
    rdfs:label "est une source de type"@fr ,
                "is source type"@en ;
    rdfs:comment "Cette propriété permet d'associer une source à un type de source."@fr,
        "This property allows to associate a source to a source type."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isSourceChangeType a owl:ObjectProperty ;
    rdfs:domain tbl:SourceChangeType ;
    rdfs:range tbl:SourceChange ;
    rdfs:label "est le type de changement dans une source"@fr ,
                "is source change type"@en ;
    rdfs:comment "Cette propriété permet d'associer un type de changement impliquant une source à un changement."@fr,
        "This property allows you to associate a type of change involving a source with a change."@en ;
    rdfs:isDefinedBy tbl: .

#tbl:hasClasse a owl:ObjectProperty ;
#    owl:deprecated true ;
#    owl:backwardCompatibleWith tbl:hasClass ;
#    rdfs:isDefinedBy tbl: .
    
tbl:sourceChangedBy a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( 
                          rico:RecordResource
                          rico:Instantiation     
                        )
            ] ;
    rdfs:range tbl:SourceChange ;
    rdfs:label "source changée par"@fr ,
                "source changed by"@en ;
    rdfs:comment "Cette propriété relie une source à un changement qui la modifie."@fr,
                "This property links a source to a change that modifies it."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:appliedToSource .

tbl:appliedToSource a owl:ObjectProperty ;
    rdfs:domain tbl:SourceChange ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( 
                          rico:RecordResource
                          rico:Instantiation     
                        )
            ] ;
    rdfs:label "changement appliqué à la source"@fr ,
                "change applied to source"@en ;
    rdfs:comment "Cette propriété relie un changement à une source qu'il modifie."@fr,
                "This property links a change to a source it modifies."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:sourceChangedBy .

tbl:sourceChangeDependsOn a owl:ObjectProperty ;
    rdfs:domain tbl:SourceChange ;
    rdfs:range tbl:SourceEvent ;
    rdfs:label "changement d'une source dépendant de"@fr ,
                "source change depends on"@en ;
    rdfs:comment "Cette propriété relie un changement modifiant une source à l'évènement dont il dépend."@fr,
                "This property links a change modifying a source to the event on which it depends."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:hasSourceChange .

tbl:hasSourceChange a owl:ObjectProperty ;
    rdfs:domain tbl:SourceEvent ;
    rdfs:range tbl:SourceChange ;
    rdfs:label "créé un changement dans une source"@fr ,
                "creates source change"@en ;
    rdfs:comment "Cette propriété relie un évènement à un changement qu'il déclenche dans une source."@fr,
                "This property links an event to a change it triggers in a source."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:sourceChangeDependsOn .

tbl:adds a owl:ObjectProperty ;
    rdfs:domain tbl:SourceChange ;
    rdfs:range owl:Thing ;
    rdfs:label "ajoute"@fr ,
               "adds"@en ;
    rdfs:comment "Cette propriété relie un changement dans une source à un élément qu'il ajoute à cette source."@fr,
                 "This property links a change in a source to an element that it adds to that source."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:isAddedBy . 

tbl:isAddedBy a owl:ObjectProperty ; 
    rdfs:domain owl:Thing ;
    rdfs:range tbl:SourceChange ;
    rdfs:label "est ajouté par"@fr ,
               "is added by"@en ; 
    rdfs:comment "Cette propriété relie un élément au changement qui l'a associé à une source."@fr,
                 "This property links an element to the change that associated it with a source."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:adds .

tbl:deletes a owl:ObjectProperty ;
    rdfs:domain tbl:SourceChange ;
    rdfs:range owl:Thing ;
    rdfs:label "supprime"@fr ,
               "deletes"@en ;
    rdfs:comment "Cette propriété relie un changement à un élément qu'il supprime ou rend obsolète dans une source."@fr,
                 "This property links a change to an element that it removes or renders obsolete in a source."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:isDeletedBy .

tbl:isDeletedBy a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range tbl:SourceChange ;
    rdfs:label "est supprimé par"@fr ,
               "is deleted by"@en ;
    rdfs:comment "Cette propriété relie un élément au changement qui l'a rendu obsolète (ou supprimé) dans une source."@fr,
                 "This property links an element to the change that rendered it obsolete (or deleted) in the source."@en ;
    rdfs:isDefinedBy tbl: ;
    owl:inverseOf tbl:deletes .

tbl:hasClass a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range tbl:AnnotationClass ;
    rdfs:comment "Relie une chose (par exemple : un document) à une classe d'annotation."@fr,
                 "Links a thing (for example: a document) to an annotation class."@en ;
    rdfs:label "a pour classe"@fr ,
                "has class"@en ;
    rdfs:isDefinedBy tbl: .

tbl:isClassOf a owl:ObjectProperty ;
    rdfs:domain tbl:AnnotationClass ;
    rdfs:range owl:Thing ;
    rdfs:label "classe attribuée à"@fr ,
                "is class of"@en ;
    rdfs:comment "Relie une classe d'annotation à une chose (par exemple : un document)."@fr,
                 "Links an annotation class to a thing (for example: a document)."@en ;
    owl:inverseOf tbl:hasClass ;
    rdfs:isDefinedBy tbl: .

tbl:hasClassValue a owl:ObjectProperty ;
    rdfs:domain tbl:AnnotationClass ;
    rdfs:range tbl:AnnotationClassType ;
    rdfs:comment "Cette propriété relie une classe d'annotation à une type de classe."@fr,
                 "This property links an annotation class to a class type."@en ;
    rdfs:label "a pour valeur de classe"@fr ,
                "has class value"@en ;
    owl:inverseOf tbl:isClassValueOf;
    rdfs:isDefinedBy tbl: .

tbl:isClassValueOf a owl:ObjectProperty ;
    rdfs:domain tbl:AnnotationClassType ; 
    rdfs:range tbl:AnnotationClass ;
    rdfs:label "est la valeur de classe attribuée à"@fr ,
                "is class value of"@en ;
    skos:prefLabel "est la valeur de classe attribuée à"@fr , 
                "is class value of"@en ;
    rdfs:comment "Cette propriété relie une valeur de classe à la classe à laquelle elle est attribuée."@fr,
                 "This property links a class value to the class to which it is assigned."@en ;
    owl:inverseOf tbl:hasClassValue ;
    rdfs:isDefinedBy tbl: .

tbl:isEventType a owl:ObjectProperty ;
    rdfs:domain peg:Event ;
    rdfs:range tbl:EventType ;
    rdfs:label "est un événement de type"@fr,
               "is event type"@en ;
    rdfs:comment "Cette propriété relie un événement à son type."@fr,
                "This property links an event to its type."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasNamedEntity a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range tbl:NamedEntity ;
    rdfs:label "possède l'entité nommée"@fr,
               "includes named entity"@en ;
    rdfs:comment "Cette propriété relie un élément (par exemple une source) à une entité nommée identifiée dans celle-ci."@fr,
                "This property links an element (for example a source) to a named entity identified within it."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isNamedEntityOf a owl:ObjectProperty ;
    rdfs:domain tbl:NamedEntity ;
    rdfs:range owl:Thing ;
    rdfs:label "est une entité nommée de"@fr,
               "is named entity of"@en ;
    rdfs:comment "Cette propriété relie une entité nommée identifiée dans celle-ci à l'élément qui la contient."@fr,
                "This property links a named entity identified within it to the element that contains it."@en ;
    owl:inverseOf tbl:hasNamedEntity;
    rdfs:isDefinedBy tbl: .

tbl:isNamedEntityType a owl:ObjectProperty ;
    rdfs:subPropertyOf tbl:hasClassValue ;
    rdfs:domain tbl:NamedEntity ;
    rdfs:range tbl:AnnotationClass ;
    rdfs:label "est une entité nommée de type"@fr,
                "is named entity type"@en ;
    rdfs:comment "Cette propriété relie une entité nommée à son type."@fr,
                "This property links a named entity to a named entity type."@en ;
    rdfs:isDefinedBy tbl: .

tbl:mentions a owl:ObjectProperty;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( rico:RecordResource
                          rico:Instantiation
                        )
            ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( 
                          peg:AttributeVersion
                          tbl:Taxpayer
                          peg:Landmark
                          peg:LandmarkVersion
                        )
            ] ;
    rdfs:comment "Cette propriété relie une source à une entité (telle qu'une entité géographique ou un contribuable) ou information qu'elle mentionne."@fr,
                "This property links a source to an entity (as a geographical entity or a taxpayer) or information that it mentions."@en ;
    rdfs:label "mentionne"@fr,
               "mentions"@en ;
    owl:inverseOf tbl:isMentionnedIn;
    rdfs:isDefinedBy tbl: .

tbl:isMentionnedIn a owl:ObjectProperty;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( 
                          peg:AttributeVersion
                          tbl:Taxpayer
                          peg:Landmark
                          peg:LandmarkVersion
                        )
            ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( rico:RecordResource
                          rico:Instantiation
                        )
            ] ;
    rdfs:comment "Cette propriété relie une entité (telle qu'une entité géographique ou un contribuable) ou information à la source dans laquelle elle est mentionnée."@fr,
                "This property links an entity (as a geographical entity or a taxpayer) or information to the source in which it is mentioned."@en ;
    rdfs:label "est mentionné dans"@fr,"is mentionned in"@en ;
    owl:inverseOf tbl:mentions;
    rdfs:isDefinedBy tbl: .

tbl:takenFrom a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( 
                          peg:AttributeVersion
                          peg:Landmark
                          peg:LandmarkVersion
                        )
            ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( rico:RecordResource
                          rico:Instantiation
                          tbl:SpecialCellValue
                        )
            ] ;
    rdfs:label "état ou localisation documentaire précédent"@fr,
               "previous state or location in document"@en ;
    skos:prefLabel "état ou localisation documentaire précédent"@fr,
               "previous state or location in document"@en ;
    skos:altLabel "tiré de"@fr, "taken from"@en ;
    rdfs:comment "Cette propriété relie un repère, une version de repère ou d'attribut à son état précédent ou à la localisation documentaire de sa dernière description."@fr ,
                "This property links a reference, a version of a reference or an attribute to its previous state or to the documentary location of its most recent description."@en ;
    rdfs:isDefinedBy tbl: .

tbl:passedTo a owl:ObjectProperty;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( 
                          peg:AttributeVersion
                          peg:Landmark
                          peg:LandmarkVersion
                        )
            ] ;
    rdfs:range [ a owl:Class ;
        owl:unionOf ( rico:RecordResource
                        rico:Instantiation
                        tbl:SpecialCellValue
                    )
        ] ;
    rdfs:label "état ou localisation documentaire suivant"@fr,
               "next state or location in document"@en ;
    skos:prefLabel "état ou localisation documentaire suivant"@fr,
               "next state or location in document"@en ;
    skos:altLabel "passé à"@fr, "passed to"@en ;
    rdfs:comment "Cette propriété relie un repère, une version de repère ou d'attribut à son état suivant ou à la localisation documentaire de sa description suivante."@fr ,
                "This property links a reference, a version of a reference or an attribute to its next state or to the documentary location of its next description."@en ;
    rdfs:isDefinedBy tbl: .

tbl:sourcedFrom a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    rdfs:comment "Une affirmation est issue d'une source."@fr, 
                "A statement is sourced from a source."@en ;
    rdfs:label "a pour source"@fr, "sourced from"@en ;
    owl:deprecated true ;
    dcterms:isReplacedBy peg:hasTrace;
    owl:backwardCompatibleWith peg:hasTrace;
    owl:equivalentProperty peg:hasTrace;
    rdfs:isDefinedBy tbl: .

tbl:hasPreviousVersionInSRCOrder a owl:ObjectProperty ;
    rdfs:label "a pour version précédente dans les documents"@fr,
               "has previous version in the source order"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    owl:inverseOf tbl:hasNextVersionInSRCOrder;
    rdfs:comment "Cette propriété indique qu'une version d'une chose précéde la version considérée selon les ordres temporel et documentaire. Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS."@fr,
                    "This property indicates that a version of an entity precedes it in both chronological and documentary order. This property is used in the PeGaZuS ontology population algorithm."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasNextVersionInSRCOrder a owl:ObjectProperty ;
    rdfs:label "a pour version suivante dans les documents"@fr,
               "has next version in the source order"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    owl:inverseOf tbl:hasPreviousVersionInSRCOrder;
    rdfs:comment "Cette propriété indique qu'une version d'une chose suit la version considérée selon les ordres temporel et documentaire. Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS."@fr,
    "This property indicates that a version of an entity follows it in both chronological and documentary order. This property is used in the PeGaZuS ontology population algorithm."@en ;
    rdfs:isDefinedBy tbl: .

tbl:hasOverlappingVersionInSRCOrder a owl:ObjectProperty ;
    rdfs:label "a pour version qui se chevauche dans les documents"@fr,
               "has overlapping version in the source order"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    owl:inverseOf tbl:isOverlappedByVersionInSRCOrder;
    rdfs:comment "Cette propriété indique qu'une version considérée d'une entité recouvre partiellement une autre version selon les ordres temporel et documentaire. Cette propriété est utilisée dans l'algorithme de remplissage de l'ontologie PeGaZuS."@fr ;
    rdfs:comment "This property indicates that a version of an entity has an overlapping version according to the temporal and documentary orders. This property is used in the PeGaZuS ontology population algorithm."@en ;
    rdfs:isDefinedBy tbl: .

tbl:isOverlappedByVersionInSRCOrder a owl:ObjectProperty ;
    rdfs:label "est chevauchée par la version dans les documents"@fr,
               "is overlapped by version in the source order"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    owl:inverseOf tbl:hasOverlappingVersionInSRCOrder;
    rdfs:comment "Cette propriété indique qu'une version donnée d'une entité est partiellement recouverte par une autre version selon les ordres temporel et documentaire. Cette propriété est utilisée dans l'algorithme de peuplage de l'ontologie PeGaZuS."@fr ;
    rdfs:comment "This property indicates that a version of an entity is partially overlapped by another version according to the temporal and documentary orders. This property is used in the PeGaZuS ontology population algorithm."@en ;
    rdfs:isDefinedBy tbl: .

