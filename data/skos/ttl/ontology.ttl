## ------- Imported Object Properties --------
#### ------ PeGazUs object properties -------
peg:hasTrace a owl:ObjectProperty ;
    rdfs:label "a pour trace"@fr, "has trace"@en ;
    rdfs:comment "Décrit qu'un élément a pour trace un autre élément"@fr, "Describes that an element has another element as its trace"@en ;
    owl:inverseOf peg:isTraceOf;
    rdfs:isDefinedBy peg: .

peg:isTraceOf a owl:ObjectProperty ;
    rdfs:label "est une trace de"@fr, "is trace of"@en ;
    rdfs:comment "Décrit qu'un élément est la trace d'un autre élément"@fr, "Describes that an element is the trace of another element"@en ;
    owl:inverseOf peg:hasTrace;
    rdfs:isDefinedBy peg: .

#### Prov-O object properties
prov:wasAssociatedWith a owl:ObjectProperty ;
    rdfs:isDefinedBy prov: .
    
prov:used a owl:ObjectProperty ;
    rdfs:isDefinedBy prov: .

prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:isDefinedBy prov: .

#### Records in Context Ontology (RiC-O) object properties

rico:includesOrIncluded a owl:ObjectProperty ;
    rdfs:label "includes or included"@en, "inclut ou a inclus"@fr ;
    rdfs:comment """Connects a Record Set to a Record or Record Set it aggregates, or
         aggregated in the past."""@en ;
    rdfs:domain rico:RecordSet ;
    rdfs:isDefinedBy rico: ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordSet ) ] ;
    rdfs:subPropertyOf rico:hasOrHadPart,
        rico:isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf rico:isOrWasIncludedIn .

rico:isOrWasIncludedIn a owl:ObjectProperty ;
    rdfs:label "is or was included in"@en, "est ou a été inclus dans"@fr ;
    rdfs:comment "Inverse of 'includes or included' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordSet ) ] ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:RecordSet ;
    rdfs:subPropertyOf rico:isOrWasPartOf,
        rico:isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf rico:includesOrIncluded.

rico:hasOrHadConstituent a owl:ObjectProperty ;
    rdfs:label "has or had constituent"@en, "a ou a eu pour constituant"@fr ;
    rdfs:comment """Connects a Record or Record Part to a Record or Record part that
         is or was a constituent of that Record or Record Part."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordPart ) ] ;
    rdfs:isDefinedBy rico: ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordPart ) ] ;
    rdfs:subPropertyOf rico:hasOrHadPart,
        rico:isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf rico:isOrWasConstituentOf .

rico:isOrWasConstituentOf a owl:ObjectProperty ;
    rdfs:label "is or was constituent of"@en, "est ou a été un constituant de"@fr ;
    rdfs:comment """Inverse of 'has or had constituent' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordPart ) ] ;
    rdfs:isDefinedBy rico: ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( rico:Record rico:RecordPart ) ] ;
    rdfs:subPropertyOf rico:isOrWasPartOf,
        rico:isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf rico:hasOrHadConstituent .

rico:hasOrHadInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had instantiation"@en,
        "tiene o tenía como instanciación"@es,
        "a ou a eu pour instanciation"@fr ;
    rdfs:comment """Connects a Record Resource to an Instantiation, which either may
         exist or may have been lost or destroyed."""@en ;
    rdfs:domain rico:RecordResource ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:isRelatedTo ;
    owl:inverseOf rico:isOrWasInstantiationOf .

rico:isOrWasInstantiationOf a owl:ObjectProperty ;
    rdfs:label "is or was instantiation of"@en,
        "est ou a été une instanciation de"@fr ;
    rdfs:comment """Inverse of 'has or had instantiation' object property."""@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:RecordResource ;
    rdfs:subPropertyOf rico:isRelatedTo ;
    owl:inverseOf rico:hasOrHadInstantiation .

rico:hasOrHadComponent a owl:ObjectProperty ;
    rdfs:label "has or had component"@en, "a ou a eu pour composant"@fr ;
    rdfs:comment """Connects an Instantiation to one of its present or past component
         instantiations."""@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:hasOrHadPart,
        rico:isInstantiationAssociatedWithInstantiation ;
    owl:inverseOf rico:isOrWasComponentOf .

rico:isOrWasComponentOf a owl:ObjectProperty ;
    rdfs:label "is or was component of"@en, "est ou a été un composant de"@fr ;
    rdfs:comment "Inverse of 'has or had component' object property."@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:isInstantiationAssociatedWithInstantiation,
        rico:isOrWasPartOf ;
    owl:inverseOf rico:hasOrHadComponent .

rico:hasOrHadDigitalInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had digital instantiation"@en, "a ou a eu pour instanciation numérique"@fr ;
    rdfs:comment """Connects a record resource to one of its digital instantiations,
         whether it exists or has been lost or destroyed."""@en ;
    rdfs:domain rico:RecordResource ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:hasOrHadInstantiation ;
    owl:inverseOf rico:isOrWasDigitalInstantiationOf .

rico:isOrWasDigitalInstantiationOf a owl:ObjectProperty ;
    rdfs:label "is or was digital instantiation of"@en, "est ou a été une instanciation numérique de"@fr ;
    rdfs:comment """Inverse of 'has or had digital instantiation' object property."""@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:RecordResource ;
    rdfs:subPropertyOf rico:isOrWasInstantiationOf ;
    owl:inverseOf rico:hasOrHadDigitalInstantiation .

rico:hasOrHadDerivedInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had derived instantiation"@en, "a ou a eu pour instanciation dérivée"@fr ;
    rdfs:comment """Connects an instantiation to an instantiation that is derived from
         it, whether it exists or has been lost or destroyed."""@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:isInstantiationAssociatedWithInstantiation,
        rico:precedesInTime ;
    owl:inverseOf rico:isOrWasDerivedFromInstantiation  .

rico:isOrWasDerivedFromInstantiation a owl:ObjectProperty ;
    rdfs:label "is or was derived from instantiation"@en, "est ou a été une instanciation dérivée de"@fr ;
    rdfs:comment """Inverse of 'has or had derived instantiation' object property."""@en ;
    rdfs:domain rico:Instantiation ;
    rdfs:isDefinedBy rico: ;
    rdfs:range rico:Instantiation ;
    rdfs:subPropertyOf rico:followsInTime,
        rico:isInstantiationAssociatedWithInstantiation ;
    owl:inverseOf rico:hasOrHadDerivedInstantiation .

#################################################################
#    Datatype properties
#################################################################
tbl:spanValue a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( owl:Thing
                      tbl:NamedEntity
                    )
        ] ;
    rdfs:range xsd:string ;
    rdfs:comment "Indiquer la valeur d'une sous-chaîne de caractères."@fr,
                 "Indicates the value of a substring."@en ;
    rdfs:label "valeur de la sous-chaîne"@fr ,
                "span value"@en.

tbl:indexOfFirstCharacter a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Indiquer l'index du premier caractère d'une sous-chaîne de caractères dans un texte. Index à partir de 0."@fr,
                 "Indicates the index of the first character of a substring. Index starts from 0."@en ;
    rdfs:label "index du premier caractère"@fr ,
                "index of first character"@en.

tbl:indexOfLastCharacter a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Indique l'index du dernier caractère d'une sous-chaîne de caractères dans un texte. Index à partir de 0."@fr,
                 "Indicates the index of the last character of a substring. Index starts from 0."@en ;
    rdfs:label "index du dernier caractère"@fr ,
                "index of last character"@en.

tbl:imageURL a owl:DatatypeProperty ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "URL d'image"@fr, "image URL"@en ;
    rdfs:comment "Renseigne l'URL d'une image représentant un document ou une partie de document."@fr,
                 "Indicates the URL of an image representing a document or part of a document."@en .

tbl:IIIFImageUrl a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:imageURL ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "URL d'image IIIF"@fr, "IIIF image URL"@en ;
    rdfs:comment "URL d'une image fournie par l'API IIIF (International Image Interoperability Framework) représentant un document ou une partie de document."@fr,
                 "URL of an image provided by the IIIF (International Image Interoperability Framework) image representing a document or part of a document."@en .

tbl:taxpayerLabel a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Label d'un contribuable, qui peut être son nom complet (pour une personne physique) ou sa raison sociale (pour une personne morale)."@fr,
                 "Label of a taxpayer, which can be their full name (for an individual) or their company name (for a legal entity)."@en ;
    rdfs:label "label de contribuable"@fr, "taxpayer label"@en .

tbl:taxpayerFullName a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:taxpayerLabel ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Identité complète d'un contribuable (personne physique) composée a minima d'un nom de famille et optionnellement d'un ou plusieurs prénoms et d'un statut familial."@fr,
                 "Full identity of an individual taxpayer: last name and first names."@en ;
    rdfs:label "nom complet"@fr, "full name"@en .

tbl:taxpayerLastName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Nom de famille d'un contribuable"@fr,
                 "Last name of a taxpayer"@en ;
    rdfs:label "nom de famille"@fr, "last name"@en .

tbl:taxpayerFirstName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom (unitiare) d'un contribuable. En pratique peu utilisée car implique de connaître de façon certaine l'état civil d'un contribuable."@fr,
                 "Unique first name of a taxpayer. Generally not used in practice as it requires certain knowledge of the taxpayer's civil status."@en ;
    rdfs:label "prénom unique"@fr, "unique first name"@en.

tbl:taxpayerFirstNames a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom(s) d'un contribuable, généralement présentés sous la forme d'une liste de prénoms dans les documents. Dans le cas des contribuables ayant le statut familial 'Mme' ou 'Veuve', le prénom indiqué est généralement celui de l'époux."@fr,
                 "First name(s) of a taxpayer, generally presented as a list of first names in documents. In the case of taxpayers with the family status 'Mrs' or 'Widow', the indicated first name is generally that of the spouse."@en ;
    rdfs:label "prénom(s)"@fr, "first name(s)"@en ;
    tbl:isPreferredOver tbl:taxpayerFirstName .

tbl:taxpayerBirthName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Nom de naissance d'une contribuable. Par exemple, le nom de naissance d'une personne avant son mariage (sans le cas où elle utilise ensuite le nom de son époux/épouse)."@fr,
                 "Birth name of a taxpayer."@en ;
    rdfs:label "nom de naissance"@fr, "birth name"@en .

tbl:taxpayerSpouseOrChildrenFirstNames a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom(s) de l'époux/épouse ou d'un enfant dans un libellé de compte foncier. Généralement indiqués en seconde partie de libellé en complémenant de l'identité d'un contribuable 'racine' (le titulaire initial du compte foncier)."@fr,
                    "First name(s) of the spouse or a child in a land registry folio label, generally indicated in the second part of the label."@en ;
    rdfs:label "prénom(s) de l'époux/épouse ou d'un enfant"@fr, "spouse or children first name(s)"@en .

tbl:taxpayerOrganisationName a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:taxpayerLabel ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Raison sociale d'un contribuable personne morale"@fr,
                 "Company name of a legal entity taxpayer"@en ;
    rdfs:label "raison sociale"@fr, "organisation name"@en .

tbl:taxpayerStatus a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Statut d'un contibuable qui n'est pas lié à son statut familial. Exemple : 'Non imposable'"@fr ,
                 "Status of a taxpayer which is not related to their family status."@en ;
    rdfs:label "statut"@fr, "status"@en .

tbl:taxpayerFamilyStatus a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Statut d'un contribuable lié à son statut ou à ses relations familiales (Veuve, Veuf, Fils, Fille, Mineur, Héritiers)"@fr ,
                 "Status of a taxpayer related to their family status or relationships (Widow, Widower, Son, Daughter, Minor, Heirs)"@en ;
    rdfs:label "statut familial"@fr, "family status"@en .

tbl:taxpayerAddress a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Adresse d'un contribuable renseignée sous la forme d'une chaîne de caractères. Pour les adresses sous forme d'entités, voir tbl:taxpayerHasAddressEntity."@fr, 
    "Address of a taxpayer provided as a string. For addresses as entities, see tbl:taxpayerHasAddressEntity."@en ;
    rdfs:label "adresse du contribuable"@fr, "taxpayer address"@en .

tbl:taxpayerActivity a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Activité d'un contribuable, généralement relatif à l'activité professionnelle"@fr, "Activity of a taxpayer, generally related to their professional activity"@en ;
    rdfs:label "activité du contribuable"@fr, "taxpayer activity"@en.

tbl:taxpayerTitle a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Civilité (M, Mme, etc.), titre de noblesse (Prince de, Marquis de, etc.) ou titre honorifique"@fr, "Civility (Mr, Mrs, etc.), noble title (e.g., Prince of, Marquis of) or honorific"@en ;
    rdfs:label "titre"@fr, "title"@en.

tbl:hasNumFolio a owl:DatatypeProperty ;
    owl:deprecated true ;
    owl:backwardCompatibleWith tbl:hasFolioNumber ;
    owl:equivalentProperty tbl:hasFolioNumber;
    dcterms:replacedBy tbl:hasFolioNumber .

tbl:hasFolioNumber a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    owl:equivalentProperty tbl:hasNumFolio ;
    rdfs:range xsd:string ;
    rdfs:comment "Numéro de folio (associé à une page entière ou à une partie de page) "@fr, "folio number (associated to a mutation register page or part of page)"@en ;
    rdfs:label "a pour numéro de folio"@fr,
               "has folio number"@en .

tbl:hasAlternativeNumFolio a owl:DatatypeProperty ;
    owl:deprecated true ;
    owl:backwardCompatibleWith tbl:hasAlternativeFolioNumber ;
    owl:equivalentProperty tbl:hasAlternativeFolioNumber ;
    dcterms:replacedBy tbl:hasAlternativeFolioNumber .

tbl:hasAlternativeFolioNumber a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    rdfs:range xsd:string ;
    owl:equivalentProperty tbl:hasAlternativeNumFolio ;
    rdfs:comment "Numéro de folio alternatif (ex: ancien numéro)"@fr, "Alternative folio number (e.g. former number)"@en;
    rdfs:label "a pour numéro de folio alternatif"@fr, "has alternative folio number"@en .

tbl:transcription a owl:DatatypeProperty ;
  rdfs:domain owl:Thing ;
  rdfs:range rdfs:Literal ;
  rdfs:label "transcription"@en, "transcription"@fr;
  skos:prefLabel "transcription"@en, "transcription"@fr ;
  rdfs:comment "Transcription d'une zone ou d'une entité obtenue automatiquement ou manuellement à partir d'un document (numérisé)."@fr,
                "Transcription of an area or an entity obtained automatically or manually from a (scanned) document."@en.

tbl:coordinatesInImageSystem a owl:DatatypeProperty ;
  rdfs:domain rico:Instantiation ;
  rdfs:range rdfs:Literal ;
  skos:prefLabel "coordinates in image"@en, "coordonnées dans l'image"@fr;
  rdfs:label "coordinates in image"@en, "coordonnées dans l'image"@fr;
  rdfs:comment "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé.".

tbl:xywhCoordinates a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:coordinatesInImageSystem ;
    rdfs:domain rico:Instantiation ;
    rdfs:range rdfs:Literal ;
    skos:prefLabel "xywh coordinates in image"@en, "coordonnées xywh dans l'image"@fr;
    rdfs:label "xywh coordinates in image"@en, "coordonnées xywh dans l'image"@fr;
    rdfs:comment "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé, sous la forme d'un rectangle défini par les coordonnées x et y du coin supérieur gauche et la largeur et la hauteur du rectangle (tel que requis dans les spécifications IIIF). Par exemple : 1160,1103,1529,1421"@fr,
                 "Coordinates (image reference system) of an annotated area (manually or automatically) in a scanned document, in the form of a rectangle defined by the x and y coordinates of the upper left corner and the width and height of the rectangle (as required in the IIIF specifications). For example: 1160,1103,1529,1421"@en.

tbl:lineOrderInArea a owl:DatatypeProperty ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:integer ;
    skos:prefLabel "row order in area"@en, "ordre de ligne dans la zone"@fr;
    rdfs:label "row order in area"@en, "ordre de ligne dans la zone"@fr;
    rdfs:comment "Ordre de la ligne dans la zone annotée (manuellement ou automatiquement) dans un document numérisé.".

tbl:TFNBGroup a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    skos:prefLabel "TFNB group"@en, "groupe TFNB"@fr;
    rdfs:label "TFNB group"@en, "groupe TFNB"@fr;
    rdfs:comment "Groupe de TFNB (Taxe Foncière sur les Propriétés Non Bâties) d'une parcelle, tel qu'indiqué dans les documents cadastraux. La table utilisée est disponible <a href='https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812'>cette URL</a>."@fr,
                 "Group of TFNB (Taxe Foncière sur les Propriétés Non Bâties) of a plot, as indicated in modern cadastral documents. The table who ispired this property is available at <a href='https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812'>this URL</a>"@en;
    rdfs:seeAlso <https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812>.

tbl:URL a owl:DatatypeProperty ;
  rdfs:domain owl:Thing ;
  rdfs:range rdfs:Literal ;
  skos:prefLabel "source URL"@en, "url de la source"@fr;
  rdfs:label "url de la source"@fr, "source URL"@en;
  rdfs:comment 'Correspond à l\'URL de la source (image, base de donnée)'.

# ---- Properties copied here to avoid imports ----
#rdfs:label a owl:DatatypeProperty.
dcterms:identifier a owl:DatatypeProperty;
    rdfs:isDefinedBy dcterms: .

p:P8422 a owl:DatatypeProperty;
    rdfs:label "identifiant Ldh/EHESS/Cassini"@fr;
    rdfs:isDefinedBy p: .

rico:identifier a owl:DatatypeProperty ;
    rdfs:isDefinedBy rico: .

rico:name a owl:DatatypeProperty ;
    rdfs:isDefinedBy rico: .

dcterms:spatial a owl:DatatypeProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:date a owl:DatatypeProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:created a owl:DatatypeProperty ;
    rdfs:isDefinedBy dcterms: .