  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Attribut"
  }, {
    "@language" : "en",
    "@value" : "Attribute"
  } ]
}, {
  "@id" : "https://w3id.org/PeGazUs#AttributeType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An attribute type is a category of attributes defined by common characteristics."
  }, {
    "@language" : "fr",
    "@value" : "Un type d'attribut est une catégorie d'attributs définie par des caractéristiques communes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/PeGazUs#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Attribute type"
