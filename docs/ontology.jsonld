  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A change type is a category of changes defined by common characteristics."
  }, {
    "@language" : "fr",
    "@value" : "Un type de changement est une catégorie de changements définie par des caractéristiques communes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/PeGazUs#"
