    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/PeGazUs#AttributeVersion",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An attribute version is a version of an attribute which has a specific value."
  }, {
    "@language" : "fr",
    "@value" : "Une version d'attribut est une version reliée à un attribut qui possède est définie par une valeur."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/PeGazUs#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Attribute version"
  }, {
    "@language" : "fr",
    "@value" : "Version de l'attribut"
  } ]
}, {
  "@id" : "https://w3id.org/PeGazUs#Change",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A change is any modification made to a geographic feature or its attributes, or to a relationship between features."
  }, {
    "@language" : "fr",
    "@value" : "Un changement est toute modification appliquée à une entité géographique ou à ses attributs ou bien à une relation entre entités."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/PeGazUs#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Change"
  }, {
    "@language" : "fr",
    "@value" : "Changement"
  } ]
}, {
