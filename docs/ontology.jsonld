}, {
  "@id" : "https://w3id.org/tabulae#AnnotationClassType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Class type provided by an annotation process to an image (document) or to a text or excerpt of text, manually or automatically."
