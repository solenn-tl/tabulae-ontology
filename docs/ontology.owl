<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/tabulae#"
     xml:base="https://w3id.org/tabulae"
     xmlns:ns="http://creativecommons.org/ns#"
     xmlns:org="http://www.w3.org/ns/org#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:voaf="http://purl.org/vocommons/voaf#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/"
     xmlns:tabulae="https://w3id.org/tabulae#">
    <owl:Ontology rdf:about="https://w3id.org/tabulae#">
        <ns:license rdf:resource="http://creativecommons.org/licenses/by/2.0/"/>
        <ns:license rdf:resource="http://opendatacommons.org/licenses/by/"/>
        <ns:license rdf:resource="http://www.data.gouv.fr/Licence-Ouverte-Open-Licence"/>
        <terms:abstract xml:lang="fr">L&apos;ontologie TABULAE est une extension de l&apos;ontologie PeGazUs dédiée à la représentation des informations relatives aux parcelles contenues dans les documents du cadastre ancien français (XIXe siècle). Elle permet de décrire les parcelles (Plot), leurs contribuables (Taxpayer), leur nature d&apos;occupation du sol (Nature, avec plus de 150 valeurs contrôlées), ainsi que les événements et changements qui affectent ces parcelles au fil du temps. Leur évolution est décrite à l&apos;échelle des attributs. L&apos;ontologie modélise également les sources documentaires mobilisées (matrices cadastrales, états de sections, plans parcellaires) et intègre un support pour la classification automatique et la reconnaissance d&apos;entités nommées dans les documents numérisés (anclass, NamedEntity). Elle s&apos;appuie sur les ontologies PeGazUs, RiC-O, SKOS et PROV-O.</terms:abstract>
        <terms:abstract xml:lang="en">L&apos;ontology TABULAE is an extension of the PeGazUs vocabulary dedicated to the representation of information contained in the French 19th-century land registry documents. It enables the description of land plots, their taxpayers, their nature (with over 150 controlled values), and the changes and events affecting these plots over time. Their evolution is described at the attribute level. The ontology also models the sources involved (mutation registers, section registers, cadastral index maps) and provides support for automatic classification and named entity recognition in digitised documents (anclass, NamedEntity). It builds on the PeGazUs, RiC-O, SKOS and PROV-O ontologies.</terms:abstract>
        <terms:contributor rdf:nodeID="genid1"/>
        <terms:contributor rdf:nodeID="genid3"/>
        <terms:contributor rdf:nodeID="genid5"/>
        <terms:contributor rdf:nodeID="genid7"/>
        <terms:creator rdf:nodeID="genid9"/>
        <terms:description xml:lang="fr">Ontologie pour décrire les informations sur les parcelles, et les entités liées, présentes dans le cadastre ancien. Extension de l&apos;ontologie PeGaZus.</terms:description>
        <terms:description xml:lang="en">Ontology to describe the information about land plots and associated entities evocated in the old land registry documents. Extension of the PeGazUs ontology.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-24</terms:issued>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/"/>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/2.0/"/>
        <terms:license rdf:resource="http://www.data.gouv.fr/Licence-Ouverte-1.0"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-07-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-07</terms:modified>
        <terms:publisher rdf:nodeID="genid16"/>
        <terms:rights>Copyright 2024-2026, IGN</terms:rights>
        <terms:title xml:lang="fr">Ontologie TABULAE</terms:title>
        <terms:title xml:lang="en">TABULAE ontology</terms:title>
        <vann:preferredNamespacePrefix>tbl</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://w3id.org/tabulae#"/>
        <voaf:extends rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="fr">Ontologie TABULAE</rdfs:label>
        <rdfs:label xml:lang="en">TABULAE Ontology</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:seeAlso rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <schema:codeRepository rdf:resource="https://github.com/solenn-tl/tabulae-ontology"/>
        <schema:funding>Agence d&apos;Innovation de Défense (AID) - Ministère des Armées</schema:funding>
        <schema:funding>Institut National de l&apos;Information Géographique et Forestière (IGN)</schema:funding>
    </owl:Ontology>
