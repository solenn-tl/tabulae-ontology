    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/created">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/date -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/date">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/spatial -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/spatial">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.wikidata.org/prop/P8422 -->


    <owl:DatatypeProperty rdf:about="http://www.wikidata.org/prop/P8422">
        <rdfs:isDefinedBy rdf:resource="http://www.wikidata.org/prop/"/>
        <rdfs:label xml:lang="fr">identifiant Ldh/EHESS/Cassini</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#IIIFImageUrl -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#IIIFImageUrl">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tabulae#imageURL"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="fr">URL d&apos;une image fournie par l&apos;API IIIF (International Image Interoperability Framework) représentant un document ou une partie de document.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL of an image provided by the IIIF (International Image Interoperability Framework) image representing a document or part of a document.</rdfs:comment>
        <rdfs:label xml:lang="en">IIIF image URL</rdfs:label>
        <rdfs:label xml:lang="fr">URL d&apos;image IIIF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#TFNBGroup -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#TFNBGroup">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Group of TFNB (Taxe Foncière sur les Propriétés Non Bâties) of a plot, as indicated in modern cadastral documents. The table who ispired this property is available at &lt;a href=&apos;https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812&apos;&gt;this URL&lt;/a&gt;</rdfs:comment>
        <rdfs:comment xml:lang="fr">Groupe de TFNB (Taxe Foncière sur les Propriétés Non Bâties) d&apos;une parcelle, tel qu&apos;indiqué dans les documents cadastraux. La table utilisée est disponible &lt;a href=&apos;https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812&apos;&gt;cette URL&lt;/a&gt;.</rdfs:comment>
        <rdfs:label xml:lang="en">TFNB group</rdfs:label>
        <rdfs:label xml:lang="fr">groupe TFNB</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://bofip.impots.gouv.fr/bofip/586-PGP.html/identifiant%3DBOI-ANNX-000256-20150812"/>
        <skos:prefLabel xml:lang="en">TFNB group</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">groupe TFNB</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#URL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#URL">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment>Correspond à l&apos;URL de la source (image, base de donnée)</rdfs:comment>
        <rdfs:label xml:lang="en">source URL</rdfs:label>
        <rdfs:label xml:lang="fr">url de la source</rdfs:label>
        <skos:prefLabel xml:lang="en">source URL</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">url de la source</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#coordinatesInImageSystem -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#coordinatesInImageSystem">
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment>Coordonnées (référentiel image) d&apos;une zone annotée (manuellement ou automatiquement) dans un document numérisé.</rdfs:comment>
        <rdfs:label xml:lang="en">coordinates in image</rdfs:label>
        <rdfs:label xml:lang="fr">coordonnées dans l&apos;image</rdfs:label>
        <skos:prefLabel xml:lang="en">coordinates in image</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">coordonnées dans l&apos;image</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#hasAlternativeFolioNumber -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#hasAlternativeFolioNumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Alternative folio number (e.g. former number)</rdfs:comment>
        <rdfs:comment xml:lang="fr">Numéro de folio alternatif (ex: ancien numéro)</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour numéro de folio alternatif</rdfs:label>
        <rdfs:label xml:lang="en">has alternative folio number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#hasAlternativeNumFolio -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#hasAlternativeNumFolio">
        <owl:backwardCompatibleWith rdf:resource="https://w3id.org/tabulae#hasAlternativeFolioNumber"/>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#hasFolioNumber -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#hasFolioNumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="fr">Numéro de folio (associé à une page entière ou à une partie de page) </rdfs:comment>
        <rdfs:comment xml:lang="en">folio number (associated to a mutation register page or part of page)</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour numéro de folio</rdfs:label>
        <rdfs:label xml:lang="en">has folio number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#hasNumFolio -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#hasNumFolio">
        <owl:backwardCompatibleWith rdf:resource="https://w3id.org/tabulae#hasFolioNumber"/>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#imageURL -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#imageURL">
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="fr">URL d&apos;une image représentant un document ou une partie de document.</rdfs:comment>
        <rdfs:comment xml:lang="en">URL of an image representing a document or part of a document.</rdfs:comment>
        <rdfs:label xml:lang="fr">URL d&apos;image</rdfs:label>
        <rdfs:label xml:lang="en">image URL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#indexOfFirstCharacter -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#indexOfFirstCharacter">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;indiquer l&apos;index du premier caractère d&apos;une sous-chaine de caractères dans un texte. Index à partir de 0.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to indicate the index of the first character of a substring. Index starts from 0.</rdfs:comment>
        <rdfs:label xml:lang="fr">index du premier caractère</rdfs:label>
        <rdfs:label xml:lang="en">index of first character</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#indexOfLastCharacter -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#indexOfLastCharacter">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;indiquer l&apos;index du dernier caractère d&apos;une sous-chaine de caractères dans un texte. Index à partir de 0.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to indicate the index of the last character of a substring. Index starts from 0.</rdfs:comment>
        <rdfs:label xml:lang="fr">index du dernier caractère</rdfs:label>
        <rdfs:label xml:lang="en">index of last character</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#lineOrderInArea -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#lineOrderInArea">
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Ordre de la ligne dans la zone annotée (manuellement ou automatiquement) dans un document numérisé.</rdfs:comment>
        <rdfs:label xml:lang="fr">ordre de ligne dans la zone</rdfs:label>
        <rdfs:label xml:lang="en">row order in area</rdfs:label>
        <skos:prefLabel xml:lang="fr">ordre de ligne dans la zone</skos:prefLabel>
        <skos:prefLabel xml:lang="en">row order in area</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#spanValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#spanValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
                    <rdf:Description rdf:about="https://w3id.org/tabulae#NamedEntity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;indiquer la valeur d&apos;une sous-chaine de caractères.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to indicate the value of a substring.</rdfs:comment>
        <rdfs:label xml:lang="en">span value</rdfs:label>
        <rdfs:label xml:lang="fr">valeur de la sous-chaîne</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerActivity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerActivity">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Activity of a taxpayer, generally related to their professional activity</rdfs:comment>
        <rdfs:comment xml:lang="fr">Activité d&apos;un contribuable, généralement relatif à l&apos;activité professionnelle</rdfs:comment>
        <rdfs:label xml:lang="fr">activité du contribuable</rdfs:label>
        <rdfs:label xml:lang="en">taxpayer activity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerAddress -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerAddress">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Address of a taxpayer provided as a string. For addresses as entities, see tbl:taxpayerHasAddressEntity.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Adresse d&apos;un contribuable renseignée sous la forme d&apos;une chaîne de caractères. Pour les adresses sous forme d&apos;entités, voir tbl:taxpayerHasAddressEntity.</rdfs:comment>
        <rdfs:label xml:lang="fr">adresse du contribuable</rdfs:label>
        <rdfs:label xml:lang="en">taxpayer address</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerBirthName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerBirthName">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Birth name of a taxpayer.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Nom de naissance d&apos;une contribuable. Par exemple, le nom de naissance d&apos;une personne avant son mariage (sans le cas où elle utilise ensuite le nom de son époux/épouse).</rdfs:comment>
        <rdfs:label xml:lang="en">birth name</rdfs:label>
        <rdfs:label xml:lang="fr">nom de naissance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerFamilyStatus -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerFamilyStatus">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Status of a taxpayer related to their family status or relationships (Widow, Widower, Son, Daughter, Minor, Heirs)</rdfs:comment>
        <rdfs:comment xml:lang="fr">Statut d&apos;un contribuable lié à son statut ou à ses relations familiales (Veuve, Veuf, Fils, Fille, Mineur, Héritiers)</rdfs:comment>
        <rdfs:label xml:lang="en">family status</rdfs:label>
        <rdfs:label xml:lang="fr">statut familial</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerFirstName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerFirstName">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="fr">Prénom (unitiare) d&apos;un contribuable. En pratique peu utilisée car implique de connaître de façon certaine l&apos;état civil d&apos;un contribuable.</rdfs:comment>
        <rdfs:comment xml:lang="en">Unique first name of a taxpayer. Generally not used in practice as it requires certain knowledge of the taxpayer&apos;s civil status.</rdfs:comment>
        <rdfs:label xml:lang="fr">prénom unique</rdfs:label>
        <rdfs:label xml:lang="en">unique first name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerFirstNames -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerFirstNames">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">First name(s) of a taxpayer, generally presented as a list of first names in documents. In the case of taxpayers with the family status &apos;Mrs&apos; or &apos;Widow&apos;, the indicated first name is generally that of the spouse.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Prénom(s) d&apos;un contribuable, généralement présentés sous la forme d&apos;une liste de prénoms dans les documents. Dans le cas des contribuables ayant le statut familial &apos;Mme&apos; ou &apos;Veuve&apos;, le prénom indiqué est généralement celui de l&apos;époux.</rdfs:comment>
        <rdfs:label xml:lang="en">first name(s)</rdfs:label>
        <rdfs:label xml:lang="fr">prénom(s)</rdfs:label>
        <isPreferredOver rdf:resource="https://w3id.org/tabulae#taxpayerFirstName"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerFullName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerFullName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tabulae#taxpayerLabel"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Full identity of an individual taxpayer: last name and first names.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Identité complète d&apos;un contribuable (personne physique) composée a minima d&apos;un nom de famille et optionnellement d&apos;un ou plusieurs prénoms et d&apos;un statut familial.</rdfs:comment>
        <rdfs:label xml:lang="en">full name</rdfs:label>
        <rdfs:label xml:lang="fr">nom complet</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerLabel -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerLabel">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="fr">Label d&apos;un contribuable, qui peut être son nom complet (pour une personne physique) ou sa raison sociale (pour une personne morale).</rdfs:comment>
        <rdfs:comment xml:lang="en">Label of a taxpayer, which can be their full name (for an individual) or their company name (for a legal entity).</rdfs:comment>
        <rdfs:label xml:lang="fr">label de contribuable</rdfs:label>
        <rdfs:label xml:lang="en">taxpayer label</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerLastName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerLastName">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Last name of a taxpayer</rdfs:comment>
        <rdfs:comment xml:lang="fr">Nom de famille d&apos;un contribuable</rdfs:comment>
        <rdfs:label xml:lang="en">last name</rdfs:label>
        <rdfs:label xml:lang="fr">nom de famille</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerOrganisationName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerOrganisationName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tabulae#taxpayerLabel"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Company name of a legal entity taxpayer</rdfs:comment>
        <rdfs:comment xml:lang="fr">Raison sociale d&apos;un contribuable personne morale</rdfs:comment>
        <rdfs:label xml:lang="en">organisation name</rdfs:label>
        <rdfs:label xml:lang="fr">raison sociale</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerSpouseOrChildrenFirstNames -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerSpouseOrChildrenFirstNames">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">First name(s) of the spouse or a child in a land registry folio label, generally indicated in the second part of the label.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Prénom(s) de l&apos;époux/épouse ou d&apos;un enfant dans un libellé de compte foncier. Généralement indiqués en seconde partie de libellé en complémenant de l&apos;identité d&apos;un contribuable &apos;racine&apos; (le titulaire initial du compte foncier).</rdfs:comment>
        <rdfs:label xml:lang="fr">prénom(s) de l&apos;époux/épouse ou d&apos;un enfant</rdfs:label>
        <rdfs:label xml:lang="en">spouse or children first name(s)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerStatus -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerStatus">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Status of a taxpayer which is not related to their family status.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Statut d&apos;un contibuable qui n&apos;est pas lié à son statut familial. Exemple : &apos;Non imposable&apos;</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
        <rdfs:label xml:lang="fr">statut</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerTitle -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#taxpayerTitle">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Civility (Mr, Mrs, etc.), noble title (e.g., Prince of, Marquis of) or honorific</rdfs:comment>
        <rdfs:comment xml:lang="fr">Civilité (M, Mme, etc.), titre de noblesse (Prince de, Marquis de, etc.) ou titre honorifique</rdfs:comment>
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:label xml:lang="fr">titre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#transcription -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#transcription">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="fr">Transcription d&apos;une zone ou d&apos;une entité obtenue automatiquement ou manuellement à partir d&apos;un document (numérisé).</rdfs:comment>
        <rdfs:comment xml:lang="en">Transcription of an area or an entity obtained automatically or manually from a (scanned) document.</rdfs:comment>
        <rdfs:label xml:lang="en">transcription</rdfs:label>
        <rdfs:label xml:lang="fr">transcription</rdfs:label>
        <skos:prefLabel xml:lang="en">transcription</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">transcription</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/tabulae#xywhCoordinates -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/tabulae#xywhCoordinates">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tabulae#coordinatesInImageSystem"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Coordinates (image reference system) of an annotated area (manually or automatically) in a scanned document, in the form of a rectangle defined by the x and y coordinates of the upper left corner and the width and height of the rectangle (as required in the IIIF specifications). For example: 1160,1103,1529,1421</rdfs:comment>
        <rdfs:comment xml:lang="fr">Coordonnées (référentiel image) d&apos;une zone annotée (manuellement ou automatiquement) dans un document numérisé, sous la forme d&apos;un rectangle défini par les coordonnées x et y du coin supérieur gauche et la largeur et la hauteur du rectangle (tel que requis dans les spécifications IIIF). Par exemple : 1160,1103,1529,1421</rdfs:comment>
        <rdfs:label xml:lang="fr">coordonnées xywh dans l&apos;image</rdfs:label>
        <rdfs:label xml:lang="en">xywh coordinates in image</rdfs:label>
        <skos:prefLabel xml:lang="fr">coordonnées xywh dans l&apos;image</skos:prefLabel>
        <skos:prefLabel xml:lang="en">xywh coordinates in image</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#identifier -->


    <owl:DatatypeProperty rdf:about="https://www.ica.org/standards/RiC/ontology#identifier">
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
    </owl:DatatypeProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#name -->


    <owl:DatatypeProperty rdf:about="https://www.ica.org/standards/RiC/ontology#name">
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/vocommons/voaf#Vocabulary -->


    <owl:Class rdf:about="http://purl.org/vocommons/voaf#Vocabulary"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
        <rdfs:label>Concept</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
        <rdfs:label xml:lang="en">Concept scheme</rdfs:label>
        <rdfs:label xml:lang="fr">Schéma de concepts</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Instant -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#Instant"/>
    


    <!-- http://www.w3.org/2006/time#Interval -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval"/>
    


    <!-- http://www.w3.org/ns/org#Membership -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Membership"/>
    


    <!-- http://www.w3.org/ns/org#Role -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Role"/>
    


    <!-- http://www.w3.org/ns/prov#Activity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity">
        <owl:disjointWith rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label>Activity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/prov#Agent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Agent">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label>Agent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- http://www.w3.org/ns/prov#SoftwareAgent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#SoftwareAgent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label>SoftwareAgent</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://schema.org/Organization -->


    <owl:Class rdf:about="https://schema.org/Organization"/>
    


    <!-- https://w3id.org/PeGazUs#Address -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#Address">
        <rdfs:comment xml:lang="en">An address defines an indirect spatial reference to a location that is the target of the address. This location is described as a sequence of address segments, each of which describes the relationships between entities.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une adresse définit une référence spatiale indirecte d&apos;un lieu qui est la cible de l&apos;adresse. La manière dont ce lieu est décrit se fait comme étant une séquence de segments d&apos;adresse étant chacun une description de relations entre entités.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Address</rdfs:label>
        <rdfs:label xml:lang="fr">Adresse</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#Attribute -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#Attribute">
        <rdfs:comment xml:lang="en">An attribute is a property of a geographic entity.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un attribut est une propriété d&apos;une entité géographique.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="fr">Attribut</rdfs:label>
        <rdfs:label xml:lang="en">Attribute</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#AttributeType -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#AttributeType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">An attribute type is a category of attributes defined by common characteristics.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un type d&apos;attribut est une catégorie d&apos;attributs définie par des caractéristiques communes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Attribute type</rdfs:label>
        <rdfs:label xml:lang="fr">Type d&apos;attribut</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#AttributeVersion -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#AttributeVersion">
        <rdfs:comment xml:lang="en">An attribute version is a version of an attribute which has a specific value.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une version d&apos;attribut est une version reliée à un attribut qui possède est définie par une valeur.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Attribute version</rdfs:label>
        <rdfs:label xml:lang="fr">Version de l&apos;attribut</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#Change -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#Change">
        <rdfs:comment xml:lang="en">A change is any modification made to a geographic feature or its attributes, or to a relationship between features.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un changement est toute modification appliquée à une entité géographique ou à ses attributs ou bien à une relation entre entités.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Change</rdfs:label>
        <rdfs:label xml:lang="fr">Changement</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#Event -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#Event">
        <rdfs:comment xml:lang="en">Event describing a development involving one or more resources at a given time.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un événément décrit une évolution impliquant une ou plusieurs ressources à un instant donné.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Event</rdfs:label>
        <rdfs:label xml:lang="fr">Événément</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#Landmark -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#Landmark"/>
    


    <!-- https://w3id.org/PeGazUs#LandmarkRelation -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#LandmarkRelation">
        <rdfs:comment xml:lang="fr">Il s&apos;agit d&apos;une relation qui représente un lien existant entre un ou plusieurs repères.
    Ces relations peuvent prendre diverses formes, notamment :
    - des relations géographiques, par exemple lorsqu&apos;un point de repère est situé à l&apos;angle de deux autres points de repère ;
    - des relations hiérarchiques, par exemple lorsqu&apos;un point de repère est la capitale d&apos;une autre entité administrative ;
    - d&apos;autres relations spécifiques.</rdfs:comment>
        <rdfs:comment xml:lang="en">It is a relation that represents a relation existing between one or more landmarks.
    Such relations may take various forms, including:
    - geographic relations, for example when a landmark is located at the corner of two other landmarks;
    - hierarchical relations, for example when a landmark is the capital of another administrative entity;
    - as well as other domain-specific or contextual relations depending on the application needs.
    </rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="en">Landmark relation</rdfs:label>
        <rdfs:label xml:lang="fr">Relation entre repères</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/PeGazUs#LandmarkType -->


    <owl:Class rdf:about="https://w3id.org/PeGazUs#LandmarkType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">A type of landmark is a category that allows classifying the different types of landmarks.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un type de repère est une catégorie qui permet de classer les différents types de repères.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="fr">Type de repère</rdfs:label>
        <rdfs:label xml:lang="en">Type of landmark</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#AnnotationClass -->


    <owl:Class rdf:about="https://w3id.org/tabulae#AnnotationClass">
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#EventType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Nature"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#PropertyAccountChange"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">Class (in the sense of annotation) used to characterize a document or text, resulting from an automatic or manual annotation process.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Classe (au sens de l&apos;annotation) utilisée pour caractériser pour un document ou un texte, résultant d&apos;un processus d&apos;annotation automatique ou manuel.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">Class provided by an annotation process</rdfs:label>
        <rdfs:label xml:lang="fr">Classe issue d&apos;un processus d&apos;annotation</rdfs:label>
        <skos:altLabel xml:lang="en">Annotation class</skos:altLabel>
        <skos:altLabel xml:lang="fr">Classe d&apos;annotation</skos:altLabel>
        <skos:prefLabel xml:lang="en">Class provided by an annotation process</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Classe issue d&apos;un processus d&apos;annotation</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#AnnotationClassType -->


    <owl:Class rdf:about="https://w3id.org/tabulae#AnnotationClassType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#EventType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Nature"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#PropertyAccountChange"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">Class type provided by an annotation process to an image (document) or to a text or excerpt of text, manually or automatically.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Type de classe attribuée manuellement ou automatiquement à une image (document) ou à un texte ou extrait de texte.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Type de classe d&apos;annotation</rdfs:label>
        <rdfs:label xml:lang="en">Type of annotation class</rdfs:label>
        <skos:prefLabel xml:lang="fr">Type de classe d&apos;annotation</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Type of annotation class</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#EventType -->


    <owl:Class rdf:about="https://w3id.org/tabulae#EventType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Nature"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#PropertyAccountChange"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">A specific type of event.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un type d&apos;évènement caractérise un évènement de nature spécifique.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Type d&apos;évènement</rdfs:label>
        <rdfs:label xml:lang="en">Type of event</rdfs:label>
        <skos:prefLabel xml:lang="fr">Type d&apos;évènement</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Type of event</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#NamedEntity -->


    <owl:Class rdf:about="https://w3id.org/tabulae#NamedEntity">
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Nature"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#PropertyAccountChange"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="fr">Entité nommée mentionnée dans une source transcrite (textuelle), identifiée par un processus manuel ou automatique. Une entité nommée peut contenir d&apos;autres entités nommées imbriquées.</rdfs:comment>
        <rdfs:comment xml:lang="en">Named entity mentioned in a transcribed source (text), identified by a manual or automatic process. A named entity may contain other named entities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Entité nommée</rdfs:label>
        <rdfs:label xml:lang="en">Named entity</rdfs:label>
        <skos:prefLabel xml:lang="fr">Entité nommée</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Named entity</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#Nature -->


    <owl:Class rdf:about="https://w3id.org/tabulae#Nature">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#PropertyAccountChange"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">A plot nature corresponds to a land use or occupation.</rdfs:comment>
        <rdfs:comment xml:lang="fr">La nature de parcelle correspond à une occupation ou un usage du sol.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Nature de parcelle</rdfs:label>
        <rdfs:label xml:lang="en">Plot nature</rdfs:label>
        <skos:prefLabel xml:lang="fr">Nature de parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Plot nature</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#PropertyAccountChange -->


    <owl:Class rdf:about="https://w3id.org/tabulae#PropertyAccountChange">
        <rdfs:subClassOf rdf:resource="https://w3id.org/PeGazUs#Change"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">A change affecting the property account of a taxpayer.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un changement sur le compte foncier caractérise un changement affectant le compte foncier d&apos;un contribuable.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Changement sur le compte foncier</rdfs:label>
        <rdfs:label xml:lang="en">Property account change</rdfs:label>
        <skos:prefLabel xml:lang="fr">Changement sur le compte foncier</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Property account change</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#SourceType -->


    <owl:Class rdf:about="https://w3id.org/tabulae#SourceType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="fr">Type d&apos;une source dont est issue une information.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of a source from which information originates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Type de source</rdfs:label>
        <rdfs:label xml:lang="en">Type of source</rdfs:label>
        <skos:prefLabel xml:lang="fr">Type de source</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Type of source</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#SpecialCellValue -->


    <owl:Class rdf:about="https://w3id.org/tabulae#SpecialCellValue">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">Special value related to the operation of cadastral documents, for example the mentions of construction, destruction, modifications of buildings indicated in the columns intended for folio numbers.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Valeur spéciale liée au fonctionnement des documents cadastraux, par exemple les mentions de construction, destruction, augmentation de bâtiments indiquées dans les colonnes destinées aux numéros de folio.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">Special value of cadastral tables</rdfs:label>
        <rdfs:label xml:lang="fr">Valeur spéciale des tables cadastrales</rdfs:label>
        <skos:prefLabel xml:lang="en">Special cell value</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Valeur spéciale</skos:prefLabel>
    </owl:Class>
    


    <!-- https://w3id.org/tabulae#Taxpayer -->


    <owl:Class rdf:about="https://w3id.org/tabulae#Taxpayer">
        <rdfs:comment xml:lang="en">Natural or legal person liable for property tax for land for which they have full ownership or usufruct.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Personne physique ou morale redevable de l&apos;impôt foncier pour les terres dont elle a la pleine propriété ou l&apos;usufruit.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">Contribuable</rdfs:label>
        <rdfs:label xml:lang="en">Taxpayer</rdfs:label>
        <skos:altLabel xml:lang="en">Owner</skos:altLabel>
        <skos:altLabel xml:lang="fr">Propriétaire ou usufruitier</skos:altLabel>
        <skos:prefLabel xml:lang="fr">Contribuable</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Taxpayer</skos:prefLabel>
    </owl:Class>
    


    <!-- https://www.ica.org/standards/RiC/ontology#Instantiation -->


    <owl:Class rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation">
        <rdfs:comment xml:lang="en">The inscription of information made by an Agent on a physical
         carrier in any persistent, recoverable form as a means of communicating information through
         time and space.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">Instanciation</rdfs:label>
        <rdfs:label xml:lang="en">Instantiation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.ica.org/standards/RiC/ontology#Record -->


    <owl:Class rdf:about="https://www.ica.org/standards/RiC/ontology#Record">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:comment xml:lang="en">Discrete information content formed and inscribed, at least once,
         by any method on any carrier in any persistent, recoverable form by an Agent in the course
         of life or work activity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">Objet informationnel</rdfs:label>
        <rdfs:label xml:lang="en">Record</rdfs:label>
    </owl:Class>
    


    <!-- https://www.ica.org/standards/RiC/ontology#RecordPart -->


    <owl:Class rdf:about="https://www.ica.org/standards/RiC/ontology#RecordPart">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:comment xml:lang="en">Component of a Record with independent information content that
         contributes to the intellectual completeness of the Record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">Partie d’objet informationnel</rdfs:label>
        <rdfs:label xml:lang="en">Record Part</rdfs:label>
    </owl:Class>
    


    <!-- https://www.ica.org/standards/RiC/ontology#RecordResource -->


    <owl:Class rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource">
        <rdfs:comment xml:lang="en">Information produced or acquired and retained by an Agent in the
         course of life or work activity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="en">Record Resource</rdfs:label>
        <rdfs:label xml:lang="fr">Ressource archivistique</rdfs:label>
    </owl:Class>
    


    <!-- https://www.ica.org/standards/RiC/ontology#RecordSet -->


    <owl:Class rdf:about="https://www.ica.org/standards/RiC/ontology#RecordSet">
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:comment xml:lang="en">One or more records that are grouped together by an Agent based on
         the records sharing one or more attributes or relations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">Ensemble d’objets informationnels</rdfs:label>
        <rdfs:label xml:lang="en">Record Set</rdfs:label>
    </owl:Class>
    


