        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:closeMatch rdf:resource="https://w3id.org/tabulae/id/codes/specialCellValue/AdditionConstructionSV"/>
        <skos:definition xml:lang="en">Indicates an extension to an existing building, which may result in a reassessment of its tax value.</skos:definition>
        <skos:definition xml:lang="fr">Indique une addition à une contruction existente, pouvant entraîner une réévaluation de la valeur fiscale de celle-ci.</skos:definition>
