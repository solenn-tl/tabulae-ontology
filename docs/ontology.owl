        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">Augmentation</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Enhancement</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/CelluleVide -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/CelluleVide">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:altLabel xml:lang="fr">EMPTY</skos:altLabel>
        <skos:definition xml:lang="en">An empty cell with no meaning. This is different from cells left blank to indicate that their value is the same as another cell (Idem).</skos:definition>
        <skos:definition xml:lang="fr">Cellule vide sans signification. Diffère des cellules laissées vides pour indiquer que leur valeur est identique à une autre cellule (Idem).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">Cellule vide</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Empty cell</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/ConstructionNouvelleSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/ConstructionNouvelleSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indique une construction d&apos;un bâtiment qui est donc imposable au titre des propriétés bâties.</skos:definition>
        <skos:definition xml:lang="fr">Indique une construction d&apos;un bâtiment qui est donc imposable au titre des propriétés bâties.</skos:definition>
