        <skos:hiddenLabel>add C</skos:hiddenLabel>
        <skos:hiddenLabel>addition</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">Addition à une construction</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Expension</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/AugmentationSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/AugmentationSV">
