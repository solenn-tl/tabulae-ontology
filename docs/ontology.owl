        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections"/>
        <skos:definition xml:lang="fr">Registre d&apos;états de sections créé avant 1822. Contient une partie dédiée à la description du sol (propriété non bâties) et une partie dédiée à la description des bâtiments (propriétés bâties).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections antérieurs à 1822</skos:prefLabel>
