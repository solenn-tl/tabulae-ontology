        <skos:prefLabel xml:lang="fr">Evaluation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/IdemPrecedentSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/IdemPrecedentSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/specialCellValue/IdemSV"/>
        <skos:definition xml:lang="en">Indicates that the cell is the same as that of the previous cell.</skos:definition>
        <skos:definition xml:lang="fr">Valeur de cellule identique à celle de la cellule précédente.</skos:definition>
        <skos:hiddenLabel>&quot;</skos:hiddenLabel>
        <skos:hiddenLabel>/</skos:hiddenLabel>
        <skos:hiddenLabel>Id</skos:hiddenLabel>
        <skos:hiddenLabel>Le même</skos:hiddenLabel>
        <skos:hiddenLabel>Les mêmes</skos:hiddenLabel>
        <skos:hiddenLabel>idem</skos:hiddenLabel>
        <skos:hiddenLabel>§</skos:hiddenLabel>
        <skos:hiddenLabel>Ø</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Idem as previous cell</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Idem au précédent</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/IdemSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/IdemSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that the cell value that is the same as that of another cell.</skos:definition>
        <skos:definition xml:lang="fr">Valeur de cellule identique à celle d&apos;une autre cellule.</skos:definition>
        <skos:hiddenLabel>&quot;</skos:hiddenLabel>
        <skos:hiddenLabel>/</skos:hiddenLabel>
        <skos:hiddenLabel>Id</skos:hiddenLabel>
        <skos:hiddenLabel>Le même</skos:hiddenLabel>
        <skos:hiddenLabel>Les mêmes</skos:hiddenLabel>
        <skos:hiddenLabel>idem</skos:hiddenLabel>
        <skos:hiddenLabel>§</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Idem</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Idem</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/IdemSuivantSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/IdemSuivantSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/specialCellValue/IdemSV"/>
        <skos:definition xml:lang="en">Indicates that the cell is the same as that of the next cell.</skos:definition>
        <skos:definition xml:lang="fr">Valeur de cellule identique à celle de la cellule suivante.</skos:definition>
        <skos:hiddenLabel>&quot;</skos:hiddenLabel>
        <skos:hiddenLabel>/</skos:hiddenLabel>
        <skos:hiddenLabel>Id</skos:hiddenLabel>
        <skos:hiddenLabel>Le même</skos:hiddenLabel>
        <skos:hiddenLabel>Les mêmes</skos:hiddenLabel>
        <skos:hiddenLabel>idem</skos:hiddenLabel>
        <skos:hiddenLabel>§</skos:hiddenLabel>
        <skos:hiddenLabel>☼</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Idem as next cell</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Idem au précédent</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/InconnuSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/InconnuSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that the cell meaning has not been specified or understanded.</skos:definition>
        <skos:definition xml:lang="fr">Valeur de cellule dont le sens n&apos;a pas été explicité.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Unknown</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Valeur inconnue</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/OmissionSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/OmissionSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:altLabel xml:lang="fr">OmissionSV{{date}}</skos:altLabel>
        <skos:definition xml:lang="en">Indicates that the plot of land has been retroactively included in the taxpayer’s land register, as the taxpayer had failed to declare it for a certain period.</skos:definition>
        <skos:definition xml:lang="fr">Indique que la parcelle a fait l&apos;objet d&apos;une intégration réatroactive dans le compte foncier du contribuable qui ne l&apos;avait pas déclarée pendant une certaine période.</skos:definition>
        <skos:hiddenLabel>Omission</skos:hiddenLabel>
        <skos:hiddenLabel>Omission depuis</skos:hiddenLabel>
        <skos:hiddenLabel>OmissionSV{{date}}</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Omission</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Omission</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/PartieSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/PartieSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that the plot is a part of an original parcel that had the same number and has (usually) been subdivided. A &quot;p&quot; letter is often concatenated after the plot number.</skos:definition>
        <skos:definition xml:lang="fr">Indique que la parcelle décrite est une partie d&apos;une parcelle initiale qui possèdait le même numéro et a (généralement) été divisée. La lettre &quot;p&quot; est souvent accolée au numéro de la parcelle.</skos:definition>
        <skos:hiddenLabel>Partie</skos:hiddenLabel>
        <skos:hiddenLabel>Ptie</skos:hiddenLabel>
        <skos:hiddenLabel>p</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Part of</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Partie</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/ResteSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/ResteSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that the plot is the remnant of a plot from the same land account that was subdivided and bore the same identifier as the plot in question.</skos:definition>
        <skos:definition xml:lang="fr">Indique que la parcelle est le résidu d&apos;une parcelle du même compte foncier qui a été divisée et qui portait le même identiant que la parcelle considérée.</skos:definition>
        <skos:hiddenLabel>Reste</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Left-over</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Reste</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/RuinesSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/RuinesSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that a building is or was in ruins.</skos:definition>
        <skos:definition xml:lang="fr">Indique qu&apos;une construction est ou était en ruines.</skos:definition>
        <skos:hiddenLabel>En ruine</skos:hiddenLabel>
        <skos:hiddenLabel>En ruines</skos:hiddenLabel>
        <skos:hiddenLabel>Ruines</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">En ruines</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Ruined</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/ValeurBarreeSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/ValeurBarreeSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:altLabel xml:lang="fr">~~TEXT~~</skos:altLabel>
        <skos:definition xml:lang="en">Indicates that the text is crossed out in the document.</skos:definition>
