        <skos:prefLabel xml:lang="en">Vectorized map</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaire -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaire">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/Plan"/>
        <rdfs:label>Plan parcellaire</rdfs:label>
        <skos:definition xml:lang="en">A map showing the lant plots within a section of a municipality (an entire section or part of a section), drawn to scales ranging from 1:1,250 to 1:5,000.</skos:definition>
        <skos:definition xml:lang="fr">Plan représentant les parcellaires d&apos;une portion d&apos;une commune (section entière ou partie d&apos;une section), réalisé à des échelles situées entre 1:1250 et 1:5000.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Cadastral index map</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plan parcellaire</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireFinal -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireFinal">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaire"/>
        <rdfs:label>Plan parcellaire final</rdfs:label>
        <skos:definition xml:lang="en">Final version of a cadastral index map.</skos:definition>
        <skos:definition xml:lang="fr">Version finale d&apos;un plan parcellaire</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Cadastral index map : final version</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plan parcellaire final</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireIssuDAtlas -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireIssuDAtlas">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireFinal"/>
        <rdfs:label>Plan parcellaire issu d&apos;atlas</rdfs:label>
        <skos:definition xml:lang="en">Final version of a cadastral index map taken from a municipal or cantonal atlas.</skos:definition>
        <skos:definition xml:lang="fr">Version finale d&apos;un plan parcellaire extraire d&apos;un atlas communal ou cantonal</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Cadastral index map : final version extract from atlas</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plan parcellaire issu d&apos;atlas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireMinute -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaireMinute">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/PlanParcellaire"/>
        <rdfs:label>Plan parcellaire : minute</rdfs:label>
        <skos:definition xml:lang="en">Draft version of a cadastral index map; may include building outlines, working notes or provisional plot numbering.</skos:definition>
        <skos:definition xml:lang="fr">Version de travail du plan parcellaire, peut comprendre des traits de constructions, notes de travail ou une numérotation non définitive des parcelles.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Cadastral index map : draft version</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plan parcellaire : minute</skos:prefLabel>
    </owl:NamedIndividual>
    


