    <!-- https://w3id.org/tabulae/id/codes/sourceType/Cadastre -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/Cadastre">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <rdfs:label>Cadastre</rdfs:label>
        <skos:altLabel xml:lang="fr">Corpus cadastral</skos:altLabel>
        <skos:definition xml:lang="en">A land registry comprising maps and registers, used for a certain period to calculate and collect property tax on plots of land within a municipality.</skos:definition>
        <skos:definition xml:lang="fr">Corpus cadastral composé de plans et de registres, utilisé pendant une certaine période pour le calcul et le prélèvement de l&apos;impôt foncier des parcelles d&apos;une commune.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Cadastre</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Land registry corpus</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/CompteFoncier -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/CompteFoncier">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale"/>
        <rdfs:label>Compte foncier</rdfs:label>
        <skos:definition xml:lang="en">A set of parcel records (lines) describing the plots of one or more successive related taxpayers. A land account may correspond ‘physically’ to a folio where the latter describes the details of one, and only one, taxpayer (or a list of successive taxpayers).</skos:definition>
        <skos:definition xml:lang="fr">Ensemble d&apos;états de parcelles (lignes) qui décrivent les parcelles d&apos;un ou plusieurs contribuables liés se succédant. Un compte foncier peut correspondre &quot;physiquement&quot; à un folio dans le cas où celui-ci décrit les informations d&apos;un, et un seul, contribuable (ou liste de contribuables successifs).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Compte foncier</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Property account</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/RegistreCadastral"/>
        <rdfs:label>Etats de sections</rdfs:label>
        <skos:definition xml:lang="en">Initial register detailing the initial status of plots within a municipality on a given date for a specific cadastral survey, prior to the completion of a cadastral map.</skos:definition>
        <skos:definition xml:lang="fr">Registre d&apos;état de sections décrivant l&apos;état initial des parcelles d&apos;une commune à une date donnée pour un cadastre donné, proche de la réalisation d&apos;un plan cadastral.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Initial register</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Ap_1822 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Ap_1822">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections"/>
        <rdfs:label>Etats de sections postérieurs à 1822</rdfs:label>
        <skos:definition xml:lang="en">Initial registers created after 1822.</skos:definition>
        <skos:definition xml:lang="fr">Registre d&apos;états de sections créé après 1822.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections postérieurs à 1822</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Initial register created after 1822</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections"/>
        <rdfs:label>Etats de sections antérieurs à 1822</rdfs:label>
        <skos:definition xml:lang="en">Initial register created before 1822. Sometimes, it contains a section describing the unbuilt plots and a section describing the buildings.</skos:definition>
        <skos:definition xml:lang="fr">Registre d&apos;états de sections créé avant 1822. Contient une partie dédiée à la description du sol (propriété non bâties) et une partie dédiée à la description des bâtiments (propriétés bâties).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections antérieurs à 1822</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Initial register created before 1822</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822_Bati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822_Bati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822"/>
        <rdfs:label>Etats de sections antérieurs à 1822 : chapitres dédiés aux propriétés bâties</rdfs:label>
        <skos:definition xml:lang="en">Extract from an initial register created before 1822, dedicated to the description of built properties.</skos:definition>
        <skos:definition xml:lang="fr">Partie d&apos;un registre d&apos;états de sections créé avant 1822 dédié à la description des propriétés bâties.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections antérieurs à 1822 (propriétés bâties)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Initial register created before 1822 (unbuilt properties)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822_NonBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822_NonBati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Av_1822"/>
        <rdfs:label>Etats de sections antérieurs à 1822 : chapitres dédiés aux propriétés non bâties</rdfs:label>
        <skos:definition xml:lang="en">Extract from an initial register created before 1822, dedicated to the description of unbuilt properties.</skos:definition>
        <skos:definition xml:lang="fr">Partie d&apos;un registre d&apos;états de sections créé avant 1822 dédié à la description des propriétés non bâties.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections antérieurs à 1822 (propriétés non bâties)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Initial register created before 1822 (built properties)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Scp_Seine_1835 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Scp_Seine_1835">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections"/>
        <rdfs:label>Etats de sections spécifiques à la rénovation du cadastre de la Seine (1835-1845)</rdfs:label>
        <skos:definition xml:lang="en">Initial registers relating specifically to the attempt to update the land registry carried out between 1835 and 1845 in the department of Seine.</skos:definition>
        <skos:definition xml:lang="fr">Registre d&apos;états de sections spécifique à la tentative de rénovation du cadastre ayant eu lieu entre 1835 et 1845 dans le département de la Seine.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Etats de sections spécifiques à la rénovation du cadastre de la Seine (1835-1845)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Special intial registers of the (1835-1845) Seine departement cadaster</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/FicheInventaire -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/FicheInventaire">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <rdfs:label>Inventaire des archives</rdfs:label>
        <skos:altLabel xml:lang="fr">Inventaire</skos:altLabel>
        <skos:definition xml:lang="fr">Fiches d&apos;inventaire décrivant le contenu des archives localisées dans un service d&apos;archives.</skos:definition>
        <skos:definition xml:lang="en">Inventory records describing the contents of the archives held by an archive service.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Archival records inventory</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Inventaire des archives</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/Folio -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/Folio">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage"/>
        <rdfs:label>Folio</rdfs:label>
        <skos:altLabel xml:lang="fr">Article</skos:altLabel>
        <skos:altLabel xml:lang="fr">Case</skos:altLabel>
        <skos:definition xml:lang="en">An area within a mutation register page that is identified by a number (ID). It may contain property accounts from one or more taxpayers, depending on the period and the type of pre-printed register.</skos:definition>
        <skos:definition xml:lang="fr">Zone située dans une page de matrice qui est caractérisée à un numéro (identifiant). Elle peut contenir des éléments d&apos;un ou plusieurs comptes fonciers selon les époques et les types de registres pré-imprimés.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="en">Folio</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Folio</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/FolioBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/FolioBati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/Folio"/>
        <rdfs:label>Folio (Bâti)</rdfs:label>
        <skos:definition xml:lang="fr">Folio dédié à des parcelles imposées au titre des propriétés bâties.</skos:definition>
        <skos:definition xml:lang="en">Section dedicated to pland plots subject to tax as built property.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Folio (Bâti)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Folio (built property)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/FolioNonBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/FolioNonBati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/Folio"/>
        <rdfs:label>Folio (Non Bâti)</rdfs:label>
        <skos:definition xml:lang="en">Account dedicated to land plots taxed as land without any buildings on it (unbuilt properties).</skos:definition>
        <skos:definition xml:lang="fr">Folio dédié à des parcelles imposées au titre des propriétés non bâties/foncières.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Folio (Non Bâti)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Folio (unbuilt property)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/LigneEtatDeSection -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/LigneEtatDeSection">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage"/>
        <rdfs:label>Ligne de tableau d&apos;états de sections</rdfs:label>
        <skos:definition xml:lang="en">A row in the main table of a section status register describing a parcel at the time of the cadastral survey’s initialisation.</skos:definition>
        <skos:definition xml:lang="fr">Ligne du tableau principal d&apos;un registre d&apos;état de sections décrivant une parcelle à l&apos;initialisation du cadastre.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Ligne de tableau d&apos;états de sections</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Table row in an initial register page</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/LigneMatrice -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/LigneMatrice">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage"/>
        <rdfs:label>Ligne de tableau d&apos;une matrice</rdfs:label>
        <skos:definition xml:lang="en">A table row in a folio of a register describing the status of a plot of land.</skos:definition>
        <skos:definition xml:lang="fr">Ligne d&apos;un folio d&apos;une matrice décrivant l&apos;état d&apos;une parcelle.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Ligne de tableau d&apos;une matrice</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Table row in a mutation register page</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/ListeDesContribuablesFonciers -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/ListeDesContribuablesFonciers">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage"/>
        <rdfs:label>Liste des contribuables fonciers</rdfs:label>
        <skos:definition xml:lang="en">A section or cell in a folio or sub-folio that lists the taxpayers on a land register and shows their dates of entry (and exit) from that register.</skos:definition>
        <skos:definition xml:lang="fr">Zone ou cellule d&apos;un folio ou sous-folio qui liste les contribuables d&apos;un compte foncier et indique leurs dates d&apos;entrée (voir de sortie) de ce même compte.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Liste des contribuables fonciers</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Page area describing a list of taxpayers</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/RegistreCadastral"/>
        <rdfs:label>Matrice cadastrale</rdfs:label>
        <skos:definition xml:lang="en">A register containing all changes affecting the plots during its period of validity.</skos:definition>
        <skos:definition xml:lang="fr">Registre contenant l&apos;ensemble des mutations affectant les parcelles pendant la période de validité de la matrice</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice cadastrale</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1807_1822_Bati_NonBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1807_1822_Bati_NonBati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale"/>
        <rdfs:label>Matrice de rôles des propriétés bâties et non bâties (1807-1822)</rdfs:label>
        <skos:altLabel xml:lang="fr">Matrice des propriétés bâties et non bâties (1807-1822)</skos:altLabel>
        <skos:definition xml:lang="fr">Matrice cadastrale créée entre 1807 et 1822, décrit les propriétés bâties et non bâties d&apos;une commune.</skos:definition>
        <skos:definition xml:lang="en">Mutation register created between 1807 and 1822, detailing the built and unbuilt properties within a municipality.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice de rôles des propriétés bâties et non bâties (1807-1822)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register of built and non built properties (1807-1822)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1822_1914_NonBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1822_1914_NonBati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale"/>
        <rdfs:label>Matrice des propriétés non bâties (1822-1914)</rdfs:label>
        <skos:altLabel xml:lang="fr">Matrice des propriétés foncières (1822-1914)</skos:altLabel>
        <skos:definition xml:lang="fr">Matrice cadastrale créée entre 1822 et 1914, décrit les propriétés bâties et non bâties jusqu&apos;à 1882 puis uniquement les propriétés non bâties jusqu&apos;à 1914.</skos:definition>
        <skos:definition xml:lang="en">Mutation register compiled between 1822 and 1914, which lists both built and unbuilt properties up to 1882, and only unbuilt properties up to 1914.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice des propriétés non bâties (1822-1914)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register of non built properties (1822-1914)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1882_1911_Bati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1882_1911_Bati">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale"/>
        <rdfs:label>Matrice des propriétés bâties (1882-1911)</rdfs:label>
        <skos:definition xml:lang="fr">Matrice cadastrale utilisée à partir de 1882 pour décrire les propriétés bâties.</skos:definition>
        <skos:definition xml:lang="en">Mutation register used from 1882 onwards to describe built properties.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice des propriétés bâties (1882-1911)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register of build properties (1882-1911)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1911_Renovation_Bati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1911_Renovation_Bati">
