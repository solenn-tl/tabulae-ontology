        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage"/>
        <skos:definition xml:lang="fr">Ensemble de lignes et de cellules qui décrivent les parcelles d&apos;un ou plusieurs propriétaires conjoints ou sucessifs. Peut correspondre à un ou plusieurs comptes fonciers</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Compte foncier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections -->


