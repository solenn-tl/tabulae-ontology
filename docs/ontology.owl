        <rdfs:comment xml:lang="en">Describes that an element is the trace of another element</rdfs:comment>
        <rdfs:comment xml:lang="fr">Décrit qu&apos;un élément est la trace d&apos;un autre élément</rdfs:comment>
        <rdfs:label xml:lang="fr">est une trace de</rdfs:label>
        <rdfs:label xml:lang="en">is trace of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasClass -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasClass">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#AnnotationClass"/>
        <rdfs:comment xml:lang="fr">Classe attribuée à un élément suivant un processus d&apos;annotation manuellement ou automatique.</rdfs:comment>
        <rdfs:comment xml:lang="en">Indicates that a document or a document area has at least one class assigned manually or automatically.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour classe</rdfs:label>
        <rdfs:label xml:lang="en">has class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasClassValue -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasClassValue">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#AnnotationClass"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <rdfs:comment xml:lang="fr">Valeur d&apos;une classe assignée à un document ou à une zone de document.</rdfs:comment>
        <rdfs:comment xml:lang="en">Value of a class assigned to a document or a document area.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour valeur de classe</rdfs:label>
        <rdfs:label xml:lang="en">has class value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasEquivalentFolio -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasEquivalentFolio">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;attribuer d&apos;associer deux comptes fonciers d&apos;un même contribuable dans une même commune dont l&apos;un est la continuation de l&apos;autre.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to associate two land registry folios of the same taxpayer in the same municipality, one being the continuation of the other.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour folio équivalent</rdfs:label>
        <rdfs:label xml:lang="en">has equivalent folio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasNamedEntity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasNamedEntity">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <rdfs:comment xml:lang="en">A text contains a named entity identified by a manual or automatic process.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un texte contient une entité nommée identifiée par un processus manuel ou automatique.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">includes named entity</rdfs:label>
        <rdfs:label xml:lang="fr">possède l&apos;entité nommée</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasNextVersionInSRCOrder -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasNextVersionInSRCOrder">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasPreviousVersionInSRCOrder"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Cette propriété est utilisée dans l&apos;algorithme de peuplement de l&apos;ontologie PeGaZuS. Elle n&apos;est pas utilisée dans le graphe final.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour version suivante dans les documents</rdfs:label>
        <rdfs:label xml:lang="en">has next version in the source order</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasOverlappingVersionInSRCOrder -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasOverlappingVersionInSRCOrder">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isOverlappedByVersionInSRCOrder"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Cette propriété est utilisée dans l&apos;algorithme de peuplement de l&apos;ontologie PeGaZuS. Elle n&apos;est pas utilisée dans le graphe final.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour version qui se chevauche dans les documents</rdfs:label>
        <rdfs:label xml:lang="en">has overlapping version in the source order</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasPlotAddress -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasPlotAddress">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isPlotAddressOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#Address"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#Landmark"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#LandmarkRelation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links an attribute version to an address or a spatial relation with other geographical landmarks.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une version d&apos;attribut à une adresse ou une relation spatiale avec d&apos;autres repères géographiques.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">has plot address</rdfs:label>
        <rdfs:label xml:lang="fr">parcelle a pour adresse</rdfs:label>
        <skos:altLabel xml:lang="fr">a pour adresse de parcelle</skos:altLabel>
        <skos:altLabel xml:lang="en">has address of plot</skos:altLabel>
        <skos:prefLabel xml:lang="fr">parcelle a pour adresse</skos:prefLabel>
        <skos:prefLabel xml:lang="en">plot has address</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasPlotNature -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasPlotNature">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isPlotNatureOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#Nature"/>
        <rdfs:comment xml:lang="en">Links an attribute version to a plot nature (corresponding to a land use or occupation).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une version d&apos;attribut à une nature de parcelle (correspondant à une occupation ou à un usage du sol).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour nature de parcelle</rdfs:label>
        <rdfs:label xml:lang="en">has plot nature</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasPreviousVersionInSRCOrder -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasPreviousVersionInSRCOrder">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Cette propriété est utilisée dans l&apos;algorithme de peuplement de l&apos;ontologie PeGaZuS. Elle n&apos;est pas utilisée dans le graphe final.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour version précédente dans les documents</rdfs:label>
        <rdfs:label xml:lang="en">has previous version in the source order</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#hasTaxpayer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#hasTaxpayer">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#AttributeVersion"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">Links an attribute version of a plot or a document (Folio) to a taxpayer.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une version d&apos;attribut d&apos;une parcelle ou un document (Folio) à un contribuable.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour contribuable</rdfs:label>
        <rdfs:label xml:lang="en">has taxpayer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isAddressEntityOfTaxpayer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isAddressEntityOfTaxpayer">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#taxpayerHasAddressEntity"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:comment xml:lang="en">Links an address or a spatial relation with other geographical landmarks to a taxpayer. For the addresses provided as strings, see tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une adresse ou une relation spatiale avec d&apos;autres repères géographiques à un contribuable. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">adresse (entité) du contribuable</rdfs:label>
        <rdfs:label xml:lang="en">is address (entity) of a taxpayer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isClassOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isClassOf">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasClass"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#AnnotationClass"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">classe attribuée à</rdfs:label>
        <rdfs:label xml:lang="en">is class of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isClassValueOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isClassValueOf">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasClassValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#AnnotationClass"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est la valeur de classe attribuée à</rdfs:label>
        <rdfs:label xml:lang="en">is class value of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isEventType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isEventType">
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#Event"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#EventType"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est un événement de type</rdfs:label>
        <rdfs:label xml:lang="en">is event type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isMentionnedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isMentionnedIn">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#AttributeVersion"/>
                    <rdf:Description rdf:about="https://w3id.org/tabulae#Taxpayer"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Une entité (entité géographique, contribuable) est mentionnée dans une source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est mentionné dans</rdfs:label>
        <rdfs:label xml:lang="en">is mentionned in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isNamedEntityOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isNamedEntityOf">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasNamedEntity"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A named entity is contained in a text.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une entité nommée est contenue dans un texte.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est une entité nommée de</rdfs:label>
        <rdfs:label xml:lang="en">is named entity of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isNamedEntityType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isNamedEntityType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tabulae#hasClassValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#NamedEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#AnnotationClass"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est une entité nommée de type</rdfs:label>
        <rdfs:label xml:lang="en">is named entity type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isOverlappedByVersionInSRCOrder -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isOverlappedByVersionInSRCOrder">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Cette propriété est utilisée dans l&apos;algorithme de peuplement de l&apos;ontologie PeGaZuS. Elle n&apos;est pas utilisée dans le graphe final.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est chevauchée par la version dans les documents</rdfs:label>
        <rdfs:label xml:lang="en">is overlapped by version in the source order</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isPlotAddressOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isPlotAddressOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#Address"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#Landmark"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#LandmarkRelation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:comment xml:lang="en">Links an address or a spatial relation with other geographical landmarks to an attribute version.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une adresse ou une relation spatiale avec d&apos;autres repères géographiques à une version d&apos;attribut.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est l&apos;adresse associée à</rdfs:label>
        <rdfs:label xml:lang="en">is plot address of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isPlotNatureOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isPlotNatureOf">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Nature"/>
        <rdfs:range rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:comment xml:lang="en">Links a plot nature (corresponding to a land use or occupation) to an attribute version.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une nature de parcelle (correspondant à une occupation ou à un usage du sol) à une version d&apos;attribut.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est une nature de la parcelle</rdfs:label>
        <rdfs:label xml:lang="en">is nature of plot</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isSourceType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isSourceType">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;associer une source à un type de source.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to associate a source to à source type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est une source de type</rdfs:label>
        <rdfs:label xml:lang="en">is source type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isTaxpayerOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isTaxpayerOf">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasTaxpayer"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#AttributeVersion"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a taxpayer to an attribute version of a plot or a document (Folio).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie un contribuable à une version d&apos;attribut d&apos;une parcelle ou un document (Folio).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">est le contribuable associé à</rdfs:label>
        <rdfs:label xml:lang="en">is associated taxpayer of</rdfs:label>
        <skos:altLabel xml:lang="fr">est le contribuable associé à la version d&apos;attribut</skos:altLabel>
        <skos:altLabel xml:lang="en">is taxpayer of attribute version</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#mentions -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#mentions">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isMentionnedIn"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
                    <rdf:Description rdf:about="https://w3id.org/PeGazUs#AttributeVersion"/>
                    <rdf:Description rdf:about="https://w3id.org/tabulae#Taxpayer"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Une source mentionne une ou plusieurs entités (entité géographique, contribuable).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">mentionne</rdfs:label>
        <rdfs:label xml:lang="en">mentions</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#passedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#passedTo">
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/tabulae#SpecialCellValue"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Folio où est décrit l&apos;état de parcelle suivant OU autre information sur l&apos;état suivant d&apos;une parcelle.</rdfs:comment>
        <rdfs:comment xml:lang="en">Folio where the following plot state is described OR other information about the previous or following state of a plot.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">next state or folio</rdfs:label>
        <rdfs:label xml:lang="fr">état ou folio suivant</rdfs:label>
        <skos:altLabel xml:lang="en">passed to</skos:altLabel>
        <skos:altLabel xml:lang="fr">passé à</skos:altLabel>
        <skos:prefLabel xml:lang="en">next state or folio</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">état ou folio suivant</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#sourcedFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#sourcedFrom">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <terms:isReplacedBy rdf:resource="https://w3id.org/PeGazUs#hasTrace"/>
        <rdfs:comment xml:lang="fr">Une affirmation est sourcée à partir d&apos;une source .</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">a pour source</rdfs:label>
        <rdfs:label xml:lang="en">sourced from</rdfs:label>
        <owl:backwardCompatibleWith rdf:resource="https://w3id.org/PeGazUs#hasTrace"/>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#takenFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#takenFrom">
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/tabulae#SpecialCellValue"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Folio où est décrit l&apos;état de parcelle précédent OU information sur l&apos;état précédent d&apos;une parcelle.</rdfs:comment>
        <rdfs:comment xml:lang="en">Folio where the previous plot state is described OR other information about the previous state of a plot.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="en">previous state or folio</rdfs:label>
        <rdfs:label xml:lang="fr">état ou folio précédent</rdfs:label>
        <skos:altLabel xml:lang="en">taken from</skos:altLabel>
        <skos:altLabel xml:lang="fr">tiré de</skos:altLabel>
        <skos:prefLabel xml:lang="en">previous state or folio</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">état ou folio précédent</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerHasAddressEntity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#taxpayerHasAddressEntity">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Links a taxpayer to an address or a spatial relation with other geographical landmarks. For the addresses provided as strings, see tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie un contribuable à une adresse ou une relation spatiale avec d&apos;autres repères géographiques. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/tabulae#"/>
        <rdfs:label xml:lang="fr">contribuable a pour adresse (entité)</rdfs:label>
        <rdfs:label xml:lang="en">taxpayer has address (entity)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#followsInTime -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#followsInTime"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadComponent -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadComponent">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#hasOrHadPart"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasComponentOf"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Connects an Instantiation to one of its present or past component
         instantiations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">a ou a eu pour composant</rdfs:label>
        <rdfs:label xml:lang="en">has or had component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadConstituent -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadConstituent">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#hasOrHadPart"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasConstituentOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordPart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordPart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Connects a Record or Record Part to a Record or Record part that
         is or was a constituent of that Record or Record Part.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">a ou a eu pour constituant</rdfs:label>
        <rdfs:label xml:lang="en">has or had constituent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadDerivedInstantiation -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadDerivedInstantiation">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#precedesInTime"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasDerivedFromInstantiation"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Connects an instantiation to an instantiation that is derived from
         it, whether it exists or has been lost or destroyed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">a ou a eu pour instanciation dérivée</rdfs:label>
        <rdfs:label xml:lang="en">has or had derived instantiation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#hasOrHadInstantiation"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Connects a record resource to one of its digital instantiations,
         whether it exists or has been lost or destroyed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">a ou a eu pour instanciation numérique</rdfs:label>
        <rdfs:label xml:lang="en">has or had digital instantiation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadInstantiation -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadInstantiation">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRelatedTo"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasInstantiationOf"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Connects a Record Resource to an Instantiation, which either may
         exist or may have been lost or destroyed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">a ou a eu pour instanciation</rdfs:label>
        <rdfs:label xml:lang="en">has or had instantiation</rdfs:label>
        <rdfs:label xml:lang="es">tiene o tenía como instanciación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#hasOrHadPart -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#hasOrHadPart"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#includesOrIncluded -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#includesOrIncluded">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#hasOrHadPart"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasIncludedIn"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordSet"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordSet"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Connects a Record Set to a Record or Record Set it aggregates, or
         aggregated in the past.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="en">includes or included</rdfs:label>
        <rdfs:label xml:lang="fr">inclut ou a inclus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasComponentOf -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasComponentOf">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasPartOf"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Inverse of &apos;has or had component&apos; object property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été un composant de</rdfs:label>
        <rdfs:label xml:lang="en">is or was component of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasConstituentOf -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasConstituentOf">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasPartOf"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordPart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordPart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Inverse of &apos;has or had constituent&apos; object
         property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été un constituant de</rdfs:label>
        <rdfs:label xml:lang="en">is or was constituent of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasDerivedFromInstantiation -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasDerivedFromInstantiation">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#followsInTime"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isInstantiationAssociatedWithInstantiation"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:comment xml:lang="en">Inverse of &apos;has or had derived instantiation&apos; object property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été une instanciation dérivée de</rdfs:label>
        <rdfs:label xml:lang="en">is or was derived from instantiation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasDigitalInstantiationOf -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasDigitalInstantiationOf">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasInstantiationOf"/>
        <owl:inverseOf rdf:resource="https://www.ica.org/standards/RiC/ontology#hasOrHadDigitalInstantiation"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:comment xml:lang="en">Inverse of &apos;has or had digital instantiation&apos; object property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été une instanciation numérique de</rdfs:label>
        <rdfs:label xml:lang="en">is or was digital instantiation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasIncludedIn -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasIncludedIn">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isOrWasPartOf"/>
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Record"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordSet"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordSet"/>
        <rdfs:comment xml:lang="en">Inverse of &apos;includes or included&apos; object property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été inclus dans</rdfs:label>
        <rdfs:label xml:lang="en">is or was included in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasInstantiationOf -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasInstantiationOf">
        <rdfs:subPropertyOf rdf:resource="https://www.ica.org/standards/RiC/ontology#isRelatedTo"/>
        <rdfs:domain rdf:resource="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
        <rdfs:range rdf:resource="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
        <rdfs:comment xml:lang="en">Inverse of &apos;has or had instantiation&apos; object property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:label xml:lang="fr">est ou a été une instanciation de</rdfs:label>
        <rdfs:label xml:lang="en">is or was instantiation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isOrWasPartOf -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isOrWasPartOf"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isRecordResourceAssociatedWithRecordResource"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#isRelatedTo -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#isRelatedTo"/>
    


    <!-- https://www.ica.org/standards/RiC/ontology#precedesInTime -->


    <owl:ObjectProperty rdf:about="https://www.ica.org/standards/RiC/ontology#precedesInTime"/>
    


    <!-- 
