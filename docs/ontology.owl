        <rdfs:label>Matrice des propriétés non bâties (1914-rénovation)</rdfs:label>
        <skos:definition xml:lang="fr">Matrice cadastrale utilisée à partir de 1914 pour décrire les propriétés non bâties</skos:definition>
        <skos:definition xml:lang="en">Mutation register used from 1914 onwards to describe unbuilt properties.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice des propriétés non bâties (1914-rénovation)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register of unbuilt properties (1914-cadaster renovation)</skos:prefLabel>
    </owl:NamedIndividual>
    


