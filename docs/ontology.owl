        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="fr">Page non complétée, indépendament de sa nature. Cette classe peut-être utilisée avec d&apos;autres classes pour décrire la page plus précisément.</skos:definition>
        <skos:definition xml:lang="en">Page not completed, regardless of its nature. This class can be used in addition of other classes to describe the page in more detail.</skos:definition>
        <skos:hiddenLabel>ets_blank</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="en">Blank page</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Page vide</skos:prefLabel>
    </owl:NamedIndividual>
    


