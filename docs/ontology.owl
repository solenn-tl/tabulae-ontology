        <skos:hiddenLabel>Cn nvelle</skos:hiddenLabel>
        <skos:hiddenLabel>Con nvelle</skos:hiddenLabel>
        <skos:hiddenLabel>Conston nouvelle</skos:hiddenLabel>
        <skos:hiddenLabel>Construction nouvelle</skos:hiddenLabel>
        <skos:hiddenLabel>Nouvelle construction</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">Construction nouvelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">New building</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/DemolitionSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/DemolitionSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates that a building has been demolished and is therefore no longer subject to property tax.</skos:definition>
        <skos:definition xml:lang="fr">Indique une destruction d&apos;un bâtiment qui n&apos;est donc plus imposable au titre des propriétés bâties.</skos:definition>
        <skos:hiddenLabel>Destruction</skos:hiddenLabel>
        <skos:hiddenLabel>Démolie</skos:hiddenLabel>
        <skos:hiddenLabel>Démolition</skos:hiddenLabel>
        <skos:hiddenLabel>Détruite</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="en">Demolition</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Démolition</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/DiminutionSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/DiminutionSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates a change to a building that results in a reduction in its property valuation.</skos:definition>
        <skos:definition xml:lang="fr">Indique une modification d&apos;un bâtiment qui entraine une diminution de l&apos;évaluation foncière de celui-ci.</skos:definition>
        <skos:hiddenLabel>Dim</skos:hiddenLabel>
        <skos:hiddenLabel>Diminution</skos:hiddenLabel>
        <skos:hiddenLabel>Dton</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#SpecialCellValueList"/>
        <skos:prefLabel xml:lang="fr">Diminution</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Reduction</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/DoubleEmploiSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/DoubleEmploiSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="fr">! A définir au sens de l&apos;administration fiscale.</skos:definition>
