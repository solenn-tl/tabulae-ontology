        <skos:prefLabel xml:lang="en">Double employement</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/specialCellValue/EvaluationSV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/specialCellValue/EvaluationSV">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SpecialCellValue"/>
        <skos:definition xml:lang="en">Indicates a tax valuation or revaluation of a land plot.</skos:definition>
        <skos:definition xml:lang="fr">Indique une évaluation ou réévaluation fiscale d&apos;une parcelle.</skos:definition>
