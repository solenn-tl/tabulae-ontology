        <skos:prefLabel xml:lang="fr">Entité nommée : Raison sociale</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Named entity : Organisation name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayerSpouseOrChildrenFirstNames -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayerSpouseOrChildrenFirstNames">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/NamedEntityTypes"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayer"/>
        <skos:definition xml:lang="fr">Entité nommée identifiable dans une valeur de la colonne relative au contribuable.</skos:definition>
        <skos:definition xml:lang="en">Named entity that can be extracted fril within a value in the taxpayer column.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Entité nommée : Prénom.s de l&apos;époux/épouse ou des enfants</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Named entity : First name.s of the spouse or children</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayerTitle -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayerTitle">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/NamedEntityTypes"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/NETaxpayer"/>
        <skos:definition xml:lang="fr">Entité nommée identifiable dans une valeur de la colonne relative au contribuable.</skos:definition>
        <skos:definition xml:lang="en">Named entity that can be extracted fril within a value in the taxpayer column.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Entité nommée : Titre</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Named entity : Title</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/NamedEntityTypes -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/NamedEntityTypes">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:definition xml:lang="fr">Types d&apos;entités nommées pouvant être reconnues dans les documents cadastraux.</skos:definition>
        <skos:definition xml:lang="en">Types of named entities that can be identified in land registry documents.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Types d&apos;entités nommées</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Types of named entities</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/Page -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/Page">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/DocumentsTypes"/>
        <skos:definition xml:lang="fr">Image correspondant à la numérisation d&apos;une page simple de registre.</skos:definition>
        <skos:definition xml:lang="en">Image showing a scanned single page from a register.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Page simple</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Simple-page</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/PageClasses -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/PageClasses">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="en">List of classes that can be assigned to a single registry page in relation to a classification task.</skos:definition>
        <skos:definition xml:lang="fr">Liste des classes pouvant être attribuées à une page simple de registre, relatif à une tâche de classification.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Types de pages</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Types of simple pages</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/TableHeader -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/TableHeader">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/DocumentsTypes"/>
        <skos:definition xml:lang="en">Image area corresponding to the header of a table.</skos:definition>
        <skos:definition xml:lang="fr">Zone d&apos;une image correspondant à l&apos;entête d&apos;un tableau.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">En-tête de tableau</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Table header</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/TableRow -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/TableRow">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/DocumentsTypes"/>
        <skos:definition xml:lang="en">Image area corresponding to a row of a table.</skos:definition>
        <skos:definition xml:lang="fr">Zone d&apos;une image correspondant à une ligne de tableau</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Ligne de tableau</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Table row</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/TextStyles -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/TextStyles">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="fr">Entité nommée : Style du texte</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Text style</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/attributeType/PlotAddress -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/attributeType/PlotAddress">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#AttributeType"/>
        <skos:altLabel xml:lang="fr">Localisation de la parcelle</skos:altLabel>
        <skos:altLabel xml:lang="en">Plot location</skos:altLabel>
        <skos:definition xml:lang="en">Address of the plot, usually corresponding to a local place name, a road or street, or possibly a house number.</skos:definition>
        <skos:definition xml:lang="fr">Adresse de la parcelle concernée, correspondant généralement à un lieu-dit, à une voie ou rue ou éventuellement à un numéro d&apos;adresse.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#PlotAttributeList"/>
        <skos:prefLabel xml:lang="fr">Adresse de la parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Plot Address</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/attributeType/PlotMention -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/attributeType/PlotMention">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#AttributeType"/>
        <skos:definition xml:lang="fr">Mention de la parcelle dans un document. Correspond généralement à l&apos;indication du folio permettant de la retrouver dans les documents.</skos:definition>
        <skos:definition xml:lang="en">Reference to the plot in the registers. This usually involves stating the current folio of the plot, enabling it to be located in the documents.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#PlotAttributeList"/>
        <skos:prefLabel xml:lang="fr">Mention de la parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mention of the plot</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/attributeType/PlotNature -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/attributeType/PlotNature">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#AttributeType"/>
        <skos:definition xml:lang="fr">Nature de la parcelle concernée, associée au type de sol ou à l&apos;usage de celui-ci.</skos:definition>
        <skos:definition xml:lang="en">Nature of the plot, in relation to the soil type or its use.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#PlotAttributeList"/>
        <skos:prefLabel xml:lang="fr">Nature de la parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Plot Nature</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/attributeType/PlotTaxpayer -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/attributeType/PlotTaxpayer">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#AttributeType"/>
        <skos:altLabel xml:lang="en">Owner or usufructuary</skos:altLabel>
        <skos:altLabel xml:lang="fr">Propriétaire ou usufruitier</skos:altLabel>
        <skos:altLabel>Contribuable</skos:altLabel>
        <skos:altLabel>Taxpayer</skos:altLabel>
        <skos:definition xml:lang="en">A natural or legal person liable for council tax on the plot in question.</skos:definition>
        <skos:definition xml:lang="fr">Personne physique ou morale redevable de l&apos;impôt foncier pour la parcelle concernée.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#PlotAttributeList"/>
        <skos:prefLabel xml:lang="fr">Contribuable associé à la parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Plot Taxpayer</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Addition -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Addition">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent"/>
        <skos:definition xml:lang="fr">Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la hausse (ex : ajout d&apos;un étage ou d&apos;une extension).</skos:definition>
        <skos:definition xml:lang="en">This event is linked to a change to the building that results in an increase in its valuation (e.g. the addition of a floor or an extension).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Augmentation d&apos;un bâtiment</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Extension to a building</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement correspond à une évolution de la nature ou de la valeur d&apos;une parcelle spécifiquement liée à l&apos;apparition, la mutation ou la disparition d&apos;un bâtiment sur celle-ci.</skos:definition>
        <skos:definition xml:lang="en">This event refers to a change in the nature or value of a plot of land specifically linked to the construction, alteration or demolition of a building on that plot.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Event involving a building</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Evènement impliquant un bâtiment</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/ClosePropertyAccount -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/ClosePropertyAccount">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:altLabel xml:lang="fr">Supression d&apos;un compte foncier</skos:altLabel>
        <skos:definition xml:lang="fr">Cet évènement est associé à la clôture du compte foncier d&apos;un contribuable dans une commune donnée. Plus précisément, la date de clôture du compte foncier correspond à la date à laquelle une personne légale ou morale ne paye plus l&apos;impôt foncier pour [1..n] parcelles de la commune concernée.</skos:definition>
        <skos:definition xml:lang="en">This event relates to the closure of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is closed corresponds to the date on which a legal or natural person ceases to pay property tax for [1..n] plots of land in the municipality in question.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Closing of a property tax account</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Fermeture d&apos;un compte foncier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/ConsideredAsRuined -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/ConsideredAsRuined">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent"/>
        <skos:definition xml:lang="fr">Cet évènement est associé au reclassement d&apos;un bâtiment en tant que ruine. Ceci implique généralement qu&apos;il n&apos;est plus imposé au titre des propriétés bâties.</skos:definition>
        <skos:definition xml:lang="en">This event is linked to a building being reclassified as a ruin. This generally means that it is no longer subject to property tax.</skos:definition>
        <skos:hiddenLabel>En ruines</skos:hiddenLabel>
        <skos:hiddenLabel>Ruines</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Declaration of a building in ruins</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Déclaration d&apos;un bâtiment en ruines</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Construction -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Construction">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent"/>
        <skos:definition xml:lang="fr">Cet évènement implique la construction d&apos;un bâtiment sur une parcelle.</skos:definition>
        <skos:definition xml:lang="en">This project involves the construction of a building on a plot of land.</skos:definition>
        <skos:hiddenLabel>Construction nouvelle</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Construction d&apos;un bâtiment</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Construction of a building</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Demotion -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Demotion">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent"/>
        <skos:definition xml:lang="fr">Cet évènement implique la destruction complète d&apos;un bâtiment sur une parcelle.</skos:definition>
        <skos:definition xml:lang="en">This project involves the complete demolition of a building on a plot of land.</skos:definition>
        <skos:hiddenLabel>Destruction</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Demolition of a building</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Démolition d&apos;un bâtiment</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/DocumentCreation -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/DocumentCreation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement désigne l&apos;ajout d&apos;un nouveau document physique dans le corpus cadastral d&apos;une commune donnée. Par exemple, il peut s&apos;agir de l&apos;ouverture d&apos;une matrice (en tant que registre) pour succéder à une matrice déjà complète.</skos:definition>
        <skos:definition xml:lang="en">This event refers to the addition of a new physical document to the cadastral register of a given municipality. For example, it may involve the creation of a new register to replace one that has already been completed.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Creating a document</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Création d&apos;un document</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/DocumentOutdated -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/DocumentOutdated">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement désigne la clôture d&apos;un document physique dans le corpus cadastral d&apos;une commune donnée. Par exemple, il peut s&apos;agir d&apos;un registre dont le contenu a été recopié dans un autre registre et qui n&apos;est plus utilisé.</skos:definition>
        <skos:definition xml:lang="en">This event refers to the closure of a physical document within the cadastral records of a given municipality. For example, it may be a register whose contents have been transcribed into another register and which is no longer in use.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Archivage d&apos;un document</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Archiving a document</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/LandRegistryCreation -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/LandRegistryCreation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement désigne la création d&apos;un cadastre dans une commune, au sens fonctionnel de celui-ci. Un cadastre est initialisé par la production d&apos;un plan parcellaire, correspond à un découpage donné du sol entre divers contribuables, sur lequel chaque parcelle porte un identifiant donné (1 cadastre = 1 numérotation). Les registres (états de sections et matrices) sont initialisés dans la foulée.</skos:definition>
        <skos:definition xml:lang="en">This event refers to the creation of a land registry in a municipality, in the functional sense of the term. A land registry is established through the production of a parcel map, which corresponds to a specific division of land among various taxpayers, on which each parcel is assigned a unique identifier (1 land registry = 1 numbering system). The registers (section statements and matrices) are then created.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Creating a land registry</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Initialisation d&apos;un cadastre</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/LandRegistryOutdated -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/LandRegistryOutdated">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement désigne la clôture d&apos;un cadastre dans une commune, au sens fonctionnel de celui-ci. La clôture précède généralement la production d&apos;un nouveau cadastre qui est doté d&apos;une nouvelle opération de levés, de la production de nouveaux plans représentant un parcellaire différent avec sa numérotation propre.</skos:definition>
        <skos:definition xml:lang="en">This event refers to the closure of a cadastral register in a municipality, in the functional sense of the term. The closure generally precedes the production of a new cadastral register, which involves a new survey, the production of new maps showing a different parcel layout with its own numbering system.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Archivage d&apos;un cadastre</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Archiving a land registry</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement est associé à différentes situations qui impliquent une modification du périmètre d&apos;une parcelle.</skos:definition>
        <skos:definition xml:lang="en">This event is associated with various situations involving a change to the boundaries of a land plot.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Modification du périmètre d&apos;une parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Modification of the boundaries of a plot</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Merge -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Merge">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent"/>
        <skos:definition xml:lang="fr">Cet évènement décrit la fusion de [2..n] parcelles. Dans les documents, cet évènement peut être dététecter de deux façons.\n- Une parcelle est nouvelle associée à deux identifiant (par exemple &quot;D-100 D-102&quot;).\n Deux parcelles portant le même numéro, précédement issues de la division d&apos;une parcelle de plus grande superficie, sont réassociées dans le compte foncier d&apos;un même contribuable.</skos:definition>
        <skos:definition xml:lang="en">This event describes the merging of [2..n] land plots. In the land registry documents, this event can be identified in two ways.\n- A new plot is associated with two identifiers (for example, ‘D-100 D-102’).\n Two plots bearing the same number, previously resulting from the division of a larger plot, are reassociated in the land register of the same taxpayer.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Fusion de parcelles</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Merger of plots</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Omission -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Omission">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:altLabel xml:lang="fr">Oubli de déclaration</skos:altLabel>
        <skos:definition xml:lang="fr">Cet évènement est associé à omission de déclaration d&apos;un bien foncier par un contribuable qui n&apos;a pas payé l&apos;impôt pendant [n] années pour celui-ci. L&apos;évènement désigne précisément le moment de la réintégration a posteriori du bien le compte foncier.</skos:definition>
        <skos:definition xml:lang="en">This event relates to a taxpayer’s failure to declare a property on which they have not paid tax for [n] years. Specifically, it refers to the point at which the property is retrospectively re-included in the property tax assessment.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Failure to declare</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Omission de déclaration</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/OpenPropertyAccount -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/OpenPropertyAccount">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:altLabel xml:lang="fr">Création d&apos;un compte foncier</skos:altLabel>
        <skos:definition xml:lang="fr">Cet évènement est associé à l&apos;ouverture du compte foncier d&apos;un contribuable dans une commune donnée. Plus précisément, la date d&apos;ouverture du compte foncier correspond à la date à laquelle une personne légale ou morale commence à payer l&apos;impôt foncier pour [1..n] parcelles de la commune concernée.</skos:definition>
        <skos:definition xml:lang="en">This event is linked to the opening of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is opened corresponds to the date on which a legal or natural person begins to pay property tax for [1..n] plots of land in the municipality in question.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Opening of a property tax account</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Ouverture d&apos;un compte foncier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Reduction -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Reduction">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent"/>
        <skos:definition xml:lang="fr">Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la baisse (ex: destruction d&apos;une partie du bâtiment).</skos:definition>
        <skos:definition xml:lang="en">This event is linked to a change to the building that results in a downward revaluation (e.g. demolition of part of the building).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Demolition of a building</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Diminution d&apos;un bâtiment</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Sale -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Sale">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation"/>
        <skos:definition xml:lang="fr">Cet évènement consiste en une vente d&apos;une parcelle d&apos;un contribuable à un autre.</skos:definition>
        <skos:definition xml:lang="en">This event involves the sale of a land plot from one taxpayer to another.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Sale</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Vente</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Split -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Split">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent"/>
        <skos:definition xml:lang="fr">Cet évènement décrit la division d&apos;une parcelle en [2..n] nouvelles parcelles. Dans les matrices des contribuables, cet évènement peut être détecté en observant les reports de folios. Si une parcelle décrite dans un compte foncier &quot;passe&quot; dans[2..n] nouveaux comptes fonciers, elle a été divisée entre plusieurs contribuables qui paieront l&apos;impôt chacun pour une sous-partie de la parcelle intiale.</skos:definition>
        <skos:definition xml:lang="en">This event describes the division of a plot into [2..n] new plots. In the mutation registres (Matrices des contribuables), this event can be detected by observing the carry-overs of folio numbers. If a plot described in a land register entry is ‘split’ across [2..n] new land register account, it has been divided amongst several taxpayers, each of whom will pay tax on a sub-portion of the original plot.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Division d&apos;une parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Split of a plot</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/SplitWithStay -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/SplitWithStay">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/Split"/>
        <skos:definition xml:lang="fr">Cet évènement est une précision de l&apos;évènement &quot;Division&quot;. Ici, au moins l&apos;une des nouvelles parcelles résultant de la division reste dans le compte foncier du contribuable associée à la parcelle divisée.</skos:definition>
        <skos:definition xml:lang="en">This event is a specific instance of the ‘Division’ event. In this case, at least one of the new parcels resulting from the division remains in the taxpayer’s land register, linked to the divided parcel.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="fr">Division d&apos;une parcelle avec résidu dans le compte foncier d&apos;origine</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Division of a plot with a residual part in the original property account</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/Succession -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/Succession">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation"/>
        <skos:definition xml:lang="fr">Cet évènement consiste en une transmission d&apos;une ou plusieurs parcelles d&apos;un contribuable à [1..n] autre contribuable lors du réglement d&apos;une sucession à une date donnée.</skos:definition>
        <skos:definition xml:lang="en">This event involves the transfer of one or more plots of land from one taxpayer to [1..n] other taxpayers upon the settlement of an estate on a given date.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Inheritance</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Succession</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#EventType"/>
        <skos:definition xml:lang="fr">Cet évènement est associé à un changement de contribuable associé à une parcelle ou à un compte foncier.</skos:definition>
        <skos:definition xml:lang="en">This event relates to a change in the taxpayer associated with a plot of land or a land account.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryEventList"/>
        <skos:prefLabel xml:lang="en">Modification of taxpayer</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Mutation de contribuable</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/Departement"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q194203"/>
        <skos:definition xml:lang="en">A geographical unit corresponding to the first level of subdivision within a department. Their administrative role has evolved since their creation, which means there are differences compared with the current definition of an arrondissement, although this does not alter the hierarchy of administrative geographical units.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant au premier niveau de sous-division des départements. Leur rôle administratif a évolué depuis leur création, ce qui implique des différences avec la définition actuelle de l&apos;arrondissement sans que celà change la hiérarchie des entités géographiques administratives.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Arrondissement départemental</skos:prefLabel>
        <skos:prefLabel xml:lang="en">French Arrondissement</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Canton -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Canton">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q184188"/>
        <skos:altLabel xml:lang="fr">Canton officiel</skos:altLabel>
        <skos:altLabel xml:lang="fr">Justice de paix</skos:altLabel>
        <skos:definition xml:lang="en">A geographical unit corresponding to the second level of subdivision within departments as recorded in the land registry, situated between the district and the municipality. These are the official cantons, established in the late 18th century, primarily for the organisation of magistrates’ courts (until 1958) and elections. In the land registry records, the term ‘Justice of the Peace’ may also be used instead of ‘Canton’.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant au deuxième niveau de sous-division des départements mentionné dans le cadastre, situé entre l&apos;arrondissement et la commune. Il s&apos;agit ici des cantons officiels, créés à la fin du 18ème siècle, notamment pour l&apos;organisation des justices de paix (jusqu&apos;à 1958) et des élections. Dans les registres cadastraux, le terme &quot;Justice de paix&quot; peut d&apos;ailleurs être utilisé à la place de &quot;Canton&quot;.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Canton</skos:prefLabel>
        <skos:prefLabel xml:lang="en">French Canton</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Commune -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Commune">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/Canton"/>
        <skos:exactMatch rdf:resource="http://data.ign.fr/def/geofla#Commune"/>
        <skos:altLabel xml:lang="en">Municipality</skos:altLabel>
        <skos:definition xml:lang="en">A geographical unit corresponding to the finest administrative division across the whole territory. Each municipality had its own land registry comprising a complete set of documents (maps and registers).</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant au maillage administratif le plus fin sur l&apos;ensemble du territoire. Chaque commune possédait son cadastre comprenant un corpus complet de documents (plans et registres).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Commune</skos:prefLabel>
        <skos:prefLabel xml:lang="en">French Commune</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Departement -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Departement">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit"/>
        <skos:exactMatch rdf:resource="http://data.ign.fr/def/geofla#Departement"/>
        <skos:definition xml:lang="en">A geographical unit corresponding to the French departments since their creation in 1790. The departments were responsible for collecting direct taxes from the municipalities within their territory.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant aux départements français depuis leur création en 1790. Les départements étaient responsable du prélèvement des contributions directes des communes se trouvant sur le territoire.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Département</skos:prefLabel>
        <skos:prefLabel xml:lang="en">French Departement</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:definition xml:lang="en">A geographical entity corresponding to a French administrative unit.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant à une unité administrative française.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="en">French Administrative Unit</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Unité administrative française</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Plot -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Plot">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/Section"/>
        <skos:altLabel xml:lang="en">Land plot</skos:altLabel>
        <skos:definition xml:lang="fr">Entité géographique la plus précise du cadastre, correspondant à une unité de terre cohérente (souvent de même nature) et associée à un contribuable.</skos:definition>
        <skos:definition xml:lang="en">The most precise geographical unit in the land registry, corresponding to a coherent parcel of land (often of the same type) and linked to a taxpayer.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Parcelle</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Plot</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/Section -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/Section">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/landmarkType/Commune"/>
        <skos:altLabel xml:lang="en">Cadastral section</skos:altLabel>
        <skos:definition xml:lang="en">A geographical unit specific to the land registry, it is identified by a single letter in the old land registry and by one or more letters in the updated land registry. It corresponds to a division of the municipality into large groups of plots. Generally speaking, each sheet of the plot map represented a section.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique spécifique au cadastre, elle est identifiée par une lettre dans l&apos;ancien cadastre et par une ou plusieurs lettres dans le cadastre rénové. Elle correspond à un découpage de la commune en grands ensembles de parcelles. Dans le cas général, chaque feuille de plan parcellaire représentait une section.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="en">Section</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Section</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/landmarkType/UnregisteredLand -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/landmarkType/UnregisteredLand">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/PeGazUs#LandmarkType"/>
        <skos:definition xml:lang="en">A geographical unit corresponding to a non-cadastral space, such as a road or a river.</skos:definition>
        <skos:definition xml:lang="fr">Entité géographique correspondant à un espace non cadastré, tel qu&apos;une route ou une rivière.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistryLandmarkList"/>
        <skos:prefLabel xml:lang="fr">Espace non cadastré</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Unregistered land</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/plotNature/Abreuvoir -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/plotNature/Abreuvoir">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#Nature"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/plotNature/NatureNonBatie"/>
        <TFNBGroup>8</TFNBGroup>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#NatureList"/>
        <skos:prefLabel xml:lang="fr">Abreuvoir</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Water trough</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/plotNature/Abricotier -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/plotNature/Abricotier">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#Nature"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/plotNature/Plantation"/>
        <TFNBGroup>3</TFNBGroup>
        <skos:altLabel xml:lang="fr">Abricotiers</skos:altLabel>
        <skos:altLabel xml:lang="en">Apricot</skos:altLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#NatureList"/>
        <skos:prefLabel xml:lang="en">Apricot trees</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plantation d&apos;abricotiers</skos:prefLabel>
