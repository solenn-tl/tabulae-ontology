        <skos:prefLabel xml:lang="en">Georeferenced map</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plan géoréférencé</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/RegistreCadastral -->


