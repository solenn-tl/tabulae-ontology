    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/TableauAssemblage -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/TableauAssemblage">
