        <rdfs:label>Matrice des propriétés bâties (1911-rénovation)</rdfs:label>
        <skos:definition xml:lang="fr">Matrice cadastrale utilisée à partir de 1911 pour décrire les propriétés bâties.</skos:definition>
        <skos:definition xml:lang="en">Mutation register used from 1911 onwards to describe built properties.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
        <skos:prefLabel xml:lang="fr">Matrice des propriétés bâties (1911-rénovation)</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Mutation register of built properties (1911-renewal)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1914_Renovation_NonBati -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale1914_Renovation_NonBati">
