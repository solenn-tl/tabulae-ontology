        <rdfs:label>Plan vectorisé</rdfs:label>
        <skos:definition xml:lang="en">Georeferenced map (manually or automatically).</skos:definition>
        <skos:definition xml:lang="fr">Plan georéférencé (manuellement ou automatiquement).</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#LandRegistrySourceList"/>
