        <rdfs:comment xml:lang="fr">Relie une adresse ou une relation spatiale avec d&apos;autres repères géographiques à une version d&apos;attribut.</rdfs:comment>
        <rdfs:label xml:lang="fr">est l&apos;adresse associée à</rdfs:label>
        <rdfs:label xml:lang="en">is plot address of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isPlotNatureOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isPlotNatureOf">
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Nature"/>
        <rdfs:range rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:comment xml:lang="en">Links a plot nature (corresponding to a land use or occupation) to an attribute version.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie une nature de parcelle (correspondant à une occupation ou à un usage du sol) à une version d&apos;attribut.</rdfs:comment>
        <rdfs:label xml:lang="fr">est une nature de la parcelle</rdfs:label>
        <rdfs:label xml:lang="en">is nature of plot</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isSourceType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isSourceType">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <rdfs:comment xml:lang="fr">Cette propriété permet d&apos;associer une source à un type de source.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to associate a source to à source type.</rdfs:comment>
        <rdfs:label xml:lang="fr">est une source de type</rdfs:label>
        <rdfs:label xml:lang="en">is source type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isTaxpayerOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isTaxpayerOf">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#hasTaxpayer"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:comment xml:lang="en">Links a taxpayer to an attribute version of a plot.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie un contribuable à une version d&apos;attribut d&apos;une parcelle.</rdfs:comment>
        <rdfs:label xml:lang="fr">est le contribuable associé à</rdfs:label>
        <rdfs:label xml:lang="en">is associated taxpayer of</rdfs:label>
        <skos:altLabel xml:lang="fr">est le contribuable associé à la version d&apos;attribut</skos:altLabel>
        <skos:altLabel xml:lang="en">is taxpayer of attribute version</skos:altLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#mentions -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#mentions">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isMentionnedIn"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Une source mentionne un objet.</rdfs:comment>
        <rdfs:label xml:lang="fr">mentionne</rdfs:label>
        <rdfs:label xml:lang="en">mentions</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#passedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#passedTo">
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/tabulae#SpecialCellValue"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Folio où est décrit l&apos;état de parcelle suivant OU autre information sur l&apos;état suivant d&apos;une parcelle.</rdfs:comment>
        <rdfs:comment xml:lang="en">Folio where the following plot state is described OR other information about the previous or following state of a plot.</rdfs:comment>
        <skos:altLabel xml:lang="en">passed to</skos:altLabel>
        <skos:altLabel xml:lang="fr">passé à</skos:altLabel>
        <skos:prefLabel xml:lang="en">next state or folio</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">état ou folio suivant</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#sourcedFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#sourcedFrom">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <terms:isReplacedBy rdf:resource="https://w3id.org/PeGazUs#hasTrace"/>
        <rdfs:comment xml:lang="fr">Une affirmation est sourcée à partir d&apos;une source .</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour source</rdfs:label>
        <rdfs:label xml:lang="en">sourced from</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#takenFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#takenFrom">
        <rdfs:domain rdf:resource="https://w3id.org/PeGazUs#AttributeVersion"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/tabulae#SpecialCellValue"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#Instantiation"/>
                    <rdf:Description rdf:about="https://www.ica.org/standards/RiC/ontology#RecordResource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="fr">Folio où est décrit l&apos;état de parcelle précédent OU information sur l&apos;état précédent d&apos;une parcelle.</rdfs:comment>
        <rdfs:comment xml:lang="en">Folio where the previous plot state is described OR other information about the previous state of a plot.</rdfs:comment>
        <rdfs:label xml:lang="en">previous state or folio</rdfs:label>
        <rdfs:label xml:lang="fr">état ou folio précédent</rdfs:label>
        <skos:altLabel xml:lang="en">taken from</skos:altLabel>
        <skos:altLabel xml:lang="fr">tiré de</skos:altLabel>
        <skos:prefLabel xml:lang="en">previous state or folio</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">état ou folio précédent</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#taxpayerHasAddressEntity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#taxpayerHasAddressEntity">
        <owl:inverseOf rdf:resource="https://w3id.org/tabulae#isAddressEntityOfTaxpayer"/>
        <rdfs:domain rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Links a taxpayer to an address or a spatial relation with other geographical landmarks. For the addresses provided as strings, see tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Relie un contribuable à une adresse ou une relation spatiale avec d&apos;autres repères géographiques. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress.</rdfs:comment>
        <rdfs:label xml:lang="fr">contribuable a pour adresse (entité)</rdfs:label>
        <rdfs:label xml:lang="en">taxpayer has address (entity)</rdfs:label>
    </owl:ObjectProperty>
    


