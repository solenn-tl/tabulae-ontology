    <owl:Ontology rdf:about="https://w3id.org/tabulae#">
        <ns:license rdf:resource="http://creativecommons.org/licenses/by/2.0/"/>
        <ns:license rdf:resource="http://opendatacommons.org/licenses/by/"/>
        <ns:license rdf:resource="http://www.data.gouv.fr/Licence-Ouverte-Open-Licence"/>
        <terms:abstract xml:lang="fr">L&apos;ontologie TABULAE vise à décrire l&apos;évolution des parcelles cadastrales à l&apos;échelle de leurs attributs.</terms:abstract>
        <terms:abstract xml:lang="en">The TABULAE ontology aims to describe the evolution of land plots at the attribute level.</terms:abstract>
        <terms:contributor rdf:nodeID="genid1"/>
        <terms:contributor rdf:nodeID="genid3"/>
        <terms:contributor rdf:nodeID="genid5"/>
        <terms:contributor rdf:nodeID="genid7"/>
        <terms:creator rdf:nodeID="genid9"/>
        <terms:description xml:lang="fr">Ontologie pour décrire les informations sur les parcelles, et les entités liées, présentes dans le cadastre ancien. Extension de l&apos;ontologie PeGaZus.</terms:description>
        <terms:description xml:lang="en">Ontology to describe the information about land plots and associated entities evocated in the old land registry documents. Extension of the PeGazUs ontology.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-24</terms:issued>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/"/>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/2.0/"/>
        <terms:license rdf:resource="http://www.data.gouv.fr/Licence-Ouverte-1.0"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-07-12</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</terms:modified>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-14</terms:modified>
        <terms:publisher rdf:nodeID="genid16"/>
        <terms:rights>Copyright 2024-2026, IGN</terms:rights>
        <terms:title xml:lang="fr">Ontologie TABULAE</terms:title>
        <terms:title xml:lang="en">TABULAE ontology</terms:title>
        <vann:preferredNamespacePrefix>tbl</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://w3id.org/tabulae#"/>
        <voaf:extends rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:label xml:lang="fr">Ontologie TABULAE</rdfs:label>
        <rdfs:label xml:lang="en">TABULAE Ontology</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/PeGazUs#"/>
        <rdfs:seeAlso rdf:resource="https://www.ica.org/standards/RiC/ontology#"/>
        <rdfs:seeAlso rdf:resource="https://www.w3.org/TR/owl-time/"/>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <schema:codeRepository rdf:resource="https://github.com/solenn-tl/tabulae-ontology"/>
        <schema:funding>Agence d&apos;Innovation de Défense (AID) - Ministère des Armées</schema:funding>
        <schema:funding>Institut National de l&apos;Information Géographique et Forestière (IGN)</schema:funding>
        <vocab:introduction xml:lang="fr">L&apos;ontologie TABULAE est une extension de l&apos;ontologie PeGazUs dédiée à la représentation des informations relatives aux parcelles contenues dans les documents du cadastre ancien français (XIXe siècle). Elle permet de décrire les parcelles (Plot), leurs contribuables (Taxpayer), leur nature d&apos;occupation du sol (Nature, avec plus de 150 valeurs contrôlées) et leur adresse, ainsi que les événements et changements qui affectent ces parcelles au fil du temps. Leur évolution est décrite à l&apos;échelle des attributs. L&apos;ontologie modélise également les sources documentaires mobilisées (matrices cadastrales, états de sections, plans parcellaires) et intègre des concepts et propriétés utiles à la traçabilité des processus de traitement (manuel ou automatique) réalisés pour extraire des informations des documents (classification des images, extraction d&apos;information, reconnaissance des entités nommées). L&apos;ontologie TABULAE s&apos;appuie sur les ontologies PeGazUs, RiC-O, Time et PROV-O.</vocab:introduction>
        <vocab:introduction xml:lang="en">The TABULAE ontology is an extension of the PeGazUs vocabulary dedicated to the representation of information about land plots contained in the French 19th-century land registry documents. It enables the description of land plots, their nature (with over 150 controlled values) and addresses, of the associated taxpayers, and the changes and events affecting these plots over time. Their evolution is described at the attribute level. The ontology also models the sources involved (mutation registers, section registers, cadastral index maps) and provides support to described the processing of the documents, by hand or automatically, including images classification, information extraction and named entity recognition in digitised documents. The TABULAE ontology re-uses concepts and properties of the PeGazUs, Time, RiC-O, and PROV-O ontologies.</vocab:introduction>
    </owl:Ontology>
