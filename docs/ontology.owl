    <!-- http://data.ign.fr/def/geofla#Commune -->


    <owl:NamedIndividual rdf:about="http://data.ign.fr/def/geofla#Commune"/>
    


    <!-- http://data.ign.fr/def/geofla#Departement -->


    <owl:NamedIndividual rdf:about="http://data.ign.fr/def/geofla#Departement"/>
    


    <!-- https://w3id.org/tabulae# -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#">
        <rdf:type rdf:resource="http://purl.org/vocommons/voaf#Vocabulary"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#AnnotationClassList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#AnnotationClassList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of the various classes that can be assigned to a document, a field within a document, or a text or text excerpt, represented as a list of SKOS concepts. These classes are assigned during the process of extracting and structuring digitised land registry documents. They enable the creation of the graph ultimately used to study changes in land plots.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des différentes classes pouvant être attribuées à un document, à une zone dans un document, à un texte ou extrait de texte, représentés comme une liste de concepts SKOS. Ces classes sont attribuées lors de processus d&apos;extraction et de structuration des documents cadastraux numérisés. Ils permettent de produire le graphe finalement utilisé pour étudier l&apos;évolution des parcelles.</rdfs:comment>
        <rdfs:label xml:lang="en">List of classes and entity types used in document processing workflows</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des classes et types d&apos;entités utilisés lors des processus de traitement des documents</rdfs:label>
        <skos:prefLabel xml:lang="en">List of classes and entity types used in document processing workflows</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des classes et types d&apos;entités utilisés lors des processus de traitement des documents</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#LandRegistryChangeList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#LandRegistryChangeList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of the various changes specific to the land registry, affecting its different types of entities (geographical entities, taxpayers, documents), represented as a list of SKOS concepts.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des différents changements spécifique au cadastre, impactant ses différents types d&apos;entités (entités géographiques, contribuables, documents), représentés comme une liste de concepts SKOS.</rdfs:comment>
        <rdfs:label xml:lang="en">List of types of changes related to the land registry.</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des types de changements liés au cadastre.</rdfs:label>
        <skos:prefLabel xml:lang="en">List of types of changes related to the land registry.</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des types de changements liés au cadastre.</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#LandRegistryEventList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#LandRegistryEventList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of types of events related to the land regsitry that may occur, relating to the geographical features described or to the documents, represented as a list of SKOS concepts.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des types d&apos;évènements associés aux cadastre pouvant intervenir, liés aux entités géographiques décrites ou aux documents, représentés comme une liste de concepts SKOS.</rdfs:comment>
        <rdfs:label xml:lang="en">List of types of events related to the land registry.</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des types d&apos;évènements liés au cadastre.</rdfs:label>
        <skos:prefLabel xml:lang="en">List of types of events related to the land registry.</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des types d&apos;évènements liés au cadastre.</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#LandRegistryLandmarkList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#LandRegistryLandmarkList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of reference types mentioned in the land registry, represented as a list of SKOS concepts.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des types de repères mentionnés dans le cadastre, représentés comme une liste de concepts SKOS.</rdfs:comment>
        <rdfs:label xml:lang="en">List of types of geographical features associated with the land registry</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des types d&apos;entités géographiques liées au cadastre</rdfs:label>
        <skos:prefLabel xml:lang="en">List of types of geographical features associated with the land registry</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des types d&apos;entités géographiques liées au cadastre</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#LandRegistrySourceList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#LandRegistrySourceList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of the different types of sources (documents) and their derivative versions, represented as a list of SKOS concepts.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des différentes types de sources (documents) et de leurs versions dérivées, représentées comme une liste de concepts SKOS.</rdfs:comment>
        <rdfs:label xml:lang="en">List of types of sources related to the land registry</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des types de sources liées au cadastre</rdfs:label>
        <skos:prefLabel xml:lang="en">List of types of sources related to the land registry</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">List of types of sources related to the land registry</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#NatureList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#NatureList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of the different natures of plots, represented as a list of SKOS concepts. The types in the list are derived from observations made in old land registry as well as in documents describing the content of the current land registry.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des différentes natures de parcelles, représentés comme une liste de concepts SKOS. Les natures de la liste sont issues d&apos;observations réalisées dans les documents cadastraux anciens ainsi que dans des documents descriptifs du cadastre moderne.</rdfs:comment>
        <rdfs:label xml:lang="en">List of plot natures</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des natures de parcelles</rdfs:label>
        <skos:prefLabel xml:lang="en">List of plot natures</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des natures de parcelles</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#PlotAttributeList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#PlotAttributeList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of the various roles specific to the plots described in the land registry, that can be assigned to an attribute, represented as a list of SKOS concepts.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des différents rôles spécifique aux parcelles cadastrales pouvant être joués par un attribut, représentés comme une liste de concepts SKOS.</rdfs:comment>
        <rdfs:label xml:lang="en">List of attribute types specific to land plots described in the land registry.</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des types d&apos;attributs spécifiques aux parcelles cadastrales.</rdfs:label>
        <skos:prefLabel xml:lang="en">List of attribute types specific to land plots described in the land registry.</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des types d&apos;attributs spécifiques aux parcelles cadastrales.</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae#SpecialCellValueList -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae#SpecialCellValueList">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment xml:lang="en">List of so-called special values found in cadastral documents. Once explained, these values enable the generation of structured insights into changes in land parcels. They are used in particular during the graph generation phase.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Liste des valeurs dites spéciales rencontrées dans les documents cadastraux. Une fois explicitées, ces valeurs permettent de produire des connaissances structurées sur l&apos;évolution des parcelles. Elles sont notamment utilisées lors de la phase de production du graphe.</rdfs:comment>
        <rdfs:label xml:lang="en">List of special values found in the cadastral tables</rdfs:label>
        <rdfs:label xml:lang="fr">Liste des valeurs spéciales rencontrées dans les tables cadastrales</rdfs:label>
        <skos:prefLabel xml:lang="en">List of special values found in the cadastral tables</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Liste des valeurs spéciales rencontrées dans les tables cadastrales</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/BlankPage -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/BlankPage">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
