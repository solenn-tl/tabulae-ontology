        <skos:prefLabel xml:lang="en">Summary</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/ETSTab -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/ETSTab">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/PageClasses"/>
        <skos:closeMatch rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/ETSTabP1"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="en">Main table page of an initial register containing a description of the plots listed in ascending order by number.</skos:definition>
        <skos:definition xml:lang="fr">Page du tableau principal d&apos;un registre d&apos;états de sections contenant la description des parcelles listées dans l&apos;ordre croissant des numéros.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="en">Main table in an initial register</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Tableau principal d&apos;état de section</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/ETSTabP1 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/ETSTabP1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/PageClasses"/>
        <skos:closeMatch rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/ETSTab"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="en">First page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822.</skos:definition>
        <skos:definition xml:lang="fr">Première page (sur deux) du tableau principal d&apos;un registre d&apos;état de sections contenant la description des parcelles listées dans l&apos;ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822.</skos:definition>
        <skos:hiddenLabel>ets_tab_p1</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="en">First page of a main table in an initial register</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Tableau principal d&apos;état de section (première page si double page)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/ETSTabP2 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/ETSTabP2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/PageClasses"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="en">Last page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822.</skos:definition>
        <skos:definition xml:lang="fr">Seconde page du tableau principal d&apos;un registre d&apos;état de sections contenant la description des parcelles listées dans l&apos;ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822.</skos:definition>
        <skos:hiddenLabel>ets_tab_p2</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="en">Second page of a main table in an initial register</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Tableau principal d&apos;état de section (seconde page si double page)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/MATAlphabeticTable -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/MATAlphabeticTable">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/PageClasses"/>
        <skos:related rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/Page"/>
        <skos:definition xml:lang="fr">Page d&apos;une matrice cadastrale correspondant à une liste alphabétique des contribuables.</skos:definition>
        <skos:definition xml:lang="en">Page from a mutation register containing an alphabetical list of taxpayers.</skos:definition>
        <skos:hiddenLabel>mat_alpha_tab</skos:hiddenLabel>
        <skos:inScheme rdf:resource="https://w3id.org/tabulae#AnnotationClassList"/>
        <skos:prefLabel xml:lang="en">Alphabetical table</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Table alphabétique</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/tabulae/id/codes/annotationClass/MATCompteFoncier -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/annotationClass/MATCompteFoncier">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#AnnotationClassType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/annotationClass/DocumentsTypes"/>
        <skos:altLabel xml:lang="fr">Ligne de tableau décrivant un état de parcelle</skos:altLabel>
        <skos:definition xml:lang="en">Image area corresponding to a group of lines delineating parcels associated with a list of 1 to n taxpayers located in a folio of a register.</skos:definition>
