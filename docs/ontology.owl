    <!-- https://w3id.org/tabulae/id/codes/sourceType/Plan -->


    <owl:NamedIndividual rdf:about="https://w3id.org/tabulae/id/codes/sourceType/Plan">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/tabulae#SourceType"/>
        <skos:broader rdf:resource="https://w3id.org/tabulae/id/codes/sourceType/Cadastre"/>
