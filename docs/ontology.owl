        <rdfs:label xml:lang="fr">a pour contribuable</rdfs:label>
        <rdfs:label xml:lang="en">has taxpayer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tabulae#isAddressEntityOfTaxpayer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tabulae#isAddressEntityOfTaxpayer">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/tabulae#Taxpayer"/>
