<https://w3id.org/tabulae#> rdf:type owl:Ontology ;
                             <http://creativecommons.org/ns#license> <http://creativecommons.org/licenses/by/2.0/> ,
                                                                     <http://opendatacommons.org/licenses/by/> ,
                                                                     <http://www.data.gouv.fr/Licence-Ouverte-Open-Licence> ;
                             <http://purl.org/dc/terms/abstract> "L'ontologie TABULAE est une extension de l'ontologie PeGazUs dédiée à la représentation des informations relatives aux parcelles contenues dans les documents du cadastre ancien français (XIXe siècle). Elle permet de décrire les parcelles (Plot), leurs contribuables (Taxpayer), leur nature d'occupation du sol (Nature, avec plus de 150 valeurs contrôlées), ainsi que les événements et changements qui affectent ces parcelles au fil du temps. Leur évolution est décrite à l'échelle des attributs. L'ontologie modélise également les sources documentaires mobilisées (matrices cadastrales, états de sections, plans parcellaires) et intègre un support pour la classification automatique et la reconnaissance d'entités nommées dans les documents numérisés (anclass, NamedEntity). Elle s'appuie sur les ontologies PeGazUs, RiC-O, SKOS et PROV-O."@fr ,
                                                                 "L'ontology TABULAE is an extension of the PeGazUs vocabulary dedicated to the representation of information contained in the French 19th-century land registry documents. It enables the description of land plots, their taxpayers, their nature (with over 150 controlled values), and the changes and events affecting these plots over time. Their evolution is described at the attribute level. The ontology also models the sources involved (mutation registers, section registers, cadastral index maps) and provides support for automatic classification and named entity recognition in digitised documents (anclass, NamedEntity). It builds on the PeGazUs, RiC-O, SKOS and PROV-O ontologies."@en ;
                             <http://purl.org/dc/terms/contributor> _:genid1 ,
                                                                    _:genid3 ,
                                                                    _:genid5 ,
                                                                    _:genid7 ;
                             <http://purl.org/dc/terms/creator> _:genid9 ;
                             <http://purl.org/dc/terms/description> "Ontologie pour décrire les informations sur les parcelles, et les entités liées, présentes dans le cadastre ancien. Extension de l'ontologie PeGaZus."@fr ,
                                                                    "Ontology to describe the information about land plots and associated entities evocated in the old land registry documents. Extension of the PeGazUs ontology."@en ;
                             <http://purl.org/dc/terms/issued> "2024-01-24"^^xsd:date ;
                             <http://purl.org/dc/terms/license> <http://creativecommons.org/licenses/by/> ,
                                                                <http://creativecommons.org/licenses/by/2.0/> ,
                                                                <http://www.data.gouv.fr/Licence-Ouverte-1.0> ;
                             <http://purl.org/dc/terms/modified> "2025-07-12"^^xsd:date ,
                                                                 "2026-04-17"^^xsd:date ,
                                                                 "2026-06-07"^^xsd:date ;
                             <http://purl.org/dc/terms/publisher> _:genid16 ;
                             <http://purl.org/dc/terms/rights> "Copyright 2024-2026, IGN" ;
                             <http://purl.org/dc/terms/title> "Ontologie TABULAE"@fr ,
                                                              "TABULAE ontology"@en ;
                             <http://purl.org/vocab/vann/preferredNamespacePrefix> "tbl" ;
                             <http://purl.org/vocab/vann/preferredNamespaceUri> <https://w3id.org/tabulae#> ;
                             <http://purl.org/vocommons/voaf#extends> <https://w3id.org/PeGazUs#> ;
                             rdfs:label "Ontologie TABULAE"@fr ,
                                        "TABULAE Ontology"@en ;
                             rdfs:seeAlso <http://www.w3.org/ns/prov#> ,
                                          <https://w3id.org/PeGazUs#> ,
                                          <https://www.ica.org/standards/RiC/ontology#> ;
                             owl:versionInfo "2.0.0" ;
                             <https://schema.org/codeRepository> <https://github.com/solenn-tl/tabulae-ontology> ;
                             <https://schema.org/funding> "Agence d'Innovation de Défense (AID) - Ministère des Armées" ,
                                                          "Institut National de l'Information Géographique et Forestière (IGN)" .

