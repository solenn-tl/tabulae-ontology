###  https://w3id.org/tabulae/id/codes/sourceType/ArticleDeMutation
<https://w3id.org/tabulae/id/codes/sourceType/ArticleDeMutation> rdf:type owl:NamedIndividual ,
                                                                          <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                          :SourceType ;
                                                                 rdfs:label "Article de mutation" ;
                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/sourceType/ZoneDePage> ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "A section or cell in a folio or sub-folio that lists the taxpayers on a land register and shows their dates of entry (and exit) from that register."@en ,
                                                                                                                  "Zone ou cellule d'un folio ou sous-folio qui liste les contribuables d'un compte foncier et indique leurs dates d'entrée (voir de sortie) de ce même compte."@fr ;
                                                                 <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistrySourceList ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Article de mutation"@fr ,
                                                                                                                 "Page area describing a list of taxpayers"@en .


###  https://w3id.org/tabulae/id/codes/sourceType/Cadastre
<https://w3id.org/tabulae/id/codes/sourceType/Cadastre> rdf:type owl:NamedIndividual ,
                                                                 <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                 :SourceType ;
                                                        rdfs:label "Cadastre" ;
                                                        <http://www.w3.org/2004/02/skos/core#altLabel> "Corpus cadastral"@fr ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "A land registry comprising maps and registers, used for a certain period to calculate and collect property tax on plots of land within a municipality."@en ,
                                                                                                         "Corpus cadastral composé de plans et de registres, utilisé pendant une certaine période pour le calcul et le prélèvement de l'impôt foncier des parcelles d'une commune."@fr ;
                                                        <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistrySourceList ;
                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Cadastre"@fr ,
                                                                                                        "Land registry corpus"@en .


###  https://w3id.org/tabulae/id/codes/sourceType/CompteFoncier
<https://w3id.org/tabulae/id/codes/sourceType/CompteFoncier> rdf:type owl:NamedIndividual ,
                                                                      <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                      :SourceType ;
                                                             rdfs:label "Compte foncier" ;
                                                             <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/sourceType/MatriceCadastrale> ;
                                                             <http://www.w3.org/2004/02/skos/core#definition> "A set of parcel records (lines) describing the plots of one or more successive related taxpayers. A land account may correspond ‘physically’ to a folio where the latter describes the details of one, and only one, taxpayer (or a list of successive taxpayers)."@en ,
                                                                                                              "Ensemble d'états de parcelles (lignes) qui décrivent les parcelles d'un ou plusieurs contribuables liés se succédant. Un compte foncier peut correspondre \"physiquement\" à un folio dans le cas où celui-ci décrit les informations d'un, et un seul, contribuable (ou liste de contribuables successifs)."@fr ;
                                                             <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistrySourceList ;
                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "Compte foncier"@fr ,
                                                                                                             "Property account"@en .


###  https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections
<https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections> rdf:type owl:NamedIndividual ,
                                                                        <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                        :SourceType ;
                                                               rdfs:label "Etats de sections" ;
                                                               <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/sourceType/RegistreCadastral> ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Initial register detailing the initial status of plots within a municipality on a given date for a specific cadastral survey, prior to the completion of a cadastral map."@en ,
                                                                                                                "Registre d'état de sections décrivant l'état initial des parcelles d'une commune à une date donnée pour un cadastre donné, proche de la réalisation d'un plan cadastral."@fr ;
                                                               <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistrySourceList ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Etats de sections"@fr ,
                                                                                                               "Initial register"@en .


###  https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Ap_1822
<https://w3id.org/tabulae/id/codes/sourceType/EtatsDeSections_Ap_1822> rdf:type owl:NamedIndividual ,
