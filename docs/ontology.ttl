                                                     <http://www.w3.org/2004/02/skos/core#hiddenLabel> "ets_couv" ;
                                                     <http://www.w3.org/2004/02/skos/core#inScheme> :AnnotationClassList ;
                                                     <http://www.w3.org/2004/02/skos/core#prefLabel> "Couverture décrivant une section dans un registre d'états de sections"@fr ;
