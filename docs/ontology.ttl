###  https://w3id.org/tabulae#AnnotationClassList
:AnnotationClassList rdf:type owl:NamedIndividual ,
                              <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                     rdfs:comment "Liste des différentes classes pouvant être attribuées à un document ou à une zone dans un document, représentés comme une liste de concepts SKOS."@fr ;
                     rdfs:label "List of classes"@en ,
                                "Liste de classes"@fr ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "List of classes"@en ,
                                                                     "Liste de classes"@fr .


###  https://w3id.org/tabulae#LandRegistryAttributeList
:LandRegistryAttributeList rdf:type owl:NamedIndividual ,
                                    <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                           rdfs:comment "Liste des différents rôles spécifique au cadastre pouvant être joués par un attribut, représentés comme une liste de concepts SKOS."@fr ;
                           rdfs:label "Type d'attributs spécifiques aux objets du cadastre"@fr ,
                                      "Type of attributes specific to land registry objects"@en ;
                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Type d'attributs spécifiques aux objets du cadastre"@fr ,
                                                                           "Type of attributes specific to land registry objects"@en .


###  https://w3id.org/tabulae#LandRegistryChangeList
:LandRegistryChangeList rdf:type owl:NamedIndividual ,
                                 <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                        rdfs:comment "Liste des différents changements spécifique au cadastre, représentés comme une liste de concepts SKOS."@fr ;
                        rdfs:label "Type de changements spécifiques au cadastre"@fr ,
                                   "Type of changes related to the land registry"@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Type de changements spécifiques au cadastre"@fr ,
                                                                        "Type of changes related to the land registry"@en .


###  https://w3id.org/tabulae#LandRegistryEventList
:LandRegistryEventList rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                       rdfs:comment "List of event types that can occur, specific to the land registry, represented as a list of SKOS concepts."@en ,
                                    "Liste des types d'évènements pouvant intervenir, spécifiques au cadastre, représentés comme une liste de concepts SKOS."@fr ;
                       rdfs:label "Type d'événement"@fr ,
                                  "Type of event"@en ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Type d'événement"@fr ,
                                                                       "Type of event"@en .


###  https://w3id.org/tabulae#LandRegistryLandmarkList
:LandRegistryLandmarkList rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                          rdfs:comment "Liste des différents rôles pouvant être joués par un repère spécifique au cadastre, représentés comme une liste de concepts SKOS."@fr ;
                          rdfs:label "Type de repère spécifiques au cadastre français"@fr ,
                                     "Type of landmark related to the land registry"@en ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Type de repère spécifiques au cadastre"@fr ,
                                                                          "Type of landmark related to the land registry"@en .


###  https://w3id.org/tabulae#LandRegistrySourceList
:LandRegistrySourceList rdf:type owl:NamedIndividual ,
                                 <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                        rdfs:comment "Liste des différentes sources de données, représentées comme une liste de concepts SKOS."@fr ;
                        rdfs:label "Type de sources"@fr ,
                                   "Type of sources"@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Type de sources"@fr ,
                                                                        "Type of sources"@en .


###  https://w3id.org/tabulae#NatureList
:NatureList rdf:type owl:NamedIndividual ,
                     <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
