                                                                <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                :EventType ;
                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la hausse (ex : ajout d'un étage ou d'une extension)."@fr ,
                                                                                                        "This event is linked to a change to the building that results in an increase in its valuation (e.g. the addition of a floor or an extension)."@en ;
                                                       <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Augmentation d'un bâtiment"@fr ,
                                                                                                       "Extension to a building"@en .


###  https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent
<https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> rdf:type owl:NamedIndividual ,
                                                                            <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                            :EventType ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement correspond à une évolution de la nature ou de la valeur d'une parcelle spécifiquement liée à l'apparition, la mutation ou la disparition d'un bâtiment sur celle-ci."@fr ,
                                                                                                                    "This event refers to a change in the nature or value of a plot of land specifically linked to the construction, alteration or demolition of a building on that plot."@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Event involving a building"@en ,
                                                                                                                   "Evènement impliquant un bâtiment"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/ClosePropertyAccount
<https://w3id.org/tabulae/id/codes/eventType/ClosePropertyAccount> rdf:type owl:NamedIndividual ,
                                                                            <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                            :EventType ;
                                                                   <http://www.w3.org/2004/02/skos/core#altLabel> "Supression d'un compte foncier"@fr ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à la clôture du compte foncier d'un contribuable dans une commune donnée. Plus précisément, la date de clôture du compte foncier correspond à la date à laquelle une personne légale ou morale ne paye plus l'impôt foncier pour [1..n] parcelles de la commune concernée."@fr ,
                                                                                                                    "This event relates to the closure of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is closed corresponds to the date on which a legal or natural person ceases to pay property tax for [1..n] plots of land in the municipality in question."@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Closing of a property tax account"@en ,
                                                                                                                   "Fermeture d'un compte foncier"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/ConsideredAsRuined
<https://w3id.org/tabulae/id/codes/eventType/ConsideredAsRuined> rdf:type owl:NamedIndividual ,
                                                                          <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                          :EventType ;
                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé au reclassement d'un bâtiment en tant que ruine. Ceci implique généralement qu'il n'est plus imposé au titre des propriétés bâties."@fr ,
                                                                                                                  "This event is linked to a building being reclassified as a ruin. This generally means that it is no longer subject to property tax."@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#hiddenLabel> "En ruines" ,
                                                                                                                   "Ruines" ;
                                                                 <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Declaration of a building in ruins"@en ,
                                                                                                                 "Déclaration d'un bâtiment en ruines"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/Construction
<https://w3id.org/tabulae/id/codes/eventType/Construction> rdf:type owl:NamedIndividual ,
                                                                    <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                    :EventType ;
                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement implique la construction d'un bâtiment sur une parcelle."@fr ,
                                                                                                            "This project involves the construction of a building on a plot of land."@en ;
                                                           <http://www.w3.org/2004/02/skos/core#hiddenLabel> "Construction nouvelle" ;
                                                           <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Construction d'un bâtiment"@fr ,
                                                                                                           "Construction of a building"@en .


###  https://w3id.org/tabulae/id/codes/eventType/Demotion
<https://w3id.org/tabulae/id/codes/eventType/Demotion> rdf:type owl:NamedIndividual ,
                                                                <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                :EventType ;
                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement implique la destruction complète d'un bâtiment sur une parcelle."@fr ,
                                                                                                        "This project involves the complete demolition of a building on a plot of land."@en ;
                                                       <http://www.w3.org/2004/02/skos/core#hiddenLabel> "Destruction" ;
                                                       <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Demolition of a building"@en ,
                                                                                                       "Démolition d'un bâtiment"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/DocumentCreation
<https://w3id.org/tabulae/id/codes/eventType/DocumentCreation> rdf:type owl:NamedIndividual ,
                                                                        <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                        :EventType ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement désigne l'ajout d'un nouveau document physique dans le corpus cadastral d'une commune donnée. Par exemple, il peut s'agir de l'ouverture d'une matrice (en tant que registre) pour succéder à une matrice déjà complète."@fr ,
                                                                                                                "This event refers to the addition of a new physical document to the cadastral register of a given municipality. For example, it may involve the creation of a new register to replace one that has already been completed."@en ;
                                                               <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Creating a document"@en ,
                                                                                                               "Création d'un document"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/DocumentOutdated
<https://w3id.org/tabulae/id/codes/eventType/DocumentOutdated> rdf:type owl:NamedIndividual ,
                                                                        <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                        :EventType ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement désigne la clôture d'un document physique dans le corpus cadastral d'une commune donnée. Par exemple, il peut s'agir d'un registre dont le contenu a été recopié dans un autre registre et qui n'est plus utilisé."@fr ,
                                                                                                                "This event refers to the closure of a physical document within the cadastral records of a given municipality. For example, it may be a register whose contents have been transcribed into another register and which is no longer in use."@en ;
                                                               <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Archivage d'un document"@fr ,
                                                                                                               "Archiving a document"@en .


###  https://w3id.org/tabulae/id/codes/eventType/LandRegistryCreation
<https://w3id.org/tabulae/id/codes/eventType/LandRegistryCreation> rdf:type owl:NamedIndividual ,
                                                                            <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                            :EventType ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement désigne la création d'un cadastre dans une commune, au sens fonctionnel de celui-ci. Un cadastre est initialisé par la production d'un plan parcellaire, correspond à un découpage donné du sol entre divers contribuables, sur lequel chaque parcelle porte un identifiant donné (1 cadastre = 1 numérotation). Les registres (états de sections et matrices) sont initialisés dans la foulée."@fr ,
                                                                                                                    "This event refers to the creation of a land registry in a municipality, in the functional sense of the term. A land registry is established through the production of a parcel map, which corresponds to a specific division of land among various taxpayers, on which each parcel is assigned a unique identifier (1 land registry = 1 numbering system). The registers (section statements and matrices) are then created."@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Creating a land registry"@en ,
                                                                                                                   "Initialisation d'un cadastre"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/LandRegistryOutdated
<https://w3id.org/tabulae/id/codes/eventType/LandRegistryOutdated> rdf:type owl:NamedIndividual ,
                                                                            <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                            :EventType ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement désigne la clôture d'un cadastre dans une commune, au sens fonctionnel de celui-ci. La clôture précède généralement la production d'un nouveau cadastre qui est doté d'une nouvelle opération de levés, de la production de nouveaux plans représentant un parcellaire différent avec sa numérotation propre."@fr ,
                                                                                                                    "This event refers to the closure of a cadastral register in a municipality, in the functional sense of the term. The closure generally precedes the production of a new cadastral register, which involves a new survey, the production of new maps showing a different parcel layout with its own numbering system."@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Archivage d'un cadastre"@fr ,
                                                                                                                   "Archiving a land registry"@en .


###  https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent
<https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent> rdf:type owl:NamedIndividual ,
                                                                     <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                     :EventType ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à différentes situations qui impliquent une modification du périmètre d'une parcelle."@fr ,
                                                                                                             "This event is associated with various situations involving a change to the boundaries of a land plot."@en ;
                                                            <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                            <http://www.w3.org/2004/02/skos/core#prefLabel> "Modification du périmètre d'une parcelle"@fr ,
                                                                                                            "Modification of the boundaries of a plot"@en .


###  https://w3id.org/tabulae/id/codes/eventType/Merge
<https://w3id.org/tabulae/id/codes/eventType/Merge> rdf:type owl:NamedIndividual ,
                                                             <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                             :EventType ;
                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent> ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement décrit la fusion de [2..n] parcelles. Dans les documents, cet évènement peut être dététecter de deux façons.\\n- Une parcelle est nouvelle associée à deux identifiant (par exemple \"D-100 D-102\").\\n Deux parcelles portant le même numéro, précédement issues de la division d'une parcelle de plus grande superficie, sont réassociées dans le compte foncier d'un même contribuable."@fr ,
                                                                                                     "This event describes the merging of [2..n] land plots. In the land registry documents, this event can be identified in two ways.\\n- A new plot is associated with two identifiers (for example, ‘D-100 D-102’).\\n Two plots bearing the same number, previously resulting from the division of a larger plot, are reassociated in the land register of the same taxpayer."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Fusion de parcelles"@fr ,
                                                                                                    "Merger of plots"@en .


###  https://w3id.org/tabulae/id/codes/eventType/Omission
<https://w3id.org/tabulae/id/codes/eventType/Omission> rdf:type owl:NamedIndividual ,
                                                                <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                :EventType ;
                                                       <http://www.w3.org/2004/02/skos/core#altLabel> "Oubli de déclaration"@fr ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à omission de déclaration d'un bien foncier par un contribuable qui n'a pas payé l'impôt pendant [n] années pour celui-ci. L'évènement désigne précisément le moment de la réintégration a posteriori du bien le compte foncier."@fr ,
                                                                                                        "This event relates to a taxpayer’s failure to declare a property on which they have not paid tax for [n] years. Specifically, it refers to the point at which the property is retrospectively re-included in the property tax assessment."@en ;
                                                       <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Failure to declare"@en ,
                                                                                                       "Omission de déclaration"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/OpenPropertyAccount
<https://w3id.org/tabulae/id/codes/eventType/OpenPropertyAccount> rdf:type owl:NamedIndividual ,
                                                                           <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                           :EventType ;
                                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "Création d'un compte foncier"@fr ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à l'ouverture du compte foncier d'un contribuable dans une commune donnée. Plus précisément, la date d'ouverture du compte foncier correspond à la date à laquelle une personne légale ou morale commence à payer l'impôt foncier pour [1..n] parcelles de la commune concernée."@fr ,
                                                                                                                   "This event is linked to the opening of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is opened corresponds to the date on which a legal or natural person begins to pay property tax for [1..n] plots of land in the municipality in question."@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Opening of a property tax account"@en ,
                                                                                                                  "Ouverture d'un compte foncier"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/Reduction
<https://w3id.org/tabulae/id/codes/eventType/Reduction> rdf:type owl:NamedIndividual ,
                                                                 <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                 :EventType ;
                                                        <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/BuildingRelatedEvent> ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la baisse (ex: destruction d'une partie du bâtiment)."@fr ,
                                                                                                         "This event is linked to a change to the building that results in a downward revaluation (e.g. demolition of part of the building)."@en ;
                                                        <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Demolition of a building"@en ,
                                                                                                        "Diminution d'un bâtiment"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/Sale
<https://w3id.org/tabulae/id/codes/eventType/Sale> rdf:type owl:NamedIndividual ,
                                                            <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                            :EventType ;
                                                   <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation> ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement consiste en une vente d'une parcelle d'un contribuable à un autre."@fr ,
                                                                                                    "This event involves the sale of a land plot from one taxpayer to another."@en ;
                                                   <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Sale"@en ,
                                                                                                   "Vente"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/Split
<https://w3id.org/tabulae/id/codes/eventType/Split> rdf:type owl:NamedIndividual ,
                                                             <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                             :EventType ;
                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/LandmarkEvent> ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement décrit la division d'une parcelle en [2..n] nouvelles parcelles. Dans les matrices des contribuables, cet évènement peut être détecté en observant les reports de folios. Si une parcelle décrite dans un compte foncier \"passe\" dans[2..n] nouveaux comptes fonciers, elle a été divisée entre plusieurs contribuables qui paieront l'impôt chacun pour une sous-partie de la parcelle intiale."@fr ,
                                                                                                     "This event describes the division of a plot into [2..n] new plots. In the mutation registres (Matrices des contribuables), this event can be detected by observing the carry-overs of folio numbers. If a plot described in a land register entry is ‘split’ across [2..n] new land register account, it has been divided amongst several taxpayers, each of whom will pay tax on a sub-portion of the original plot."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Division d'une parcelle"@fr ,
                                                                                                    "Split of a plot"@en .


###  https://w3id.org/tabulae/id/codes/eventType/SplitWithStay
<https://w3id.org/tabulae/id/codes/eventType/SplitWithStay> rdf:type owl:NamedIndividual ,
                                                                     <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                     :EventType ;
                                                            <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/Split> ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est une précision de l'évènement \"Division\". Ici, au moins l'une des nouvelles parcelles résultant de la division reste dans le compte foncier du contribuable associée à la parcelle divisée."@fr ,
                                                                                                             "This event is a specific instance of the ‘Division’ event. In this case, at least one of the new parcels resulting from the division remains in the taxpayer’s land register, linked to the divided parcel."@en ;
                                                            <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                            <http://www.w3.org/2004/02/skos/core#prefLabel> "Division d'une parcelle avec résidu dans le compte foncier d'origine"@fr ,
                                                                                                            "Division of a plot with a residual part in the original property account"@en .


###  https://w3id.org/tabulae/id/codes/eventType/Succession
<https://w3id.org/tabulae/id/codes/eventType/Succession> rdf:type owl:NamedIndividual ,
                                                                  <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                  :EventType ;
                                                         <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation> ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement consiste en une transmission d'une ou plusieurs parcelles d'un contribuable à [1..n] autre contribuable lors du réglement d'une sucession à une date donnée."@fr ,
                                                                                                          "This event involves the transfer of one or more plots of land from one taxpayer to [1..n] other taxpayers upon the settlement of an estate on a given date."@en ;
                                                         <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Inheritance"@en ,
                                                                                                         "Succession"@fr .


###  https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation
<https://w3id.org/tabulae/id/codes/eventType/TaxpayerMutation> rdf:type owl:NamedIndividual ,
                                                                        <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                        :EventType ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Cet évènement est associé à un changement de contribuable associé à une parcelle ou à un compte foncier."@fr ,
                                                                                                                "This event relates to a change in the taxpayer associated with a plot of land or a land account."@en ;
                                                               <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryEventList ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Modification of taxpayer"@en ,
                                                                                                               "Mutation de contribuable"@fr .


###  https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement
<https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement> rdf:type owl:NamedIndividual ,
                                                                         <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                         <https://w3id.org/PeGazUs#LandmarkType> ;
                                                                rdf:seeAlso "https://fr.wikipedia.org/wiki/Arrondissement_fran%C3%A7ais" ;
                                                                <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/Departement> ;
                                                                <http://www.w3.org/2004/02/skos/core#definition> "A geographical unit corresponding to the first level of subdivision within a department. Their administrative role has evolved since their creation, which means there are differences compared with the current definition of an arrondissement, although this does not alter the hierarchy of administrative geographical units."@en ,
                                                                                                                 "Entité géographique correspondant au premier niveau de sous-division des départements. Leur rôle administratif a évolué depuis leur création, ce qui implique des différences avec la définition actuelle de l'arrondissement sans que celà change la hiérarchie des entités géographiques administratives."@fr ;
                                                                <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Arrondissement départemental"@fr ,
                                                                                                                "French Arrondissement"@en .


###  https://w3id.org/tabulae/id/codes/landmarkType/Canton
<https://w3id.org/tabulae/id/codes/landmarkType/Canton> rdf:type owl:NamedIndividual ,
                                                                 <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                 <https://w3id.org/PeGazUs#LandmarkType> ;
                                                        rdf:seeAlso "https://fr.wikipedia.org/wiki/Canton_fran%C3%A7ais" ;
                                                        <http://www.w3.org/2004/02/skos/core#altLabel> "Canton officiel"@fr ,
                                                                                                       "Justice de paix"@fr ;
                                                        <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/Arrondissement> ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "A geographical unit corresponding to the second level of subdivision within departments as recorded in the land registry, situated between the district and the municipality. These are the official cantons, established in the late 18th century, primarily for the organisation of magistrates’ courts (until 1958) and elections. In the land registry records, the term ‘Justice of the Peace’ may also be used instead of ‘Canton’."@en ,
                                                                                                         "Entité géographique correspondant au deuxième niveau de sous-division des départements mentionné dans le cadastre, situé entre l'arrondissement et la commune. Il s'agit ici des cantons officiels, créés à la fin du 18ème siècle, notamment pour l'organisation des justices de paix (jusqu'à 1958) et des élections. Dans les registres cadastraux, le terme \"Justice de paix\" peut d'ailleurs être utilisé à la place de \"Canton\"."@fr ;
                                                        <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Canton"@fr ,
                                                                                                        "French Canton"@en .


###  https://w3id.org/tabulae/id/codes/landmarkType/Commune
<https://w3id.org/tabulae/id/codes/landmarkType/Commune> rdf:type owl:NamedIndividual ,
                                                                  <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                  <https://w3id.org/PeGazUs#LandmarkType> ;
                                                         <http://www.w3.org/2004/02/skos/core#altLabel> "Municipality"@en ;
                                                         <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/Canton> ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "A geographical unit corresponding to the finest administrative division across the whole territory. Each municipality had its own land registry comprising a complete set of documents (maps and registers)."@en ,
                                                                                                          "Entité géographique correspondant au maillage administratif le plus fin sur l'ensemble du territoire. Chaque commune possédait son cadastre comprenant un corpus complet de documents (plans et registres)."@fr ;
                                                         <http://www.w3.org/2004/02/skos/core#exactMatch> <http://data.ign.fr/def/geofla#Commune> ;
                                                         <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Commune"@fr ,
                                                                                                         "French Commune"@en .


###  https://w3id.org/tabulae/id/codes/landmarkType/Departement
<https://w3id.org/tabulae/id/codes/landmarkType/Departement> rdf:type owl:NamedIndividual ,
                                                                      <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                      <https://w3id.org/PeGazUs#LandmarkType> ;
                                                             <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit> ;
                                                             <http://www.w3.org/2004/02/skos/core#definition> "A geographical unit corresponding to the French departments since their creation in 1790. The departments were responsible for collecting direct taxes from the municipalities within their territory."@en ,
                                                                                                              "Entité géographique correspondant aux départements français depuis leur création en 1790. Les départements étaient responsable du prélèvement des contributions directes des communes se trouvant sur le territoire."@fr ;
                                                             <http://www.w3.org/2004/02/skos/core#exactMatch> <http://data.ign.fr/def/geofla#Departement> ;
                                                             <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "Département"@fr ,
                                                                                                             "French Departement"@en .


###  https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit
<https://w3id.org/tabulae/id/codes/landmarkType/FrenchAdministrativeUnit> rdf:type owl:NamedIndividual ,
                                                                                   <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                                   <https://w3id.org/PeGazUs#LandmarkType> ;
                                                                          <http://www.w3.org/2004/02/skos/core#definition> "A geographical entity corresponding to a French administrative unit."@en ,
                                                                                                                           "Entité géographique correspondant à une unité administrative française."@fr ;
                                                                          <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "French Administrative Unit"@en ,
                                                                                                                          "Unité administrative française"@fr .


###  https://w3id.org/tabulae/id/codes/landmarkType/Plot
<https://w3id.org/tabulae/id/codes/landmarkType/Plot> rdf:type owl:NamedIndividual ,
                                                               <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                               <https://w3id.org/PeGazUs#LandmarkType> ;
                                                      <http://www.w3.org/2004/02/skos/core#altLabel> "Land plot"@en ;
                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/Section> ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "Entité géographique la plus précise du cadastre, correspondant à une unité de terre cohérente (souvent de même nature) et associée à un contribuable."@fr ,
                                                                                                       "The most precise geographical unit in the land registry, corresponding to a coherent parcel of land (often of the same type) and linked to a taxpayer."@en ;
                                                      <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Parcelle"@fr ,
                                                                                                      "Plot"@en .


###  https://w3id.org/tabulae/id/codes/landmarkType/Section
<https://w3id.org/tabulae/id/codes/landmarkType/Section> rdf:type owl:NamedIndividual ,
                                                                  <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                  <https://w3id.org/PeGazUs#LandmarkType> ;
                                                         <http://www.w3.org/2004/02/skos/core#altLabel> "Cadastral section"@en ;
                                                         <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/landmarkType/Commune> ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "A geographical unit specific to the land registry, it is identified by a single letter in the old land registry and by one or more letters in the updated land registry. It corresponds to a division of the municipality into large groups of plots. Generally speaking, each sheet of the plot map represented a section."@en ,
                                                                                                          "Entité géographique spécifique au cadastre, elle est identifiée par une lettre dans l'ancien cadastre et par une ou plusieurs lettres dans le cadastre rénové. Elle correspond à un découpage de la commune en grands ensembles de parcelles. Dans le cas général, chaque feuille de plan parcellaire représentait une section."@fr ;
                                                         <http://www.w3.org/2004/02/skos/core#inScheme> :LandRegistryLandmarkList ;
                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Section"@en ,
                                                                                                         "Section"@fr .


