@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/tabulae#> .

<https://w3id.org/tabulae#> rdf:type owl:Ontology ;
                             <http://creativecommons.org/ns#license> <http://creativecommons.org/licenses/by/2.0/> ,
                                                                     <http://opendatacommons.org/licenses/by/> ,
                                                                     <http://www.data.gouv.fr/Licence-Ouverte-Open-Licence> ;
                             <http://purl.org/dc/terms/abstract> "L'ontologie TABULAE vise à décrire l'évolution des parcelles cadastrales à l'échelle de leurs attributs."@fr ,
                                                                 "The TABULAE ontology aims to describe the evolution of land plots at the attribute level."@en ;
                             <http://purl.org/dc/terms/contributor> _:genid1 ,
                                                                    _:genid3 ,
                                                                    _:genid5 ,
                                                                    _:genid7 ;
                             <http://purl.org/dc/terms/creator> _:genid9 ;
                             <http://purl.org/dc/terms/description> "Ontologie pour décrire les informations sur les parcelles, et les entités liées, présentes dans le cadastre ancien. Extension de l'ontologie PeGaZus."@fr ,
                                                                    "Ontology to describe the information about land plots and associated entities evocated in the old land registry documents. Extension of the PeGazUs ontology."@en ;
                             <http://purl.org/dc/terms/issued> "2024-01-24"^^xsd:date ;
                             <http://purl.org/dc/terms/license> <http://creativecommons.org/licenses/by/> ,
                                                                <http://creativecommons.org/licenses/by/2.0/> ,
                                                                <http://www.data.gouv.fr/Licence-Ouverte-1.0> ;
                             <http://purl.org/dc/terms/modified> "2025-07-12"^^xsd:date ,
                                                                 "2026-04-17"^^xsd:date ,
                                                                 "2026-06-14"^^xsd:date ;
                             <http://purl.org/dc/terms/publisher> _:genid16 ;
                             <http://purl.org/dc/terms/rights> "Copyright 2024-2026, IGN" ;
                             <http://purl.org/dc/terms/title> "Ontologie TABULAE"@fr ,
                                                              "TABULAE ontology"@en ;
                             <http://purl.org/vocab/vann/preferredNamespacePrefix> "tbl" ;
                             <http://purl.org/vocab/vann/preferredNamespaceUri> <https://w3id.org/tabulae#> ;
                             <http://purl.org/vocommons/voaf#extends> <https://w3id.org/PeGazUs#> ;
                             rdfs:label "Ontologie TABULAE"@fr ,
                                        "TABULAE Ontology"@en ;
                             rdfs:seeAlso <http://www.w3.org/ns/prov#> ,
                                          <https://w3id.org/PeGazUs#> ,
                                          <https://www.ica.org/standards/RiC/ontology#> ,
                                          <https://www.w3.org/TR/owl-time/> ;
                             owl:versionInfo "2.0.0" ;
                             <https://schema.org/codeRepository> <https://github.com/solenn-tl/tabulae-ontology> ;
                             <https://schema.org/funding> "Agence d'Innovation de Défense (AID) - Ministère des Armées" ,
                                                          "Institut National de l'Information Géographique et Forestière (IGN)" ;
                             <https://w3id.org/widoco/vocab#introduction> "L'ontologie TABULAE est une extension de l'ontologie PeGazUs dédiée à la représentation des informations relatives aux parcelles contenues dans les documents du cadastre ancien français (XIXe siècle). Elle permet de décrire les parcelles (Plot), leurs contribuables (Taxpayer), leur nature d'occupation du sol (Nature, avec plus de 150 valeurs contrôlées) et leur adresse, ainsi que les événements et changements qui affectent ces parcelles au fil du temps. Leur évolution est décrite à l'échelle des attributs. L'ontologie modélise également les sources documentaires mobilisées (matrices cadastrales, états de sections, plans parcellaires) et intègre des concepts et propriétés utiles à la traçabilité des processus de traitement (manuel ou automatique) réalisés pour extraire des informations des documents (classification des images, extraction d'information, reconnaissance des entités nommées). L'ontologie TABULAE s'appuie sur les ontologies PeGazUs, RiC-O, Time et PROV-O."@fr ,
                                                                          "The TABULAE ontology is an extension of the PeGazUs vocabulary dedicated to the representation of information about land plots contained in the French 19th-century land registry documents. It enables the description of land plots, their nature (with over 150 controlled values) and addresses, of the associated taxpayers, and the changes and events affecting these plots over time. Their evolution is described at the attribute level. The ontology also models the sources involved (mutation registers, section registers, cadastral index maps) and provides support to described the processing of the documents, by hand or automatically, including images classification, information extraction and named entity recognition in digitised documents. The TABULAE ontology re-uses concepts and properties of the PeGazUs, Time, RiC-O, and PROV-O ontologies."@en .

