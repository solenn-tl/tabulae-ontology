#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/PeGazUs#hasTrace
<https://w3id.org/PeGazUs#hasTrace> rdf:type owl:ObjectProperty ;
                                    rdfs:comment "Describes that an element has another element as its trace"@en ,
                                                 "Décrit qu'un élément a pour trace un autre élément"@fr ;
                                    rdfs:label "a pour trace"@fr ,
                                               "has trace"@en .


###  https://w3id.org/PeGazUs#isTraceOf
<https://w3id.org/PeGazUs#isTraceOf> rdf:type owl:ObjectProperty ;
                                     owl:inverseOf <https://w3id.org/PeGazUs#hasTrace> ;
                                     rdfs:comment "Describes that an element is the trace of another element"@en ,
                                                  "Décrit qu'un élément est la trace d'un autre élément"@fr ;
                                     rdfs:label "est une trace de"@fr ,
                                                "is trace of"@en .


###  https://w3id.org/tabulae#hasClass
:hasClass rdf:type owl:ObjectProperty ;
          rdfs:domain owl:Thing ;
          rdfs:range :AnnotationClass ;
          rdfs:comment "Classe attribuée à un élément suivant un processus d'annotation manuellement ou automatique."@fr ,
                       "Indicates that a document or a document area has at least one class assigned manually or automatically."@en ;
          rdfs:label "a pour classe"@fr ,
                     "has class"@en .


###  https://w3id.org/tabulae#hasClassValue
:hasClassValue rdf:type owl:ObjectProperty ;
               owl:inverseOf :isClassValueOf ;
               rdfs:domain :AnnotationClass ;
               rdfs:range :AnnotationClassType ;
               rdfs:comment "Valeur d'une classe assignée à un document ou à une zone de document."@fr ,
                            "Value of a class assigned to a document or a document area."@en ;
               rdfs:label "a pour valeur de classe"@fr ,
                          "has class value"@en .


###  https://w3id.org/tabulae#hasEquivalentFolio
:hasEquivalentFolio rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                                <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                              )
                                ] ;
                    rdfs:range [ rdf:type owl:Class ;
                                 owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                               <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                             )
                               ] ;
                    rdfs:comment "Cette propriété permet d'attribuer d'associer deux comptes fonciers d'un même contribuable dans une même commune dont l'un est la continuation de l'autre."@fr ,
                                 "This property allows to associate two land registry folios of the same taxpayer in the same municipality, one being the continuation of the other."@en ;
                    rdfs:label "a pour folio équivalent"@fr ,
                               "has equivalent folio"@en .


###  https://w3id.org/tabulae#hasNamedEntity
:hasNamedEntity rdf:type owl:ObjectProperty ;
                rdfs:domain owl:Thing ;
                rdfs:range :NamedEntity ;
                rdfs:comment "A text contains a named entity identified by a manual or automatic process."@en ,
                             "Un texte contient une entité nommée identifiée par un processus manuel ou automatique."@fr ;
                rdfs:label "includes named entity"@en ,
                           "possède l'entité nommée"@fr .


###  https://w3id.org/tabulae#hasNextVersionInSRCOrder
:hasNextVersionInSRCOrder rdf:type owl:ObjectProperty ;
                          owl:inverseOf :hasPreviousVersionInSRCOrder ;
                          rdfs:domain owl:Thing ;
                          rdfs:range owl:Thing ;
                          rdfs:comment "Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS. Elle n'est pas utilisée dans le graphe final."@fr ,
                                       "This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph."@en ;
                          rdfs:label "a pour version suivante dans les documents"@fr ,
                                     "has next version in the source order"@en .


###  https://w3id.org/tabulae#hasOverlappingVersionInSRCOrder
:hasOverlappingVersionInSRCOrder rdf:type owl:ObjectProperty ;
                                 owl:inverseOf :isOverlappedByVersionInSRCOrder ;
                                 rdfs:domain owl:Thing ;
                                 rdfs:range owl:Thing ;
                                 rdfs:comment "Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS. Elle n'est pas utilisée dans le graphe final."@fr ,
                                              "This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph."@en ;
                                 rdfs:label "a pour version qui se chevauche dans les documents"@fr ,
                                            "has overlapping version in the source order"@en .


###  https://w3id.org/tabulae#hasPlotAddress
:hasPlotAddress rdf:type owl:ObjectProperty ;
                owl:inverseOf :isPlotAddressOf ;
                rdfs:domain <https://w3id.org/PeGazUs#AttributeVersion> ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( <https://w3id.org/PeGazUs#Address>
                                           <https://w3id.org/PeGazUs#Landmark>
                                           <https://w3id.org/PeGazUs#LandmarkRelation>
                                         )
                           ] ;
                rdfs:comment "Links an attribute version to an address or a spatial relation with other geographical landmarks."@en ,
                             "Relie une version d'attribut à une adresse ou une relation spatiale avec d'autres repères géographiques."@fr ;
                rdfs:label "has plot address"@en ,
                           "parcelle a pour adresse"@fr ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "a pour adresse de parcelle"@fr ,
                                                               "has address of plot"@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "parcelle a pour adresse"@fr ,
                                                                "plot has address"@en .


###  https://w3id.org/tabulae#hasPlotNature
:hasPlotNature rdf:type owl:ObjectProperty ;
               owl:inverseOf :isPlotNatureOf ;
               rdfs:domain <https://w3id.org/PeGazUs#AttributeVersion> ;
               rdfs:range :Nature ;
               rdfs:comment "Links an attribute version to a plot nature (corresponding to a land use or occupation)."@en ,
                            "Relie une version d'attribut à une nature de parcelle (correspondant à une occupation ou à un usage du sol)."@fr ;
               rdfs:label "a pour nature de parcelle"@fr ,
                          "has plot nature"@en .


###  https://w3id.org/tabulae#hasPreviousVersionInSRCOrder
:hasPreviousVersionInSRCOrder rdf:type owl:ObjectProperty ;
                              rdfs:domain owl:Thing ;
                              rdfs:range owl:Thing ;
                              rdfs:comment "Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS. Elle n'est pas utilisée dans le graphe final."@fr ,
                                           "This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph."@en ;
                              rdfs:label "a pour version précédente dans les documents"@fr ,
                                         "has previous version in the source order"@en .


###  https://w3id.org/tabulae#hasTaxpayer
:hasTaxpayer rdf:type owl:ObjectProperty ;
             rdfs:domain <https://w3id.org/PeGazUs#AttributeVersion> ;
             rdfs:range :Taxpayer ;
             rdfs:comment "Links an attribute version of a plot to a taxpayer liable for the property tax for that plot."@en ,
                          "Relie une version d'attribut d'une parcelle à un contribuable redevable de l'impôt foncier pour celle-ci."@fr ;
             rdfs:label "a pour contribuable"@fr ,
                        "has taxpayer"@en .


###  https://w3id.org/tabulae#isAddressEntityOfTaxpayer
:isAddressEntityOfTaxpayer rdf:type owl:ObjectProperty ;
                           rdfs:domain owl:Thing ;
                           rdfs:range :Taxpayer ;
                           rdfs:comment "Links an address or a spatial relation with other geographical landmarks to a taxpayer. For the addresses provided as strings, see tbl:taxpayerAddress."@en ,
                                        "Relie une adresse ou une relation spatiale avec d'autres repères géographiques à un contribuable. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress."@fr ;
                           rdfs:label "adresse (entité) du contribuable"@fr ,
                                      "is address (entity) of a taxpayer"@en .


###  https://w3id.org/tabulae#isClassOf
:isClassOf rdf:type owl:ObjectProperty ;
           owl:inverseOf :hasClass ;
           rdfs:domain :AnnotationClass ;
           rdfs:range owl:Thing ;
           rdfs:label "classe attribuée à"@fr ,
                      "is class of"@en .


###  https://w3id.org/tabulae#isClassValueOf
:isClassValueOf rdf:type owl:ObjectProperty ;
                rdfs:domain :AnnotationClassType ;
                rdfs:range :AnnotationClass ;
                rdfs:label "est la valeur de classe attribuée à"@fr ,
                           "is class value of"@en .


###  https://w3id.org/tabulae#isEventType
:isEventType rdf:type owl:ObjectProperty ;
             rdfs:domain <https://w3id.org/PeGazUs#Event> ;
             rdfs:range :EventType ;
             rdfs:label "est un événement de type"@fr ,
                        "is event type"@en .


###  https://w3id.org/tabulae#isMentionnedIn
:isMentionnedIn rdf:type owl:ObjectProperty ;
                rdfs:domain owl:Thing ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                           <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                         )
                           ] ;
                rdfs:comment "Un objet est mentionné dans une source."@fr ;
                rdfs:label "est mentionné dans"@fr ,
                           "is mentionned in"@en .


###  https://w3id.org/tabulae#isNamedEntityType
:isNamedEntityType rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasClassValue ;
                   rdfs:domain :NamedEntity ;
                   rdfs:range :AnnotationClass ;
                   rdfs:label "est une entité nommée de type"@fr ,
                              "is named entity type"@en .


###  https://w3id.org/tabulae#isOverlappedByVersionInSRCOrder
:isOverlappedByVersionInSRCOrder rdf:type owl:ObjectProperty ;
                                 rdfs:domain owl:Thing ;
                                 rdfs:range owl:Thing ;
                                 rdfs:comment "Cette propriété est utilisée dans l'algorithme de peuplement de l'ontologie PeGaZuS. Elle n'est pas utilisée dans le graphe final."@fr ,
                                              "This property is used in the population algorithm of the PeGaZuS ontology. It is not used in the final graph."@en ;
                                 rdfs:label "est chevauchée par la version dans les documents"@fr ,
                                            "is overlapped by version in the source order"@en .


###  https://w3id.org/tabulae#isPlotAddressOf
:isPlotAddressOf rdf:type owl:ObjectProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( <https://w3id.org/PeGazUs#Address>
                                             <https://w3id.org/PeGazUs#Landmark>
                                             <https://w3id.org/PeGazUs#LandmarkRelation>
                                           )
                             ] ;
                 rdfs:range <https://w3id.org/PeGazUs#AttributeVersion> ;
                 rdfs:comment "Links an address or a spatial relation with other geographical landmarks to an attribute version."@en ,
                              "Relie une adresse ou une relation spatiale avec d'autres repères géographiques à une version d'attribut."@fr ;
                 rdfs:label "est l'adresse associée à"@fr ,
                            "is plot address of"@en .


###  https://w3id.org/tabulae#isPlotNatureOf
:isPlotNatureOf rdf:type owl:ObjectProperty ;
                rdfs:domain :Nature ;
                rdfs:range <https://w3id.org/PeGazUs#AttributeVersion> ;
                rdfs:comment "Links a plot nature (corresponding to a land use or occupation) to an attribute version."@en ,
                             "Relie une nature de parcelle (correspondant à une occupation ou à un usage du sol) à une version d'attribut."@fr ;
                rdfs:label "est une nature de la parcelle"@fr ,
                           "is nature of plot"@en .


###  https://w3id.org/tabulae#isSourceType
:isSourceType rdf:type owl:ObjectProperty ;
              rdfs:domain owl:Thing ;
              rdfs:range :SourceType ;
              rdfs:comment "Cette propriété permet d'associer une source à un type de source."@fr ,
                           "This property allows to associate a source to à source type."@en ;
              rdfs:label "est une source de type"@fr ,
                         "is source type"@en .


###  https://w3id.org/tabulae#isTaxpayerOf
:isTaxpayerOf rdf:type owl:ObjectProperty ;
              owl:inverseOf :hasTaxpayer ;
              rdfs:domain :Taxpayer ;
              rdfs:range <https://w3id.org/PeGazUs#AttributeVersion> ;
              rdfs:comment "Links a taxpayer to an attribute version of a plot."@en ,
                           "Relie un contribuable à une version d'attribut d'une parcelle."@fr ;
              rdfs:label "est le contribuable associé à"@fr ,
                         "is associated taxpayer of"@en ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "est le contribuable associé à la version d'attribut"@fr ,
                                                             "is taxpayer of attribute version"@en .


###  https://w3id.org/tabulae#mentions
:mentions rdf:type owl:ObjectProperty ;
          owl:inverseOf :isMentionnedIn ;
          rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                      <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                    )
                      ] ;
          rdfs:range owl:Thing ;
          rdfs:comment "Une source mentionne un objet."@fr ;
          rdfs:label "mentionne"@fr ,
                     "mentions"@en .


###  https://w3id.org/tabulae#passedTo
:passedTo rdf:type owl:ObjectProperty ;
          rdfs:domain <https://w3id.org/PeGazUs#AttributeVersion> ;
          rdfs:range [ rdf:type owl:Class ;
                       owl:unionOf ( :SpecialCellValue
                                     <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                     <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                   )
                     ] ;
          rdfs:comment "Folio où est décrit l'état de parcelle suivant OU autre information sur l'état suivant d'une parcelle."@fr ,
                       "Folio where the following plot state is described OR other information about the previous or following state of a plot."@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "passed to"@en ,
                                                         "passé à"@fr ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "next state or folio"@en ,
                                                          "état ou folio suivant"@fr .


###  https://w3id.org/tabulae#sourcedFrom
:sourcedFrom rdf:type owl:ObjectProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range owl:Thing ;
             <http://purl.org/dc/terms/isReplacedBy> <https://w3id.org/PeGazUs#hasTrace> ;
             rdfs:comment "Une affirmation est sourcée à partir d'une source ."@fr ;
             rdfs:label "a pour source"@fr ,
                        "sourced from"@en ;
             owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/tabulae#takenFrom
:takenFrom rdf:type owl:ObjectProperty ;
           rdfs:domain <https://w3id.org/PeGazUs#AttributeVersion> ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( :SpecialCellValue
                                      <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                      <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                    )
                      ] ;
           rdfs:comment "Folio où est décrit l'état de parcelle précédent OU information sur l'état précédent d'une parcelle."@fr ,
                        "Folio where the previous plot state is described OR other information about the previous state of a plot."@en ;
           rdfs:label "previous state or folio"@en ,
                      "état ou folio précédent"@fr ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "taken from"@en ,
                                                          "tiré de"@fr ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "previous state or folio"@en ,
                                                           "état ou folio précédent"@fr .


###  https://w3id.org/tabulae#taxpayerHasAddressEntity
:taxpayerHasAddressEntity rdf:type owl:ObjectProperty ;
                          owl:inverseOf :isAddressEntityOfTaxpayer ;
                          rdfs:domain :Taxpayer ;
                          rdfs:range owl:Thing ;
                          rdfs:comment "Links a taxpayer to an address or a spatial relation with other geographical landmarks. For the addresses provided as strings, see tbl:taxpayerAddress."@en ,
                                       "Relie un contribuable à une adresse ou une relation spatiale avec d'autres repères géographiques. Pour les adresses renseignées sous la forme de chaînes de caractères, voir tbl:taxpayerAddress."@fr ;
                          rdfs:label "contribuable a pour adresse (entité)"@fr ,
                                     "taxpayer has address (entity)"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/tabulae#IIIFImageUrl
:IIIFImageUrl rdf:type owl:DatatypeProperty ;
              rdfs:domain <https://www.ica.org/standards/RiC/ontology#Instantiation> ;
              rdfs:range xsd:anyURI ;
              rdfs:comment "URL d'une image fournie par l'API IIIF (International Image Interoperability Framework) représentant un document ou une partie de document."@fr ,
                           "URL of an image provided by the IIIF (International Image Interoperability Framework) image representing a document or part of a document."@en ;
              rdfs:label "IIIF image URL"@en ,
                         "URL d'image IIIF"@fr .


###  https://w3id.org/tabulae#TFNBGroup
:TFNBGroup rdf:type owl:DatatypeProperty ;
           rdfs:domain owl:Thing ;
           rdfs:range xsd:string ;
           rdfs:comment "Group of TFNB (Taxe Foncière sur les Propriétés Non Bâties) of a plot, as indicated in cadastral documents."@en ,
                        "Groupe de TFNB (Taxe Foncière sur les Propriétés Non Bâties) d'une parcelle, tel qu'indiqué dans les documents cadastraux."@fr ;
           rdfs:label "TFNB group"@en ,
                      "groupe TFNB"@fr ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "TFNB group"@en ,
                                                           "groupe TFNB"@fr .


###  https://w3id.org/tabulae#URL
:URL rdf:type owl:DatatypeProperty ;
     rdfs:domain owl:Thing ;
     rdfs:range rdfs:Literal ;
     rdfs:comment "Correspond à l'URL de la source (image, base de donnée)" ;
     rdfs:label "source URL"@en ,
                "url de la source"@fr ;
     <http://www.w3.org/2004/02/skos/core#prefLabel> "source URL"@en ,
                                                     "url de la source"@fr .


###  https://w3id.org/tabulae#coordinatesInImageSystem
:coordinatesInImageSystem rdf:type owl:DatatypeProperty ;
                          rdfs:domain <https://www.ica.org/standards/RiC/ontology#Instantiation> ;
                          rdfs:range rdfs:Literal ;
                          rdfs:comment "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé." ;
                          rdfs:label "coordinates in image"@en ,
                                     "coordonnées dans l'image"@fr ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "coordinates in image"@en ,
                                                                          "coordonnées dans l'image"@fr .


###  https://w3id.org/tabulae#hasAlternativeNumFolio
:hasAlternativeNumFolio rdf:type owl:DatatypeProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                                    <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                                  )
                                    ] ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Alternative folio number (e.g. former number)"@en ,
                                     "Numéro de folio alternatif (ex: ancien numéro)"@fr ;
                        rdfs:label "a pour numéro de folio alternatif"@fr ,
                                   "has alternative folio number"@en .


###  https://w3id.org/tabulae#hasNumFolio
:hasNumFolio rdf:type owl:DatatypeProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                         <https://www.ica.org/standards/RiC/ontology#RecordResource>
                                       )
                         ] ;
             rdfs:range xsd:string ;
             rdfs:comment "Numéro de folio (associé à une page entière ou à une partie de page) "@fr ,
                          "folio number (associated to a mutation register page or part of page)"@en ;
             rdfs:label "a pour numéro de folio"@fr ,
                        "has folio number"@en .


###  https://w3id.org/tabulae#imageURL
:imageURL rdf:type owl:DatatypeProperty ;
          rdfs:domain <https://www.ica.org/standards/RiC/ontology#Instantiation> ;
          rdfs:range xsd:anyURI ;
          rdfs:comment "URL d'une image représentant un document ou une partie de document."@fr ,
                       "URL of an image representing a document or part of a document."@en ;
          rdfs:label "URL d'image"@fr ,
                     "image URL"@en .


###  https://w3id.org/tabulae#indexOfFirstCharacter
:indexOfFirstCharacter rdf:type owl:DatatypeProperty ;
                       rdfs:domain owl:Thing ;
                       rdfs:range xsd:nonNegativeInteger ;
                       rdfs:comment "Cette propriété permet d'indiquer l'index du premier caractère d'une sous-chaine de caractères dans un texte. Index à partir de 0."@fr ,
                                    "This property allows to indicate the index of the first character of a substring. Index starts from 0."@en ;
                       rdfs:label "index du premier caractère"@fr ,
                                  "index of first character"@en .


###  https://w3id.org/tabulae#indexOfLastCharacter
:indexOfLastCharacter rdf:type owl:DatatypeProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range xsd:nonNegativeInteger ;
                      rdfs:comment "Cette propriété permet d'indiquer l'index du dernier caractère d'une sous-chaine de caractères dans un texte. Index à partir de 0."@fr ,
                                   "This property allows to indicate the index of the last character of a substring. Index starts from 0."@en ;
                      rdfs:label "index du dernier caractère"@fr ,
                                 "index of last character"@en .


###  https://w3id.org/tabulae#lineOrderInArea
:lineOrderInArea rdf:type owl:DatatypeProperty ;
                 rdfs:domain <https://www.ica.org/standards/RiC/ontology#Instantiation> ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Ordre de la ligne dans la zone annotée (manuellement ou automatiquement) dans un document numérisé." ;
                 rdfs:label "ordre de ligne dans la zone"@fr ,
                            "row order in area"@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "ordre de ligne dans la zone"@fr ,
                                                                 "row order in area"@en .


###  https://w3id.org/tabulae#spanValue
:spanValue rdf:type owl:DatatypeProperty ;
           rdfs:domain owl:Thing ;
           rdfs:range xsd:string ;
           rdfs:comment "Cette propriété permet d'indiquer la valeur d'une sous-chaine de caractères."@fr ,
                        "This property allows to indicate the value of a substring."@en ;
           rdfs:label "span value"@en ,
                      "valeur de la sous-chaîne"@fr .


###  https://w3id.org/tabulae#taxpayerActivity
:taxpayerActivity rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Taxpayer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Activity of a taxpayer, generally related to their professional activity"@en ,
                               "Activité d'un contribuable, généralement relatif à l'activité professionnelle"@fr ;
                  rdfs:label "activité du contribuable"@fr ,
                             "taxpayer activity"@en .


###  https://w3id.org/tabulae#taxpayerAddress
:taxpayerAddress rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Taxpayer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Address of a taxpayer provided as a string. For addresses as entities, see tbl:taxpayerHasAddressEntity."@en ,
                              "Adresse d'un contribuable renseignée sous la forme d'une chaîne de caractères. Pour les adresses sous forme d'entités, voir tbl:taxpayerHasAddressEntity."@fr ;
                 rdfs:label "adresse du contribuable"@fr ,
                            "taxpayer address"@en .


###  https://w3id.org/tabulae#taxpayerBirthName
:taxpayerBirthName rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Taxpayer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Birth name of a taxpayer."@en ,
                                "Nom de naissance d'une contribuable. Par exemple, le nom de naissance d'une personne avant son mariage (sans le cas où elle utilise ensuite le nom de son époux/épouse)."@fr ;
                   rdfs:label "birth name"@en ,
                              "nom de naissance"@fr .


###  https://w3id.org/tabulae#taxpayerFamilyStatus
:taxpayerFamilyStatus rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Taxpayer ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Status of a taxpayer related to their family status or relationships (Widow, Widower, Son, Daughter, Minor, Heirs)"@en ,
                                   "Statut d'un contribuable lié à son statut ou à ses relations familiales (Veuve, Veuf, Fils, Fille, Mineur, Héritiers)"@fr ;
                      rdfs:label "family status"@en ,
                                 "statut familial"@fr .


###  https://w3id.org/tabulae#taxpayerFirstName
:taxpayerFirstName rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Taxpayer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Prénom (unitiare) d'un contribuable. En pratique peu utilisée car implique de connaître de façon certaine l'état civil d'un contribuable."@fr ,
                                "Unique first name of a taxpayer. Generally not used in practice as it requires certain knowledge of the taxpayer's civil status."@en ;
                   rdfs:label "prénom unique"@fr ,
                              "unique first name"@en .


###  https://w3id.org/tabulae#taxpayerFirstNames
:taxpayerFirstNames rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Taxpayer ;
                    rdfs:range xsd:string ;
                    rdfs:comment "First name(s) of a taxpayer, generally presented as a list of first names in documents. In the case of taxpayers with the family status 'Mrs' or 'Widow', the indicated first name is generally that of the spouse."@en ,
                                 "Prénom(s) d'un contribuable, généralement présentés sous la forme d'une liste de prénoms dans les documents. Dans le cas des contribuables ayant le statut familial 'Mme' ou 'Veuve', le prénom indiqué est généralement celui de l'époux."@fr ;
                    rdfs:label "first name(s)"@en ,
                               "prénom(s)"@fr ;
                    :isPreferredOver :taxpayerFirstName .


###  https://w3id.org/tabulae#taxpayerFullName
:taxpayerFullName rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :taxpayerLabel ;
                  rdfs:domain :Taxpayer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Full identity of an individual taxpayer: last name and first names."@en ,
                               "Identité complète d'un contribuable (personne physique) composée a minima d'un nom de famille et optionnellement d'un ou plusieurs prénoms et d'un statut familial."@fr ;
                  rdfs:label "full name"@en ,
                             "nom complet"@fr .


###  https://w3id.org/tabulae#taxpayerLabel
:taxpayerLabel rdf:type owl:DatatypeProperty ;
               rdfs:domain :Taxpayer ;
               rdfs:range xsd:string ;
               rdfs:comment "Label d'un contribuable, qui peut être son nom complet (pour une personne physique) ou sa raison sociale (pour une personne morale)."@fr ,
                            "Label of a taxpayer, which can be their full name (for an individual) or their company name (for a legal entity)."@en ;
               rdfs:label "label de contribuable"@fr ,
                          "taxpayer label"@en .


###  https://w3id.org/tabulae#taxpayerLastName
:taxpayerLastName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Taxpayer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Last name of a taxpayer"@en ,
                               "Nom de famille d'un contribuable"@fr ;
                  rdfs:label "last name"@en ,
                             "nom de famille"@fr .


###  https://w3id.org/tabulae#taxpayerOrganisationName
:taxpayerOrganisationName rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf :taxpayerLabel ;
                          rdfs:domain :Taxpayer ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Company name of a legal entity taxpayer"@en ,
                                       "Raison sociale d'un contribuable personne morale"@fr ;
                          rdfs:label "organisation name"@en ,
                                     "raison sociale"@fr .


###  https://w3id.org/tabulae#taxpayerSpouseOrChildrenFirstNames
:taxpayerSpouseOrChildrenFirstNames rdf:type owl:DatatypeProperty ;
                                    rdfs:domain :Taxpayer ;
                                    rdfs:range xsd:string ;
                                    rdfs:comment "First name(s) of the spouse or a child in a land registry folio label, generally indicated in the second part of the label."@en ,
                                                 "Prénom(s) de l'époux/épouse ou d'un enfant dans un libellé de compte foncier. Généralement indiqués en seconde partie de libellé en complémenant de l'identité d'un contribuable 'racine' (le titulaire initial du compte foncier)."@fr ;
                                    rdfs:label "prénom(s) de l'époux/épouse ou d'un enfant"@fr ,
                                               "spouse or children first name(s)"@en .


###  https://w3id.org/tabulae#taxpayerStatus
:taxpayerStatus rdf:type owl:DatatypeProperty ;
                rdfs:domain :Taxpayer ;
                rdfs:range xsd:string ;
                rdfs:comment "Status of a taxpayer which is not related to their family status."@en ,
                             "Statut d'un contibuable qui n'est pas lié à son statut familial. Exemple : 'Non imposable'"@fr ;
                rdfs:label "status"@en ,
                           "statut"@fr .


###  https://w3id.org/tabulae#taxpayerTitle
:taxpayerTitle rdf:type owl:DatatypeProperty ;
               rdfs:domain :Taxpayer ;
               rdfs:range xsd:string ;
               rdfs:comment "Civility (Mr, Mrs, etc.), noble title (e.g., Prince of, Marquis of) or honorific"@en ,
                            "Civilité (M, Mme, etc.), titre de noblesse (Prince de, Marquis de, etc.) ou titre honorifique"@fr ;
               rdfs:label "title"@en ,
                          "titre"@fr .


###  https://w3id.org/tabulae#transcription
:transcription rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :NamedEntity
                                           <https://www.ica.org/standards/RiC/ontology#Instantiation>
                                         )
                           ] ;
               rdfs:range rdfs:Literal ;
               rdfs:comment "Transcription d'une zone ou d'une entité obtenue automatiquement ou manuellement à partir d'un document (numérisé)."@fr ,
                            "Transcription of an area or an entity obtained automatically or manually from a (scanned) document."@en ;
               rdfs:label "transcription"@en ,
                          "transcription"@fr ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "transcription"@en ,
                                                               "transcription"@fr .


###  https://w3id.org/tabulae#xywhCoordinates
:xywhCoordinates rdf:type owl:DatatypeProperty ;
                 rdfs:domain <https://www.ica.org/standards/RiC/ontology#Instantiation> ;
                 rdfs:range rdfs:Literal ;
                 rdfs:comment "Coordinates (image reference system) of an annotated area (manually or automatically) in a scanned document, in the form of a rectangle defined by the x and y coordinates of the upper left corner and the width and height of the rectangle (as required in the IIIF specifications). For example: 1160,1103,1529,1421"@en ,
                              "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé, sous la forme d'un rectangle défini par les coordonnées x et y du coin supérieur gauche et la largeur et la hauteur du rectangle (tel que requis dans les spécifications IIIF). Par exemple : 1160,1103,1529,1421"@fr ;
                 rdfs:label "coordonnées xywh dans l'image"@fr ,
                            "xywh coordinates in image"@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "coordonnées xywh dans l'image"@fr ,
                                                                 "xywh coordinates in image"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/vocommons/voaf#Vocabulary
<http://purl.org/vocommons/voaf#Vocabulary> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  http://www.w3.org/2006/time#Instant
<http://www.w3.org/2006/time#Instant> rdf:type owl:Class .


###  http://www.w3.org/2006/time#Interval
<http://www.w3.org/2006/time#Interval> rdf:type owl:Class .


###  http://www.w3.org/ns/org#Membership
<http://www.w3.org/ns/org#Membership> rdf:type owl:Class .


###  http://www.w3.org/ns/org#Role
<http://www.w3.org/ns/org#Role> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class ;
                                     owl:disjointWith <http://www.w3.org/ns/prov#Entity> ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                     rdfs:label "Activity" .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class ;
                                  rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                  rdfs:label "Agent" .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#SoftwareAgent
<http://www.w3.org/ns/prov#SoftwareAgent> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
                                          rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                                          rdfs:label "SoftwareAgent" .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class .


###  https://w3id.org/PeGazUs#Address
<https://w3id.org/PeGazUs#Address> rdf:type owl:Class ;
                                   rdfs:comment "An address defines an indirect spatial reference to a location that is the target of the address. This location is described as a sequence of address segments, each of which describes the relationships between entities."@en ,
                                                "Une adresse définit une référence spatiale indirecte d'un lieu qui est la cible de l'adresse. La manière dont ce lieu est décrit se fait comme étant une séquence de segments d'adresse étant chacun une description de relations entre entités."@fr ;
                                   rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                   rdfs:label "Address"@en ,
                                              "Adresse"@fr .


###  https://w3id.org/PeGazUs#Attribute
<https://w3id.org/PeGazUs#Attribute> rdf:type owl:Class ;
                                     rdfs:comment "An attribute is a property of a geographic entity."@en ,
                                                  "Un attribut est une propriété d'une entité géographique."@fr ;
                                     rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                     rdfs:label "Attribut"@fr ,
                                                "Attribute"@en .


###  https://w3id.org/PeGazUs#AttributeType
<https://w3id.org/PeGazUs#AttributeType> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                                         rdfs:comment "An attribute type is a category of attributes defined by common characteristics."@en ,
                                                      "Un type d'attribut est une catégorie d'attributs définie par des caractéristiques communes."@fr ;
                                         rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                         rdfs:label "Attribute type"@en ,
                                                    "Type d'attribut"@fr .


###  https://w3id.org/PeGazUs#AttributeVersion
<https://w3id.org/PeGazUs#AttributeVersion> rdf:type owl:Class ;
                                            rdfs:comment "An attribute version is a version of an attribute which has a specific value."@en ,
                                                         "Une version d'attribut est une version reliée à un attribut qui possède est définie par une valeur."@fr ;
                                            rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                            rdfs:label "Attribute version"@en ,
                                                       "Version de l'attribut"@fr .


###  https://w3id.org/PeGazUs#Change
<https://w3id.org/PeGazUs#Change> rdf:type owl:Class ;
                                  rdfs:comment "A change is any modification made to a geographic feature or its attributes, or to a relationship between features."@en ,
                                               "Un changement est toute modification appliquée à une entité géographique ou à ses attributs ou bien à une relation entre entités."@fr ;
                                  rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                  rdfs:label "Change"@en ,
                                             "Changement"@fr .


###  https://w3id.org/PeGazUs#ChangeType
<https://w3id.org/PeGazUs#ChangeType> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                                      rdfs:comment "A change type is a category of changes defined by common characteristics."@en ,
                                                   "Un type de changement est une catégorie de changements définie par des caractéristiques communes."@fr ;
                                      rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                      rdfs:label "Change Type"@en ,
                                                 "Type de changement"@fr .


###  https://w3id.org/PeGazUs#Event
<https://w3id.org/PeGazUs#Event> rdf:type owl:Class ;
                                 rdfs:comment "Event describing a development involving one or more resources at a given time."@en ,
                                              "Un événément décrit une évolution impliquant une ou plusieurs ressources à un instant donné."@fr ;
                                 rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                 rdfs:label "Event"@en ,
                                            "Événément"@fr .


###  https://w3id.org/PeGazUs#Landmark
<https://w3id.org/PeGazUs#Landmark> rdf:type owl:Class .


###  https://w3id.org/PeGazUs#LandmarkRelation
<https://w3id.org/PeGazUs#LandmarkRelation> rdf:type owl:Class ;
                                            rdfs:comment """Il s'agit d'une relation qui représente un lien existant entre un ou plusieurs repères.
    Ces relations peuvent prendre diverses formes, notamment :
    - des relations géographiques, par exemple lorsqu'un point de repère est situé à l'angle de deux autres points de repère ;
    - des relations hiérarchiques, par exemple lorsqu'un point de repère est la capitale d'une autre entité administrative ;
    - d'autres relations spécifiques."""@fr ,
                                                         """It is a relation that represents a relation existing between one or more landmarks.
    Such relations may take various forms, including:
    - geographic relations, for example when a landmark is located at the corner of two other landmarks;
    - hierarchical relations, for example when a landmark is the capital of another administrative entity;
    - as well as other domain-specific or contextual relations depending on the application needs.
    """@en ;
                                            rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                            rdfs:label "Landmark relation"@en ,
                                                       "Relation entre repères"@fr .


###  https://w3id.org/PeGazUs#LandmarkType
<https://w3id.org/PeGazUs#LandmarkType> rdf:type owl:Class ;
                                        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                                        rdfs:comment "A type of landmark is a category that allows classifying the different types of landmarks."@en ,
                                                     "Un type de repère est une catégorie qui permet de classer les différents types de repères."@fr ;
                                        rdfs:isDefinedBy <https://w3id.org/PeGazUs#> ;
                                        rdfs:label "Type de repère"@fr ,
                                                   "Type of landmark"@en .


###  https://w3id.org/tabulae#AnnotationClass
:AnnotationClass rdf:type owl:Class ;
                 owl:disjointWith :AnnotationClassType ,
                                  :EventType ,
                                  :NamedEntity ,
                                  :Nature ,
                                  :PropertyAccountChange ,
                                  :SourceType ,
                                  :SpecialCellValue ,
                                  :Taxpayer ;
                 rdfs:comment "Class (in the sense of annotation) used to characterize a document or text, resulting from an automatic or manual annotation process."@en ,
                              "Classe (au sens de l'annotation) utilisée pour caractériser pour un document ou un texte, résultant d'un processus d'annotation automatique ou manuel."@fr ;
                 rdfs:label "Class provided by an annotation process"@en ,
                            "Classe issue d'un processus d'annotation"@fr ;
                 <http://www.w3.org/2004/02/skos/core#altLabel> "Annotation class"@en ,
                                                                "Classe d'annotation"@fr ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Class provided by an annotation process"@en ,
                                                                 "Classe issue d'un processus d'annotation"@fr .


###  https://w3id.org/tabulae#AnnotationClassType
:AnnotationClassType rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                     owl:disjointWith :EventType ,
                                      :NamedEntity ,
                                      :Nature ,
                                      :PropertyAccountChange ,
                                      :SourceType ,
                                      :SpecialCellValue ,
                                      :Taxpayer ;
                     rdfs:comment "Class type provided by an annotation process to an image (document) or to a text or excerpt of text, manually or automatically."@en ,
                                  "Type de classe attribuée manuellement ou automatiquement à une image (document) ou à un texte ou extrait de texte."@fr ;
                     rdfs:label "Class type provided by an annotation process"@en ,
                                "Type de classe d'annotation"@fr ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "Class type provided by an annotation process"@en ,
                                                                     "Type de classe attribuée par un processus d'annotation"@fr .


###  https://w3id.org/tabulae#EventType
:EventType rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
           owl:disjointWith :NamedEntity ,
                            :Nature ,
                            :PropertyAccountChange ,
                            :SourceType ,
                            :SpecialCellValue ,
                            :Taxpayer ;
           rdfs:comment "A specific type of event."@en ,
                        "Un type d'évènement caractérise un évènement de nature spécifique."@fr ;
           rdfs:label "Type d'évènement"@fr ,
                      "Type of event"@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Type d'évènement"@fr ,
                                                           "Type of event"@en .


###  https://w3id.org/tabulae#NamedEntity
:NamedEntity rdf:type owl:Class ;
             owl:disjointWith :Nature ,
                              :PropertyAccountChange ,
                              :SourceType ,
                              :SpecialCellValue ,
                              :Taxpayer ;
             rdfs:comment "Entité nommée mentionnée dans une source transcrite (textuelle), identifiée par un processus manuel ou automatique. Une entité nommée peut contenir d'autres entités nommées imbriquées."@fr ,
                          "Named entity mentioned in a transcribed source (text), identified by a manual or automatic process. A named entity may contain other named entities."@en ;
             rdfs:label "Entité nommée"@fr ,
                        "Named entity"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Entité nommée"@fr ,
                                                             "Named entity"@en .


###  https://w3id.org/tabulae#Nature
:Nature rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
        owl:disjointWith :PropertyAccountChange ,
                         :SourceType ,
                         :SpecialCellValue ,
                         :Taxpayer ;
        rdfs:comment "A plot nature corresponds to a land use or occupation."@en ,
                     "La nature de parcelle correspond à une occupation ou un usage du sol."@fr ;
        rdfs:label "Nature de parcelle"@fr ,
                   "Plot nature"@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "Nature de parcelle"@fr ,
                                                        "Plot nature"@en .


###  https://w3id.org/tabulae#PropertyAccountChange
:PropertyAccountChange rdf:type owl:Class ;
                       rdfs:subClassOf <https://w3id.org/PeGazUs#Change> ;
                       owl:disjointWith :SourceType ,
                                        :SpecialCellValue ,
                                        :Taxpayer ;
                       rdfs:comment "A change affecting the property account of a taxpayer."@en ,
                                    "Un changement sur le compte foncier caractérise un changement affectant le compte foncier d'un contribuable."@fr ;
                       rdfs:label "Changement sur le compte foncier"@fr ,
                                  "Property account change"@en ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Changement sur le compte foncier"@fr ,
                                                                       "Property account change"@en .


###  https://w3id.org/tabulae#SourceType
:SourceType rdf:type owl:Class ;
            rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
            owl:disjointWith :SpecialCellValue ,
                             :Taxpayer ;
            rdfs:comment "Type d'une source dont est issue une information."@fr ,
                         "Type of a source from which information originates."@en ;
            rdfs:label "Type de source"@fr ,
                       "Type of source"@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Type de source"@fr ,
                                                            "Type of source"@en .


###  https://w3id.org/tabulae#SpecialCellValue
:SpecialCellValue rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                  owl:disjointWith :Taxpayer ;
                  rdfs:comment "Special value related to the operation of cadastral documents, for example the mentions of construction, destruction, modifications of buildings indicated in the columns intended for folio numbers."@en ,
                               "Valeur spéciale liée au fonctionnement des documents cadastraux, par exemple les mentions de construction, destruction, augmentation de bâtiments indiquées dans les colonnes destinées aux numéros de folio."@fr ;
                  rdfs:label "Special value of cadastral tables"@en ,
                             "Valeur spéciale des tables cadastrales"@fr ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Special cell value"@en ,
                                                                  "Valeur spéciale"@fr .


###  https://w3id.org/tabulae#Taxpayer
:Taxpayer rdf:type owl:Class ;
          rdfs:comment "Natural or legal person liable for property tax for land for which they have full ownership or usufruct."@en ,
                       "Personne physique ou morale redevable de l'impôt foncier pour les terres dont elle a la pleine propriété ou l'usufruit."@fr ;
          rdfs:label "Contribuable"@fr ,
                     "Taxpayer"@en ;
          <http://www.w3.org/2004/02/skos/core#altLabel> "Owner"@en ,
                                                         "Propriétaire ou usufruitier"@fr ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Contribuable"@fr ,
                                                          "Taxpayer"@en .


###  https://www.ica.org/standards/RiC/ontology#Instantiation
<https://www.ica.org/standards/RiC/ontology#Instantiation> rdf:type owl:Class .


###  https://www.ica.org/standards/RiC/ontology#Record
<https://www.ica.org/standards/RiC/ontology#Record> rdf:type owl:Class .


###  https://www.ica.org/standards/RiC/ontology#RecordPart
<https://www.ica.org/standards/RiC/ontology#RecordPart> rdf:type owl:Class .


###  https://www.ica.org/standards/RiC/ontology#RecordResource
<https://www.ica.org/standards/RiC/ontology#RecordResource> rdf:type owl:Class .


###  https://www.ica.org/standards/RiC/ontology#RecordSet
<https://www.ica.org/standards/RiC/ontology#RecordSet> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  https://w3id.org/tabulae#
<https://w3id.org/tabulae#> rdf:type owl:NamedIndividual ,
                                     <http://purl.org/vocommons/voaf#Vocabulary> .


###  https://w3id.org/tabulae#AnnotationClassList
:AnnotationClassList rdf:type owl:NamedIndividual ,
                              <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                     rdfs:comment "List of the various classes that can be assigned to a document, a field within a document, or a text or text excerpt, represented as a list of SKOS concepts. These classes are assigned during the process of extracting and structuring digitised land registry documents. They enable the creation of the graph ultimately used to study changes in land plots."@en ,
                                  "Liste des différentes classes pouvant être attribuées à un document, à une zone dans un document, à un texte ou extrait de texte, représentés comme une liste de concepts SKOS. Ces classes sont attribuées lors de processus d'extraction et de structuration des documents cadastraux numérisés. Ils permettent de produire le graphe finalement utilisé pour étudier l'évolution des parcelles."@fr ;
                     rdfs:label "List of classes and entity types used in document processing workflows"@en ,
                                "Liste des classes et types d'entités utilisés lors des processus de traitement des documents"@fr ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "List of classes and entity types used in document processing workflows"@en ,
                                                                     "Liste des classes et types d'entités utilisés lors des processus de traitement des documents"@fr .


###  https://w3id.org/tabulae#LandRegistryChangeList
:LandRegistryChangeList rdf:type owl:NamedIndividual ,
                                 <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                        rdfs:comment "List of the various changes specific to the land registry, affecting its different types of entities (geographical entities, taxpayers, documents), represented as a list of SKOS concepts."@en ,
                                     "Liste des différents changements spécifique au cadastre, impactant ses différents types d'entités (entités géographiques, contribuables, documents), représentés comme une liste de concepts SKOS."@fr ;
                        rdfs:label "List of types of changes related to the land registry."@en ,
                                   "Liste des types de changements liés au cadastre."@fr ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "List of types of changes related to the land registry."@en ,
                                                                        "Liste des types de changements liés au cadastre."@fr .


###  https://w3id.org/tabulae#LandRegistryEventList
:LandRegistryEventList rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                       rdfs:comment "List of types of events related to the land regsitry that may occur, relating to the geographical features described or to the documents, represented as a list of SKOS concepts."@en ,
                                    "Liste des types d'évènements associés aux cadastre pouvant intervenir, liés aux entités géographiques décrites ou aux documents, représentés comme une liste de concepts SKOS."@fr ;
                       rdfs:label "List of types of events related to the land registry."@en ,
                                  "Liste des types d'évènements liés au cadastre."@fr ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "List of types of events related to the land registry."@en ,
                                                                       "Liste des types d'évènements liés au cadastre."@fr .


###  https://w3id.org/tabulae#LandRegistryLandmarkList
:LandRegistryLandmarkList rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                          rdfs:comment "List of reference types mentioned in the land registry, represented as a list of SKOS concepts."@en ,
                                       "Liste des types de repères mentionnés dans le cadastre, représentés comme une liste de concepts SKOS."@fr ;
                          rdfs:label "List of types of geographical features associated with the land registry"@en ,
                                     "Liste des types d'entités géographiques liées au cadastre"@fr ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "List of types of geographical features associated with the land registry"@en ,
                                                                          "Liste des types d'entités géographiques liées au cadastre"@fr .


###  https://w3id.org/tabulae#LandRegistrySourceList
:LandRegistrySourceList rdf:type owl:NamedIndividual ,
                                 <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                        rdfs:comment "List of the different types of sources (documents) and their derivative versions, represented as a list of SKOS concepts."@en ,
                                     "Liste des différentes types de sources (documents) et de leurs versions dérivées, représentées comme une liste de concepts SKOS."@fr ;
                        rdfs:label "List of types of sources related to the land registry"@en ,
                                   "Liste des types de sources liées au cadastre"@fr ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "List of types of sources related to the land registry"@en ,
                                                                        "List of types of sources related to the land registry"@fr .


###  https://w3id.org/tabulae#NatureList
:NatureList rdf:type owl:NamedIndividual ,
                     <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
            rdfs:comment "List of the different natures of plots, represented as a list of SKOS concepts. The types in the list are derived from observations made in old land registry as well as in documents describing the content of the current land registry."@en ,
                         "Liste des différentes natures de parcelles, représentés comme une liste de concepts SKOS. Les natures de la liste sont issues d'observations réalisées dans les documents cadastraux anciens ainsi que dans des documents descriptifs du cadastre moderne."@fr ;
            rdfs:label "List of plot natures"@en ,
                       "Liste des natures de parcelles"@fr ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "List of plot natures"@en ,
                                                            "Liste des natures de parcelles"@fr .


###  https://w3id.org/tabulae#PlotAttributeList
:PlotAttributeList rdf:type owl:NamedIndividual ,
                            <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                   rdfs:comment "List of the various roles specific to the plots described in the land registry, that can be assigned to an attribute, represented as a list of SKOS concepts."@en ,
                                "Liste des différents rôles spécifique aux parcelles cadastrales pouvant être joués par un attribut, représentés comme une liste de concepts SKOS."@fr ;
                   rdfs:label "List of attribute types specific to land plots described in the land registry."@en ,
                              "Liste des types d'attributs spécifiques aux parcelles cadastrales."@fr ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "List of attribute types specific to land plots described in the land registry."@en ,
                                                                   "Liste des types d'attributs spécifiques aux parcelles cadastrales."@fr .


###  https://w3id.org/tabulae#SpecialCellValueList
:SpecialCellValueList rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                      rdfs:comment "List of so-called special values found in cadastral documents. Once explained, these values enable the generation of structured insights into changes in land parcels. They are used in particular during the graph generation phase."@en ,
                                   "Liste des valeurs dites spéciales rencontrées dans les documents cadastraux. Une fois explicitées, ces valeurs permettent de produire des connaissances structurées sur l'évolution des parcelles. Elles sont notamment utilisées lors de la phase de production du graphe."@fr ;
                      rdfs:label "List of special values found in the cadastral tables"@en ,
                                 "Liste des valeurs spéciales rencontrées dans les tables cadastrales"@fr ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "List of special values found in the cadastral tables"@en ,
                                                                      "Liste des valeurs spéciales rencontrées dans les tables cadastrales"@fr .


###  https://w3id.org/tabulae/id/codes/annotationClass/BlankPage
<https://w3id.org/tabulae/id/codes/annotationClass/BlankPage> rdf:type owl:NamedIndividual ,
                                                                       <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                       :AnnotationClassType ;
                                                              <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/tabulae/id/codes/annotationClass/PageClasses> ;
                                                              <http://www.w3.org/2004/02/skos/core#definition> "Page non complétée, indépendament de sa nature. Cette classe peut-être utilisée avec d'autres classes pour décrire la page plus précisément."@fr ,
                                                                                                               "Page not completed, regardless of its nature. This class can be used in addition of other classes to describe the page in more detail."@en ;
                                                              <http://www.w3.org/2004/02/skos/core#hiddenLabel> "ets_blank" ;
                                                              <http://www.w3.org/2004/02/skos/core#inScheme> :AnnotationClassList ;
                                                              <http://www.w3.org/2004/02/skos/core#prefLabel> "Blank page"@en ,
                                                                                                              "Page vide"@fr ;
                                                              <http://www.w3.org/2004/02/skos/core#related> <https://w3id.org/tabulae/id/codes/annotationClass/Page> .


###  https://w3id.org/tabulae/id/codes/annotationClass/CrossedOut
<https://w3id.org/tabulae/id/codes/annotationClass/CrossedOut> rdf:type owl:NamedIndividual ,
                                                                        <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                        :AnnotationClassType ;
