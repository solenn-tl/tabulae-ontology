peg:hasTrace a owl:ObjectProperty ;
    rdfs:label "a pour trace"@fr, "has trace"@en ;
    rdfs:comment "Décrit qu'un élément a pour trace un autre élément"@fr, "Describes that an element has another element as its trace"@en ;
    owl:inverseOf peg:isTraceOf.

peg:isTraceOf a owl:ObjectProperty ;
    rdfs:label "est une trace de"@fr, "is trace of"@en ;
    rdfs:comment "Décrit qu'un élément est la trace d'un autre élément"@fr, "Describes that an element is the trace of another element"@en ;
    owl:inverseOf peg:hasTrace.


#################################################################
#    Datatype properties
#################################################################
tbl:spanValue a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:comment "Cette propriété permet d'indiquer la valeur d'une sous-chaine de caractères."@fr,
                 "This property allows to indicate the value of a substring."@en ;
    rdfs:label "valeur de la sous-chaîne"@fr ,
                "span value"@en.

tbl:indexOfFirstCharacter a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Cette propriété permet d'indiquer l'index du premier caractère d'une sous-chaine de caractères dans un texte. Index à partir de 0."@fr,
                 "This property allows to indicate the index of the first character of a substring. Index starts from 0."@en ;
    rdfs:label "index du premier caractère"@fr ,
                "index of first character"@en.

tbl:indexOfLastCharacter a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Cette propriété permet d'indiquer l'index du dernier caractère d'une sous-chaine de caractères dans un texte. Index à partir de 0."@fr,
                 "This property allows to indicate the index of the last character of a substring. Index starts from 0."@en ;
    rdfs:label "index du dernier caractère"@fr ,
                "index of last character"@en.

tbl:imageURL a owl:DatatypeProperty ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "URL d'image"@fr, "image URL"@en ;
    rdfs:comment "URL d'une image représentant un document ou une partie de document."@fr,
                 "URL of an image representing a document or part of a document."@en .

tbl:IIIFImageUrl a owl:DatatypeProperty ;
    owl:subPropertyOf tbl:imageURL ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "URL d'image IIIF"@fr, "IIIF image URL"@en ;
    rdfs:comment "URL d'une image fournie par l'API IIIF (International Image Interoperability Framework) représentant un document ou une partie de document."@fr,
                 "URL of an image provided by the IIIF (International Image Interoperability Framework) image representing a document or part of a document."@en .

tbl:taxpayerLabel a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Label d'un contribuable, qui peut être son nom complet (pour une personne physique) ou sa raison sociale (pour une personne morale)."@fr,
                 "Label of a taxpayer, which can be their full name (for an individual) or their company name (for a legal entity)."@en ;
    rdfs:label "label de contribuable"@fr, "taxpayer label"@en .

tbl:taxpayerFullName a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:taxpayerLabel ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Identité complète d'un contribuable (personne physique) composée a minima d'un nom de famille et optionnellement d'un ou plusieurs prénoms et d'un statut familial."@fr,
                 "Full identity of an individual taxpayer: last name and first names."@en ;
    rdfs:label "nom complet"@fr, "full name"@en .

tbl:taxpayerLastName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Nom de famille d'un contribuable"@fr,
                 "Last name of a taxpayer"@en ;
    rdfs:label "nom de famille"@fr, "last name"@en .

tbl:taxpayerFirstName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom (unitiare) d'un contribuable. En pratique peu utilisée car implique de connaître de façon certaine l'état civil d'un contribuable."@fr,
                 "Unique first name of a taxpayer. Generally not used in practice as it requires certain knowledge of the taxpayer's civil status."@en ;
    rdfs:label "prénom unique"@fr, "unique first name"@en.

tbl:taxpayerFirstNames a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom(s) d'un contribuable, généralement présentés sous la forme d'une liste de prénoms dans les documents. Dans le cas des contribuables ayant le statut familial 'Mme' ou 'Veuve', le prénom indiqué est généralement celui de l'époux."@fr,
                 "First name(s) of a taxpayer, generally presented as a list of first names in documents. In the case of taxpayers with the family status 'Mrs' or 'Widow', the indicated first name is generally that of the spouse."@en ;
    rdfs:label "prénom(s)"@fr, "first name(s)"@en ;
    tbl:isPreferredOver tbl:taxpayerFirstName .

tbl:taxpayerBirthName a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Nom de naissance d'une contribuable. Par exemple, le nom de naissance d'une personne avant son mariage (sans le cas où elle utilise ensuite le nom de son époux/épouse)."@fr,
                 "Birth name of a taxpayer."@en ;
    rdfs:label "nom de naissance"@fr, "birth name"@en .

tbl:taxpayerSpouseOrChildrenFirstNames a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Prénom(s) de l'époux/épouse ou d'un enfant dans un libellé de compte foncier. Généralement indiqués en seconde partie de libellé en complémenant de l'identité d'un contribuable 'racine' (le titulaire initial du compte foncier)."@fr,
                    "First name(s) of the spouse or a child in a land registry folio label, generally indicated in the second part of the label."@en ;
    rdfs:label "prénom(s) de l'époux/épouse ou d'un enfant"@fr, "spouse or children first name(s)"@en .

tbl:taxpayerOrganisationName a owl:DatatypeProperty ;
    rdfs:subPropertyOf tbl:taxpayerLabel ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Raison sociale d'un contribuable personne morale"@fr,
                 "Company name of a legal entity taxpayer"@en ;
    rdfs:label "raison sociale"@fr, "organisation name"@en .

tbl:taxpayerStatus a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Statut d'un contibuable qui n'est pas lié à son statut familial. Exemple : 'Non imposable'"@fr ,
                 "Status of a taxpayer which is not related to their family status."@en ;
    rdfs:label "statut"@fr, "status"@en .

tbl:taxpayerFamilyStatus a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Statut d'un contribuable lié à son statut ou à ses relations familiales (Veuve, Veuf, Fils, Fille, Mineur, Héritiers)"@fr ,
                 "Status of a taxpayer related to their family status or relationships (Widow, Widower, Son, Daughter, Minor, Heirs)"@en ;
    rdfs:label "statut familial"@fr, "family status"@en .

tbl:taxpayerAddress a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Adresse d'un contribuable renseignée sous la forme d'une chaîne de caractères. Pour les adresses sous forme d'entités, voir tbl:taxpayerHasAddressEntity."@fr, 
    "Address of a taxpayer provided as a string. For addresses as entities, see tbl:taxpayerHasAddressEntity."@en ;
    rdfs:label "adresse du contribuable"@fr, "taxpayer address"@en .

tbl:taxpayerActivity a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Activité d'un contribuable, généralement relatif à l'activité professionnelle"@fr, "Activity of a taxpayer, generally related to their professional activity"@en ;
    rdfs:label "activité du contribuable"@fr, "taxpayer activity"@en.

tbl:taxpayerTitle a owl:DatatypeProperty ;
    rdfs:domain tbl:Taxpayer ;
    rdfs:range xsd:string ;
    rdfs:comment "Civilité (M, Mme, etc.), titre de noblesse (Prince de, Marquis de, etc.) ou titre honorifique"@fr, "Civility (Mr, Mrs, etc.), noble title (e.g., Prince of, Marquis of) or honorific"@en ;
    rdfs:label "titre"@fr, "title"@en.

tbl:hasNumFolio a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    rdfs:range xsd:string ;
    rdfs:comment "Numéro de folio (associé à une page entière ou à une partie de page) "@fr, "folio number (associated to a mutation register page or part of page)"@en ;
    rdfs:label "a pour numéro de folio"@fr,
               "has folio number"@en .

tbl:hasAlternativeNumFolio a owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                    owl:unionOf ( rico:Instantiation
                                  rico:RecordResource
                                )
                  ] ;
    rdfs:range xsd:string ;
    rdfs:comment "Numéro de folio alternatif (ex: ancien numéro)"@fr, "Alternative folio number (e.g. former number)"@en;
    rdfs:label "a pour numéro de folio alternatif"@fr, "has alternative folio number"@en .

tbl:transcription a owl:DatatypeProperty ;
  rdfs:domain [ a owl:Class ;
        owl:unionOf ( rico:Instantiation tbl:NamedEntity )
    ] ;
  rdfs:range rdfs:Literal ;
  rdfs:label "transcription"@en, "transcription"@fr;
  skos:prefLabel "transcription"@en, "transcription"@fr ;
  rdfs:comment "Transcription d'une zone ou d'une entité obtenue automatiquement ou manuellement à partir d'un document (numérisé)."@fr,
                "Transcription of an area or an entity obtained automatically or manually from a (scanned) document."@en.

tbl:coordinatesInImageSystem a owl:DatatypeProperty ;
  rdfs:domain rico:Instantiation ;
  rdfs:range rdfs:Literal ;
  skos:prefLabel "coordinates in image"@en, "coordonnées dans l'image"@fr;
  rdfs:label "coordinates in image"@en, "coordonnées dans l'image"@fr;
  rdfs:comment "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé.".

tbl:xywhCoordinates a owl:DatatypeProperty ;
    owl:subPropertyOf tbl:coordinatesInImageSystem ;
    rdfs:domain rico:Instantiation ;
    rdfs:range rdfs:Literal ;
    skos:prefLabel "xywh coordinates in image"@en, "coordonnées xywh dans l'image"@fr;
    rdfs:label "xywh coordinates in image"@en, "coordonnées xywh dans l'image"@fr;
    rdfs:comment "Coordonnées (référentiel image) d'une zone annotée (manuellement ou automatiquement) dans un document numérisé, sous la forme d'un rectangle défini par les coordonnées x et y du coin supérieur gauche et la largeur et la hauteur du rectangle (tel que requis dans les spécifications IIIF). Par exemple : 1160,1103,1529,1421"@fr,
                 "Coordinates (image reference system) of an annotated area (manually or automatically) in a scanned document, in the form of a rectangle defined by the x and y coordinates of the upper left corner and the width and height of the rectangle (as required in the IIIF specifications). For example: 1160,1103,1529,1421"@en.

tbl:lineOrderInArea a owl:DatatypeProperty ;
    rdfs:domain rico:Instantiation ;
    rdfs:range xsd:integer ;
    skos:prefLabel "row order in area"@en, "ordre de ligne dans la zone"@fr;
    rdfs:label "row order in area"@en, "ordre de ligne dans la zone"@fr;
    rdfs:comment "Ordre de la ligne dans la zone annotée (manuellement ou automatiquement) dans un document numérisé.".

tbl:TFNBGroup a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    skos:prefLabel "TFNB group"@en, "groupe TFNB"@fr;
    rdfs:label "TFNB group"@en, "groupe TFNB"@fr;
    rdfs:comment "Groupe de TFNB (Taxe Foncière sur les Propriétés Non Bâties) d'une parcelle, tel qu'indiqué dans les documents cadastraux."@fr,
                 "Group of TFNB (Taxe Foncière sur les Propriétés Non Bâties) of a plot, as indicated in cadastral documents."@en.

tbl:URL a owl:DatatypeProperty ;
  rdfs:domain owl:Thing ;
  rdfs:range rdfs:Literal ;
  skos:prefLabel "source URL"@en, "url de la source"@fr;
  rdfs:label "url de la source"@fr, "source URL"@en;
  rdfs:comment 'Correspond à l\'URL de la source (image, base de donnée)'.

# ---- Properties copied here to avoid imports ----
#rdfs:label a owl:DatatypeProperty.
#dcterms:identifier a owl:DatatypeProperty.
#pwikidata:P8422 a owl:DatatypeProperty;
#    rdfs:label "identifiant Ldh/EHESS/Cassini"@fr.
#igeo:codeINSEE  a owl:DatatypeProperty .
#rico:identifier a owl:DatatypeProperty .
#rico:name a owl:DatatypeProperty .

##########################
#####  Individuals
##########################

# ------ Lists

tbl:AnnotationClassList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of classes and entity types used in document processing workflows"@en,
        "Liste des classes et types d'entités utilisés lors des processus de traitement des documents"@fr ;
    rdfs:comment "List of the various classes that can be assigned to a document, a field within a document, or a text or text excerpt, represented as a list of SKOS concepts. These classes are assigned during the process of extracting and structuring digitised land registry documents. They enable the creation of the graph ultimately used to study changes in land plots."@en,
        "Liste des différentes classes pouvant être attribuées à un document, à une zone dans un document, à un texte ou extrait de texte, représentés comme une liste de concepts SKOS. Ces classes sont attribuées lors de processus d'extraction et de structuration des documents cadastraux numérisés. Ils permettent de produire le graphe finalement utilisé pour étudier l'évolution des parcelles."@fr ;
    skos:prefLabel "List of classes and entity types used in document processing workflows"@en,
        "Liste des classes et types d'entités utilisés lors des processus de traitement des documents"@fr .

tbl:LandRegistryChangeList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of types of changes related to the land registry."@en,
        "Liste des types de changements liés au cadastre."@fr ;
    rdfs:comment "List of the various changes specific to the land registry, affecting its different types of entities (geographical entities, taxpayers, documents), represented as a list of SKOS concepts."@en,
        "Liste des différents changements spécifique au cadastre, impactant ses différents types d'entités (entités géographiques, contribuables, documents), représentés comme une liste de concepts SKOS."@fr ;
    skos:prefLabel "List of types of changes related to the land registry."@en,
        "Liste des types de changements liés au cadastre."@fr .

tbl:LandRegistryEventList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of types of events related to the land registry."@en,
        "Liste des types d'évènements liés au cadastre."@fr ;
    rdfs:comment "List of types of events related to the land regsitry that may occur, relating to the geographical features described or to the documents, represented as a list of SKOS concepts."@en,
        "Liste des types d'évènements associés aux cadastre pouvant intervenir, liés aux entités géographiques décrites ou aux documents, représentés comme une liste de concepts SKOS."@fr ;
    skos:prefLabel "List of types of events related to the land registry."@en,
        "Liste des types d'évènements liés au cadastre."@fr .

tbl:LandRegistryLandmarkList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of types of geographical features associated with the land registry"@en,
        "Liste des types d'entités géographiques liées au cadastre"@fr ;
    rdfs:comment "List of reference types mentioned in the land registry, represented as a list of SKOS concepts."@en,
        "Liste des types de repères mentionnés dans le cadastre, représentés comme une liste de concepts SKOS."@fr ;
    skos:prefLabel "List of types of geographical features associated with the land registry"@en,
        "Liste des types d'entités géographiques liées au cadastre"@fr .

tbl:LandRegistrySourceList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of types of sources related to the land registry"@en,
        "Liste des types de sources liées au cadastre"@fr ;
    rdfs:comment "List of the different types of sources (documents) and their derivative versions, represented as a list of SKOS concepts."@en,
        "Liste des différentes types de sources (documents) et de leurs versions dérivées, représentées comme une liste de concepts SKOS."@fr ;
    skos:prefLabel "List of types of sources related to the land registry"@en,
        "List of types of sources related to the land registry"@fr .

tbl:NatureList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of plot natures"@en,
        "Liste des natures de parcelles"@fr ;
    rdfs:comment "List of the different natures of plots, represented as a list of SKOS concepts. The types in the list are derived from observations made in old land registry as well as in documents describing the content of the current land registry."@en,
        "Liste des différentes natures de parcelles, représentés comme une liste de concepts SKOS. Les natures de la liste sont issues d'observations réalisées dans les documents cadastraux anciens ainsi que dans des documents descriptifs du cadastre moderne."@fr ;
    skos:prefLabel "List of plot natures"@en,
        "Liste des natures de parcelles"@fr .

tbl:PlotAttributeList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of attribute types specific to land plots described in the land registry."@en,
        "Liste des types d'attributs spécifiques aux parcelles cadastrales."@fr ;
    rdfs:comment "List of the various roles specific to the plots described in the land registry, that can be assigned to an attribute, represented as a list of SKOS concepts."@en,
        "Liste des différents rôles spécifique aux parcelles cadastrales pouvant être joués par un attribut, représentés comme une liste de concepts SKOS."@fr ;
    skos:prefLabel "List of attribute types specific to land plots described in the land registry."@en,
        "Liste des types d'attributs spécifiques aux parcelles cadastrales."@fr .

tbl:SpecialCellValueList a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "List of special values found in the cadastral tables"@en,
        "Liste des valeurs spéciales rencontrées dans les tables cadastrales"@fr ;
    rdfs:comment "List of so-called special values found in cadastral documents. Once explained, these values enable the generation of structured insights into changes in land parcels. They are used in particular during the graph generation phase."@en,
        "Liste des valeurs dites spéciales rencontrées dans les documents cadastraux. Une fois explicitées, ces valeurs permettent de produire des connaissances structurées sur l'évolution des parcelles. Elles sont notamment utilisées lors de la phase de production du graphe."@fr ;
    skos:prefLabel "List of special values found in the cadastral tables"@en,
        "Liste des valeurs spéciales rencontrées dans les tables cadastrales"@fr .


# ----- List of land registry landmarks (peg:Landmark) -----

tblltype:Plot a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    skos:altLabel "Land plot"@en ;
    skos:broader tblltype:Section ;
    skos:definition "The most precise geographical unit in the land registry, corresponding to a coherent parcel of land (often of the same type) and linked to a taxpayer."@en,
        "Entité géographique la plus précise du cadastre, correspondant à une unité de terre cohérente (souvent de même nature) et associée à un contribuable."@fr ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "Plot"@en,
        "Parcelle"@fr .

tblltype:Arrondissement a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    rdf:seeAlso "https://fr.wikipedia.org/wiki/Arrondissement_fran%C3%A7ais" ;
    skos:broader tblltype:Departement ;
    skos:definition "A geographical unit corresponding to the first level of subdivision within a department. Their administrative role has evolved since their creation, which means there are differences compared with the current definition of an arrondissement, although this does not alter the hierarchy of administrative geographical units."@en,
        "Entité géographique correspondant au premier niveau de sous-division des départements. Leur rôle administratif a évolué depuis leur création, ce qui implique des différences avec la définition actuelle de l'arrondissement sans que celà change la hiérarchie des entités géographiques administratives."@fr ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "French Arrondissement"@en,
        "Arrondissement départemental"@fr .

tblltype:Canton a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    rdf:seeAlso "https://fr.wikipedia.org/wiki/Canton_fran%C3%A7ais" ;
    skos:altLabel "Canton officiel"@fr,
        "Justice de paix"@fr ;
    skos:broader tblltype:Arrondissement ;
    skos:definition "A geographical unit corresponding to the second level of subdivision within departments as recorded in the land registry, situated between the district and the municipality. These are the official cantons, established in the late 18th century, primarily for the organisation of magistrates’ courts (until 1958) and elections. In the land registry records, the term ‘Justice of the Peace’ may also be used instead of ‘Canton’."@en,
        "Entité géographique correspondant au deuxième niveau de sous-division des départements mentionné dans le cadastre, situé entre l'arrondissement et la commune. Il s'agit ici des cantons officiels, créés à la fin du 18ème siècle, notamment pour l'organisation des justices de paix (jusqu'à 1958) et des élections. Dans les registres cadastraux, le terme \"Justice de paix\" peut d'ailleurs être utilisé à la place de \"Canton\"."@fr ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "French Canton"@en,
        "Canton"@fr .

tblltype:Commune a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    skos:altLabel "Municipality"@en ;
    skos:broader tblltype:Canton ;
    skos:definition "A geographical unit corresponding to the finest administrative division across the whole territory. Each municipality had its own land registry comprising a complete set of documents (maps and registers)."@en,
        "Entité géographique correspondant au maillage administratif le plus fin sur l'ensemble du territoire. Chaque commune possédait son cadastre comprenant un corpus complet de documents (plans et registres)."@fr ;
    skos:exactMatch <http://data.ign.fr/def/geofla#Commune> ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "French Commune"@en,
        "Commune"@fr .

tblltype:Departement a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    skos:broader tblltype:FrenchAdministrativeUnit ;
    skos:definition "A geographical unit corresponding to the French departments since their creation in 1790. The departments were responsible for collecting direct taxes from the municipalities within their territory."@en,
        "Entité géographique correspondant aux départements français depuis leur création en 1790. Les départements étaient responsable du prélèvement des contributions directes des communes se trouvant sur le territoire."@fr ;
    skos:exactMatch <http://data.ign.fr/def/geofla#Departement> ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "French Departement"@en,
        "Département"@fr .

tblltype:FrenchAdministrativeUnit a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    skos:definition "A geographical entity corresponding to a French administrative unit."@en,
        "Entité géographique correspondant à une unité administrative française."@fr ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "French Administrative Unit"@en,
        "Unité administrative française"@fr .

tblltype:Section a owl:NamedIndividual,
        skos:Concept,
        peg:LandmarkType ;
    skos:altLabel "Cadastral section"@en ;
    skos:broader tblltype:Commune ;
    skos:definition "A geographical unit specific to the land registry, it is identified by a single letter in the old land registry and by one or more letters in the updated land registry. It corresponds to a division of the municipality into large groups of plots. Generally speaking, each sheet of the plot map represented a section."@en,
        "Entité géographique spécifique au cadastre, elle est identifiée par une lettre dans l'ancien cadastre et par une ou plusieurs lettres dans le cadastre rénové. Elle correspond à un découpage de la commune en grands ensembles de parcelles. Dans le cas général, chaque feuille de plan parcellaire représentait une section."@fr ;
    skos:inScheme tbl:LandRegistryLandmarkList ;
    skos:prefLabel "Section"@en,
        "Section"@fr .

# ----- List of land registry landmarks attributes types (peg:AttributeType) -----
tblatype:PlotAddress a owl:NamedIndividual,
        skos:Concept,
        peg:AttributeType ;
    skos:altLabel "Plot location"@en,
        "Localisation de la parcelle"@fr ;
    skos:definition "Address of the plot, usually corresponding to a local place name, a road or street, or possibly a house number."@en,
        "Adresse de la parcelle concernée, correspondant généralement à un lieu-dit, à une voie ou rue ou éventuellement à un numéro d'adresse."@fr ;
    skos:inScheme tbl:PlotAttributeList ;
    skos:prefLabel "Plot Address"@en,
        "Adresse de la parcelle"@fr .

tblatype:PlotMention a owl:NamedIndividual,
        skos:Concept,
        peg:AttributeType ;
    skos:definition "Reference to the plot in the registers. This usually involves stating the current folio of the plot, enabling it to be located in the documents."@en,
        "Mention de la parcelle dans un document. Correspond généralement à l'indication du folio permettant de la retrouver dans les documents."@fr ;
    skos:inScheme tbl:PlotAttributeList ;
    skos:prefLabel "Mention of the plot"@en,
        "Mention de la parcelle"@fr .

tblatype:PlotNature a owl:NamedIndividual,
        skos:Concept,
        peg:AttributeType ;
    skos:definition "Nature of the plot, in relation to the soil type or its use."@en,
        "Nature de la parcelle concernée, associée au type de sol ou à l'usage de celui-ci."@fr ;
    skos:inScheme tbl:PlotAttributeList ;
    skos:prefLabel "Plot Nature"@en,
        "Nature de la parcelle"@fr .

tblatype:PlotTaxpayer a owl:NamedIndividual,
        skos:Concept,
        peg:AttributeType ;
    skos:altLabel "Owner or usufructuary"@en,
        "Propriétaire ou usufruitier"@fr ;
    skos:definition "A natural or legal person liable for council tax on the plot in question."@en,
        "Personne physique ou morale redevable de l'impôt foncier pour la parcelle concernée."@fr ;
    skos:inScheme tbl:PlotAttributeList ;
    skos:prefLabel "Taxpayer"@en,
        "Contribuable"@fr .

# ----- List of land registry events (peg:Event) -----
tbletype:Addition a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:BuildingRelatedEvent ;
    skos:definition "This event is linked to a change to the building that results in an increase in its valuation (e.g. the addition of a floor or an extension)."@en,
        "Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la hausse (ex : ajout d'un étage ou d'une extension)."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Extension to a building"@en,
        "Augmentation d'un bâtiment"@fr .

tbletype:ClosePropertyAccount a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:altLabel "Supression d'un compte foncier"@fr ;
    skos:definition "This event relates to the closure of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is closed corresponds to the date on which a legal or natural person ceases to pay property tax for [1..n] plots of land in the municipality in question."@en,
        "Cet évènement est associé à la clôture du compte foncier d'un contribuable dans une commune donnée. Plus précisément, la date de clôture du compte foncier correspond à la date à laquelle une personne légale ou morale ne paye plus l'impôt foncier pour [1..n] parcelles de la commune concernée."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Closing of a property tax account"@en,
        "Fermeture d'un compte foncier"@fr .

tbletype:ConsideredAsRuined a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:BuildingRelatedEvent ;
    skos:definition "This event is linked to a building being reclassified as a ruin. This generally means that it is no longer subject to property tax."@en,
        "Cet évènement est associé au reclassement d'un bâtiment en tant que ruine. Ceci implique généralement qu'il n'est plus imposé au titre des propriétés bâties."@fr ;
    skos:hiddenLabel "En ruines",
        "Ruines" ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Declaration of a building in ruins"@en,
        "Déclaration d'un bâtiment en ruines"@fr .

tbletype:Construction a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:BuildingRelatedEvent ;
    skos:definition "This project involves the construction of a building on a plot of land."@en,
        "Cet évènement implique la construction d'un bâtiment sur une parcelle."@fr ;
    skos:hiddenLabel "Construction nouvelle" ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Construction of a building"@en,
        "Construction d'un bâtiment"@fr .

tbletype:Demotion a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:BuildingRelatedEvent ;
    skos:definition "This project involves the complete demolition of a building on a plot of land."@en,
        "Cet évènement implique la destruction complète d'un bâtiment sur une parcelle."@fr ;
    skos:hiddenLabel "Destruction" ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Demolition of a building"@en,
        "Démolition d'un bâtiment"@fr .

tbletype:DocumentCreation a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event refers to the addition of a new physical document to the cadastral register of a given municipality. For example, it may involve the creation of a new register to replace one that has already been completed."@en,
        "Cet évènement désigne l'ajout d'un nouveau document physique dans le corpus cadastral d'une commune donnée. Par exemple, il peut s'agir de l'ouverture d'une matrice (en tant que registre) pour succéder à une matrice déjà complète."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Creating a document"@en,
        "Création d'un document"@fr .

tbletype:DocumentOutdated a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event refers to the closure of a physical document within the cadastral records of a given municipality. For example, it may be a register whose contents have been transcribed into another register and which is no longer in use."@en,
        "Cet évènement désigne la clôture d'un document physique dans le corpus cadastral d'une commune donnée. Par exemple, il peut s'agir d'un registre dont le contenu a été recopié dans un autre registre et qui n'est plus utilisé."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Archiving a document"@en,
        "Archivage d'un document"@fr .

tbletype:LandRegistryCreation a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event refers to the creation of a land registry in a municipality, in the functional sense of the term. A land registry is established through the production of a parcel map, which corresponds to a specific division of land among various taxpayers, on which each parcel is assigned a unique identifier (1 land registry = 1 numbering system). The registers (section statements and matrices) are then created."@en,
        "Cet évènement désigne la création d'un cadastre dans une commune, au sens fonctionnel de celui-ci. Un cadastre est initialisé par la production d'un plan parcellaire, correspond à un découpage donné du sol entre divers contribuables, sur lequel chaque parcelle porte un identifiant donné (1 cadastre = 1 numérotation). Les registres (états de sections et matrices) sont initialisés dans la foulée."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Creating a land registry"@en,
        "Initialisation d'un cadastre"@fr .

tbletype:LandRegistryOutdated a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event refers to the closure of a cadastral register in a municipality, in the functional sense of the term. The closure generally precedes the production of a new cadastral register, which involves a new survey, the production of new maps showing a different parcel layout with its own numbering system."@en,
        "Cet évènement désigne la clôture d'un cadastre dans une commune, au sens fonctionnel de celui-ci. La clôture précède généralement la production d'un nouveau cadastre qui est doté d'une nouvelle opération de levés, de la production de nouveaux plans représentant un parcellaire différent avec sa numérotation propre."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Archiving a land registry"@en,
        "Archivage d'un cadastre"@fr .

tbletype:Merge a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:LandmarkEvent ;
    skos:definition "This event describes the merging of [2..n] land plots. In the land registry documents, this event can be identified in two ways.\\n- A new plot is associated with two identifiers (for example, ‘D-100 D-102’).\\n Two plots bearing the same number, previously resulting from the division of a larger plot, are reassociated in the land register of the same taxpayer."@en,
        "Cet évènement décrit la fusion de [2..n] parcelles. Dans les documents, cet évènement peut être dététecter de deux façons.\\n- Une parcelle est nouvelle associée à deux identifiant (par exemple \"D-100 D-102\").\\n Deux parcelles portant le même numéro, précédement issues de la division d'une parcelle de plus grande superficie, sont réassociées dans le compte foncier d'un même contribuable."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Merger of plots"@en,
        "Fusion de parcelles"@fr .

tbletype:Omission a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:altLabel "Oubli de déclaration"@fr ;
    skos:definition "This event relates to a taxpayer’s failure to declare a property on which they have not paid tax for [n] years. Specifically, it refers to the point at which the property is retrospectively re-included in the property tax assessment."@en,
        "Cet évènement est associé à omission de déclaration d'un bien foncier par un contribuable qui n'a pas payé l'impôt pendant [n] années pour celui-ci. L'évènement désigne précisément le moment de la réintégration a posteriori du bien le compte foncier."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Failure to declare"@en,
        "Omission de déclaration"@fr .

tbletype:OpenPropertyAccount a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:altLabel "Création d'un compte foncier"@fr ;
    skos:definition "This event is linked to the opening of a taxpayer’s property tax account in a given municipality. More specifically, the date on which the property tax account is opened corresponds to the date on which a legal or natural person begins to pay property tax for [1..n] plots of land in the municipality in question."@en,
        "Cet évènement est associé à l'ouverture du compte foncier d'un contribuable dans une commune donnée. Plus précisément, la date d'ouverture du compte foncier correspond à la date à laquelle une personne légale ou morale commence à payer l'impôt foncier pour [1..n] parcelles de la commune concernée."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Opening of a property tax account"@en,
        "Ouverture d'un compte foncier"@fr .

tbletype:Reduction a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:BuildingRelatedEvent ;
    skos:definition "This event is linked to a change to the building that results in a downward revaluation (e.g. demolition of part of the building)."@en,
        "Cet évènement est associé à une modification du bâtiment qui provoque sa réévaluation à la baisse (ex: destruction d'une partie du bâtiment)."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Demolition of a building"@en,
        "Diminution d'un bâtiment"@fr .

tbletype:Sale a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:TaxpayerMutation ;
    skos:definition "This event involves the sale of a land plot from one taxpayer to another."@en,
        "Cet évènement consiste en une vente d'une parcelle d'un contribuable à un autre."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Sale"@en,
        "Vente"@fr .

tbletype:SplitWithStay a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:Split ;
    skos:definition "This event is a specific instance of the ‘Division’ event. In this case, at least one of the new parcels resulting from the division remains in the taxpayer’s land register, linked to the divided parcel."@en,
        "Cet évènement est une précision de l'évènement \"Division\". Ici, au moins l'une des nouvelles parcelles résultant de la division reste dans le compte foncier du contribuable associée à la parcelle divisée."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Division of a plot with a residual part in the original property account"@en,
        "Division d'une parcelle avec résidu dans le compte foncier d'origine"@fr .

tbletype:Succession a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:TaxpayerMutation ;
    skos:definition "This event involves the transfer of one or more plots of land from one taxpayer to [1..n] other taxpayers upon the settlement of an estate on a given date."@en,
        "Cet évènement consiste en une transmission d'une ou plusieurs parcelles d'un contribuable à [1..n] autre contribuable lors du réglement d'une sucession à une date donnée."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Inheritance"@en,
        "Succession"@fr .

tbletype:Split a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:broader tbletype:LandmarkEvent ;
    skos:definition "This event describes the division of a plot into [2..n] new plots. In the mutation registres (Matrices des contribuables), this event can be detected by observing the carry-overs of folio numbers. If a plot described in a land register entry is ‘split’ across [2..n] new land register account, it has been divided amongst several taxpayers, each of whom will pay tax on a sub-portion of the original plot."@en,
        "Cet évènement décrit la division d'une parcelle en [2..n] nouvelles parcelles. Dans les matrices des contribuables, cet évènement peut être détecté en observant les reports de folios. Si une parcelle décrite dans un compte foncier \"passe\" dans[2..n] nouveaux comptes fonciers, elle a été divisée entre plusieurs contribuables qui paieront l'impôt chacun pour une sous-partie de la parcelle intiale."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Split of a plot"@en,
        "Division d'une parcelle"@fr .

tbletype:LandmarkEvent a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event is associated with various situations involving a change to the boundaries of a land plot."@en,
        "Cet évènement est associé à différentes situations qui impliquent une modification du périmètre d'une parcelle."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Modification of the boundaries of a plot"@en,
        "Modification du périmètre d'une parcelle"@fr .

tbletype:TaxpayerMutation a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event relates to a change in the taxpayer associated with a plot of land or a land account."@en,
        "Cet évènement est associé à un changement de contribuable associé à une parcelle ou à un compte foncier."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Modification of taxpayer"@en,
        "Mutation de contribuable"@fr .

tbletype:BuildingRelatedEvent a owl:NamedIndividual,
        skos:Concept,
        tbl:EventType ;
    skos:definition "This event refers to a change in the nature or value of a plot of land specifically linked to the construction, alteration or demolition of a building on that plot."@en,
        "Cet évènement correspond à une évolution de la nature ou de la valeur d'une parcelle spécifiquement liée à l'apparition, la mutation ou la disparition d'un bâtiment sur celle-ci."@fr ;
    skos:inScheme tbl:LandRegistryEventList ;
    skos:prefLabel "Event involving a building"@en,
        "Evènement impliquant un bâtiment"@fr .

