# ----- List of source types -----

srctype:ArticleDeMutation a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Article de mutation" ;
    skos:broader srctype:ZoneDePage ;
    skos:definition "A section or cell in a folio or sub-folio that lists the taxpayers on a land register and shows their dates of entry (and exit) from that register."@en,
        "Zone ou cellule d'un folio ou sous-folio qui liste les contribuables d'un compte foncier et indique leurs dates d'entrée (voir de sortie) de ce même compte."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Page area describing a list of taxpayers"@en,
        "Article de mutation"@fr .

srctype:CompteFoncier a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Compte foncier" ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "A set of parcel records (lines) describing the plots of one or more successive related taxpayers. A land account may correspond ‘physically’ to a folio where the latter describes the details of one, and only one, taxpayer (or a list of successive taxpayers)."@en,
        "Ensemble d'états de parcelles (lignes) qui décrivent les parcelles d'un ou plusieurs contribuables liés se succédant. Un compte foncier peut correspondre \"physiquement\" à un folio dans le cas où celui-ci décrit les informations d'un, et un seul, contribuable (ou liste de contribuables successifs)."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Property account"@en,
        "Compte foncier"@fr .

srctype:EtatsDeSections_Ap_1822 a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections postérieurs à 1822" ;
    skos:broader srctype:EtatsDeSections ;
    skos:definition "Initial registers created after 1822."@en,
        "Registre d'états de sections créé après 1822."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Initial register created after 1822"@en,
        "Etats de sections postérieurs à 1822"@fr .

srctype:EtatsDeSections_Av_1822_Bati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections antérieurs à 1822 : chapitres dédiés aux propriétés bâties" ;
    skos:broader srctype:EtatsDeSections_Av_1822 ;
    skos:definition "Extract from an initial register created before 1822, dedicated to the description of built properties."@en,
        "Partie d'un registre d'états de sections créé avant 1822 dédié à la description des propriétés bâties."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Initial register created before 1822 (unbuilt properties)"@en,
        "Etats de sections antérieurs à 1822 (propriétés bâties)"@fr .

srctype:EtatsDeSections_Av_1822_NonBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections antérieurs à 1822 : chapitres dédiés aux propriétés non bâties" ;
    skos:broader srctype:EtatsDeSections_Av_1822 ;
    skos:definition "Extract from an initial register created before 1822, dedicated to the description of unbuilt properties."@en,
        "Partie d'un registre d'états de sections créé avant 1822 dédié à la description des propriétés non bâties."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Initial register created before 1822 (built properties)"@en,
        "Etats de sections antérieurs à 1822 (propriétés non bâties)"@fr .

srctype:EtatsDeSections_Scp_Seine_1835 a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections spécifiques à la rénovation du cadastre de la Seine (1835-1845)" ;
    skos:broader srctype:EtatsDeSections ;
    skos:definition "Initial registers relating specifically to the attempt to update the land registry carried out between 1835 and 1845 in the department of Seine."@en,
        "Registre d'états de sections spécifique à la tentative de rénovation du cadastre ayant eu lieu entre 1835 et 1845 dans le département de la Seine."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Special intial registers of the (1835-1845) Seine departement cadaster"@en,
        "Etats de sections spécifiques à la rénovation du cadastre de la Seine (1835-1845)"@fr .

srctype:FicheInventaire a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Inventaire des archives" ;
    skos:altLabel "Inventaire"@fr ;
    skos:definition "Inventory records describing the contents of the archives held by an archive service."@en,
        "Fiches d'inventaire décrivant le contenu des archives localisées dans un service d'archives."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Archival Records Inventory"@en,
        "Inventaire des archives"@fr .

srctype:FolioBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Folio (Bâti)" ;
    skos:broader srctype:Folio ;
    skos:definition "Section dedicated to pland plots subject to tax as built property."@en,
        "Folio dédié à des parcelles imposées au titre des propriétés bâties."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Folio (built property)"@en,
        "Folio (Bâti)"@fr .

srctype:FolioNonBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Folio (Non Bâti)" ;
    skos:broader srctype:Folio ;
    skos:definition "Account dedicated to land plots taxed as land without any buildings on it (unbuilt properties)."@en,
        "Folio dédié à des parcelles imposées au titre des propriétés non bâties/foncières."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Folio (unbuilt property)"@en,
        "Folio (Non Bâti)"@fr .

srctype:LigneEtatDeSection a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Ligne de tableau d'états de sections" ;
    skos:broader srctype:ZoneDePage ;
    skos:definition "A row in the main table of a section status register describing a parcel at the time of the cadastral survey’s initialisation."@en,
        "Ligne du tableau principal d'un registre d'état de sections décrivant une parcelle à l'initialisation du cadastre."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Table row in an initial register page"@en,
        "Ligne de tableau d'états de sections"@fr .

srctype:LigneMatrice a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Ligne de tableau d'une matrice" ;
    skos:broader srctype:ZoneDePage ;
    skos:definition "A table row in a folio of a register describing the status of a plot of land."@en,
        "Ligne d'un folio d'une matrice décrivant l'état d'une parcelle."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Table row in a mutation register page"@en,
        "Ligne de tableau d'une matrice"@fr .

srctype:MatriceCadastrale1807_1822_Bati_NonBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice de rôles des propriétés bâties et non bâties (1807-1822)" ;
    skos:altLabel "Matrice des propriétés bâties et non bâties (1807-1822)"@fr ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "Mutation register created between 1807 and 1822, detailing the built and unbuilt properties within a municipality."@en,
        "Matrice cadastrale créée entre 1807 et 1822, décrit les propriétés bâties et non bâties d'une commune."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register of built and non built properties (1807-1822)"@en,
        "Matrice de rôles des propriétés bâties et non bâties (1807-1822)"@fr .

srctype:MatriceCadastrale1822_1914_NonBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice des propriétés non bâties (1822-1914)" ;
    skos:altLabel "Matrice des propriétés foncières (1822-1914)"@fr ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "Mutation register compiled between 1822 and 1914, which lists both built and unbuilt properties up to 1882, and only unbuilt properties up to 1914."@en,
        "Matrice cadastrale créée entre 1822 et 1914, décrit les propriétés bâties et non bâties jusqu'à 1882 puis uniquement les propriétés non bâties jusqu'à 1914."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register of non built properties (1822-1914)"@en,
        "Matrice des propriétés non bâties (1822-1914)"@fr .

srctype:MatriceCadastrale1882_1911_Bati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice des propriétés bâties (1882-1911)" ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "Mutation register used from 1882 onwards to describe built properties."@en,
        "Matrice cadastrale utilisée à partir de 1882 pour décrire les propriétés bâties."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register of build properties (1882-1911)"@en,
        "Matrice des propriétés bâties (1882-1911)"@fr .

srctype:MatriceCadastrale1911_Renovation_Bati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice des propriétés bâties (1911-rénovation)" ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "Mutation register used from 1911 onwards to describe built properties."@en,
        "Matrice cadastrale utilisée à partir de 1911 pour décrire les propriétés bâties."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register of built properties (1911-renewal)"@en,
        "Matrice des propriétés bâties (1911-rénovation)"@fr .

srctype:MatriceCadastrale1914_Renovation_NonBati a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice des propriétés non bâties (1914-rénovation)" ;
    skos:broader srctype:MatriceCadastrale ;
    skos:definition "Mutation register used from 1914 onwards to describe unbuilt properties."@en,
        "Matrice cadastrale utilisée à partir de 1914 pour décrire les propriétés non bâties"@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register of unbuilt properties (1914-cadaster renovation)"@en,
        "Matrice des propriétés non bâties (1914-rénovation)"@fr .

srctype:Ouvrage a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Ouvrage" ;
    skos:definition "Publication (book, article)."@en,
        "Ouvrage (livre, article)."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Book"@en,
        "Ouvrage"@fr .

srctype:PlanGeoreference a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan vectorisé" ;
    skos:broader srctype:Plan ;
    skos:definition "Georeferenced map (manually or automatically)."@en,
        "Plan georéférencé (manuellement ou automatiquement)."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Vectorized map"@en,
        "Plan vectorisé"@fr .

srctype:PlanParcellaireIssuDAtlas a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan parcellaire issu d'atlas" ;
    skos:broader srctype:PlanParcellaireFinal ;
    skos:definition "Final version of a cadastral index map taken from a municipal or cantonal atlas."@en,
        "Version finale d'un plan parcellaire extraire d'un atlas communal ou cantonal"@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Cadastral index map : final version extract from atlas"@en,
        "Plan parcellaire issu d'atlas"@fr .

srctype:PlanParcellaireMinute a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan parcellaire : minute" ;
    skos:broader srctype:PlanParcellaire ;
    skos:definition "Draft version of a cadastral index map; may include building outlines, working notes or provisional plot numbering."@en,
        "Version de travail du plan parcellaire, peut comprendre des traits de constructions, notes de travail ou une numérotation non définitive des parcelles."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Cadastral index map : draft version"@en,
        "Plan parcellaire : minute"@fr .

srctype:PlanVectorise a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan géoréférencé" ;
    skos:broader srctype:Plan ;
    skos:definition "Vectorised plan (manually or automatically)."@en,
        "Plan vectorisé (manuellement ou automatiquement)."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Georeferenced map"@en,
        "Plan géoréférencé"@fr .

srctype:TableauAssemblage a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Tableau d'assemblage" ;
    skos:broader srctype:Plan ;
    skos:definition "A map drawn to the scale of a municipality, showing the compilation of cadastral index maps detailing the plots within the municipality."@en,
        "Plan réalisé à l'échelle d'une commune représentant l'assemblage des plans parcellaires qui détaillent les parcelles de la commune."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Assembly map of the cadastral index maps"@en,
        "Tableau d'assemblage"@fr .

srctype:PageDeRegistre a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Page de registre cadastral" ;
    skos:broader srctype:RegistreCadastral ;
    skos:definition "Page taken from a register."@en,
        "Page issue d'un registre."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Page of register"@en,
        "Page de registre cadastral"@fr .

srctype:PlanParcellaireFinal a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan parcellaire final" ;
    skos:broader srctype:PlanParcellaire ;
    skos:definition "Final version of a cadastral index map."@en,
        "Version finale d'un plan parcellaire"@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Cadastral index map : final version"@en,
        "Plan parcellaire final"@fr .

srctype:Cadastre a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Cadastre" ;
    skos:altLabel "Corpus cadastral"@fr ;
    skos:definition "A land registry comprising maps and registers, used for a certain period to calculate and collect property tax on plots of land within a municipality."@en,
        "Corpus cadastral composé de plans et de registres, utilisé pendant une certaine période pour le calcul et le prélèvement de l'impôt foncier des parcelles d'une commune."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Land registry corpus"@en,
        "Cadastre"@fr .

srctype:EtatsDeSections_Av_1822 a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections antérieurs à 1822" ;
    skos:broader srctype:EtatsDeSections ;
    skos:definition "Initial register created before 1822. Sometimes, it contains a section describing the unbuilt plots and a section describing the buildings."@en,
        "Registre d'états de sections créé avant 1822. Contient une partie dédiée à la description du sol (propriété non bâties) et une partie dédiée à la description des bâtiments (propriétés bâties)."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Initial register created before 1822"@en,
        "Etats de sections antérieurs à 1822"@fr .

srctype:Folio a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Folio" ;
    skos:altLabel "Article"@fr,
        "Case"@fr ;
    skos:broader srctype:ZoneDePage ;
    skos:definition "An area within a mutation register page that is identified by a number (ID). It may contain property accounts from one or more taxpayers, depending on the period and the type of pre-printed register."@en,
        "Zone située dans une page de matrice qui est caractérisée à un numéro (identifiant). Elle peut contenir des éléments d'un ou plusieurs comptes fonciers selon les époques et les types de registres pré-imprimés."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Folio"@en,
        "Folio"@fr .

srctype:PlanParcellaire a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan parcellaire" ;
    skos:broader srctype:Plan ;
    skos:definition "A map showing the lant plots within a section of a municipality (an entire section or part of a section), drawn to scales ranging from 1:1,250 to 1:5,000."@en,
        "Plan représentant les parcellaires d'une portion d'une commune (section entière ou partie d'une section), réalisé à des échelles situées entre 1:1250 et 1:5000."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Cadastral index map"@en,
        "Plan parcellaire"@fr .

srctype:EtatsDeSections a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Etats de sections" ;
    skos:broader srctype:RegistreCadastral ;
    skos:definition "Initial register detailing the initial status of plots within a municipality on a given date for a specific cadastral survey, prior to the completion of a cadastral map."@en,
        "Registre d'état de sections décrivant l'état initial des parcelles d'une commune à une date donnée pour un cadastre donné, proche de la réalisation d'un plan cadastral."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Initial register"@en,
        "Etats de sections"@fr .

srctype:RegistreCadastral a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Registre cadastral" ;
    skos:broader srctype:Cadastre ;
    skos:definition "A register forming part of the land registry records."@en,
        "Registre faisant partie de la documentation cadastrale."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Register"@en,
        "Registre cadastral"@fr .

srctype:Plan a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Plan" ;
    skos:broader srctype:Cadastre ;
    skos:definition "Map forming part of the land registry records."@en,
        "Plan faisant partie de la documentation cadastrale."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Map"@en,
        "Plan"@fr .

srctype:ZoneDePage a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Zone située dans une page de registre cadastral" ;
    skos:broader srctype:PageDeRegistre ;
    skos:definition "An area within a registry page."@en,
        "Zone située dans une page de registre."@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Area in a register page"@en,
        "Zone située dans une page de registre cadastral"@fr .

srctype:MatriceCadastrale a owl:NamedIndividual,
        skos:Concept,
        tbl:SourceType ;
    rdfs:label "Matrice cadastrale" ;
    skos:broader srctype:RegistreCadastral ;
    skos:definition "A register containing all changes affecting the plots during its period of validity."@en,
        "Registre contenant l'ensemble des mutations affectant les parcelles pendant la période de validité de la matrice"@fr ;
    skos:inScheme tbl:LandRegistrySourceList ;
    skos:prefLabel "Mutation register"@en,
        "Matrice cadastrale"@fr .

# ----- List of special values -----

spval:CelluleVide a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:altLabel "EMPTY"@fr ;
    skos:definition "An empty cell with no meaning. This is different from cells left blank to indicate that their value is the same as another cell (Idem)."@en,
        "Cellule vide sans signification. Diffère des cellules laissées vides pour indiquer que leur valeur est identique à une autre cellule (Idem)."@fr ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Empty cell"@en,
        "Cellule vide"@fr .

spval:ConstructionNouvelleSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indique une construction d'un bâtiment qui est donc imposable au titre des propriétés bâties."@en,
        "Indique une construction d'un bâtiment qui est donc imposable au titre des propriétés bâties."@fr ;
    skos:hiddenLabel "CN",
        "Cn nvelle",
        "Con nvelle",
        "Conston nouvelle",
        "Construction nouvelle",
        "Nouvelle construction" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "New building"@en,
        "Construction nouvelle"@fr .

spval:DemolitionSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that a building has been demolished and is therefore no longer subject to property tax."@en,
        "Indique une destruction d'un bâtiment qui n'est donc plus imposable au titre des propriétés bâties."@fr ;
    skos:hiddenLabel "Destruction",
        "Démolie",
        "Démolition",
        "Détruite" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Demolition"@en,
        "Démolition"@fr .

spval:DiminutionSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates a change to a building that results in a reduction in its property valuation."@en,
        "Indique une modification d'un bâtiment qui entraine une diminution de l'évaluation foncière de celui-ci."@fr ;
    skos:hiddenLabel "Dim",
        "Diminution",
        "Dton" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Reduction"@en,
        "Diminution"@fr .

spval:DoubleEmploiSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "! To be defined in accordance with the tax authorities’ guidelines."@en,
        "! A définir au sens de l'administration fiscale."@fr ;
    skos:hiddenLabel "Double emploi" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Double employement"@en,
        "Double emploi"@fr .

spval:EvaluationSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates a tax valuation or revaluation of a land plot."@en,
        "Indique une évaluation ou réévaluation fiscale d'une parcelle."@fr ;
    skos:hiddenLabel "Eval",
        "Evaluation" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Evaluation"@en,
        "Evaluation"@fr .

spval:IdemPrecedentSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:broader spval:IdemSV ;
    skos:definition "Indicates that the cell is the same as that of the previous cell."@en,
        "Valeur de cellule identique à celle de la cellule précédente."@fr ;
    skos:hiddenLabel "\"",
        "/",
        "Id",
        "Le même",
        "Les mêmes",
        "idem",
        "§",
        "Ø" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Idem as previous cell"@en,
        "Idem au précédent"@fr .

spval:IdemSuivantSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:broader spval:IdemSV ;
    skos:definition "Indicates that the cell is the same as that of the next cell."@en,
        "Valeur de cellule identique à celle de la cellule suivante."@fr ;
    skos:hiddenLabel "\"",
        "/",
        "Id",
        "Le même",
        "Les mêmes",
        "idem",
        "§",
        "☼" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Idem as next cell"@en,
        "Idem au précédent"@fr .

spval:InconnuSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that the cell meaning has not been specified or understanded."@en,
        "Valeur de cellule dont le sens n'a pas été explicité."@fr ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Unknown"@en,
        "Valeur inconnue"@fr .

spval:OmissionSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:altLabel "OmissionSV{{date}}"@fr ;
    skos:definition "Indicates that the plot of land has been retroactively included in the taxpayer’s land register, as the taxpayer had failed to declare it for a certain period."@en,
        "Indique que la parcelle a fait l'objet d'une intégration réatroactive dans le compte foncier du contribuable qui ne l'avait pas déclarée pendant une certaine période."@fr ;
    skos:hiddenLabel "Omission",
        "Omission depuis",
        "OmissionSV{{date}}" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Omission"@en,
        "Omission"@fr .

spval:PartieSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that the plot is a part of an original parcel that had the same number and has (usually) been subdivided. A \"p\" letter is often concatenated after the plot number."@en,
        "Indique que la parcelle décrite est une partie d'une parcelle initiale qui possèdait le même numéro et a (généralement) été divisée. La lettre \"p\" est souvent accolée au numéro de la parcelle."@fr ;
    skos:hiddenLabel "Partie",
        "Ptie",
        "p" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Part of"@en,
        "Partie"@fr .

spval:ResteSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that the plot is the remnant of a plot from the same land account that was subdivided and bore the same identifier as the plot in question."@en,
        "Indique que la parcelle est le résidu d'une parcelle du même compte foncier qui a été divisée et qui portait le même identiant que la parcelle considérée."@fr ;
    skos:hiddenLabel "Reste" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Left-over"@en,
        "Reste"@fr .

spval:RuinesSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that a building is or was in ruins."@en,
        "Indique qu'une construction est ou était en ruines."@fr ;
    skos:hiddenLabel "En ruine",
        "En ruines",
        "Ruines" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Ruined"@en,
        "En ruines"@fr .

spval:ValeurBarreeSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:altLabel "~~TEXT~~"@fr ;
    skos:definition "Indicates that the text is crossed out in the document."@en,
        "Indique que le texte est barré dans le document."@fr ;
    skos:hiddenLabel "~~~~" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Crossed out"@en,
        "Valeur barrée"@fr .

spval:VoiePubliqueSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that part of the plot has been incorporated into the public highway."@en,
        "Indique d'une partie de la parcelle est passée à la voie publique."@fr ;
    skos:hiddenLabel "Voie publique",
        "Vp" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Passed to the public roads"@en,
        "Passé à la voie publique"@fr .

spval:AdditionConstructionSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:closeMatch spval:AugmentationSV ;
    skos:definition "Indicates an extension to an existing building, which may result in a reassessment of its tax value."@en,
        "Indique une addition à une contruction existente, pouvant entraîner une réévaluation de la valeur fiscale de celle-ci."@fr ;
    skos:hiddenLabel "add",
        "add C",
        "addition" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Expension"@en,
        "Addition à une construction"@fr .

spval:AugmentationSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:closeMatch spval:AdditionConstructionSV ;
    skos:definition "Indicates an extension to an existing building, which may result in a reassessment of its tax value."@en,
        "Indique une addition à une contruction existente, pouvant entraîner une réévaluation de la valeur fiscale de celle-ci."@fr ;
    skos:hiddenLabel "Augmentation",
        "Augon",
        "Augtion",
        "Augton" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Enhancement"@en,
        "Augmentation"@fr .

spval:IdemSV a owl:NamedIndividual,
        skos:Concept,
        tbl:SpecialCellValue ;
    skos:definition "Indicates that the cell value that is the same as that of another cell."@en,
        "Valeur de cellule identique à celle d'une autre cellule."@fr ;
    skos:hiddenLabel "\"",
        "/",
        "Id",
        "Le même",
        "Les mêmes",
        "idem",
        "§" ;
    skos:inScheme tbl:SpecialCellValuesList ;
    skos:prefLabel "Idem"@en,
        "Idem"@fr .

# ----- List of annotation classes -----

anclass:BlankPage a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Page not completed, regardless of its nature. This class can be used in addition of other classes to describe the page in more detail."@en,
        "Page non complétée, indépendament de sa nature. Cette classe peut-être utilisée avec d'autres classes pour décrire la page plus précisément."@fr ;
    skos:hiddenLabel "ets_blank" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Blank page"@en,
        "Page vide"@fr ;
    skos:related anclass:Page .

anclass:CrossedOut a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:TextStyles ;
    skos:definition "Indicates that the text in a page area is crossed out."@en,
        "Indique que le texte d'une zone de page est barré."@fr ;
    skos:hiddenLabel "~~~~" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Crossed-out text"@en,
        "Entité nommée : Texte barré/rayé"@fr .

anclass:DocumentType a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:definition "Types of documents or fields contained in cadastral archive documents, relating to a task of detecting/locating content within images."@en,
        "Types de documents ou de zones contenues dans les documents d'archives du cadastre, relatif à une tâche de détection/localisation de contenu dans des images."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Type of document"@en,
        "Type de document"@fr .

anclass:DoublePage a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image showing a scanned double-page from a register."@en,
        "Image correspondant à la numérisation d'une double page de registre."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Double-page"@en,
        "Double page"@fr .

anclass:ETSCover a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Cover page preceding the main table describing the plots in a given section within a section register."@en,
        "Page de couverture qui précéde le tableau principal décrivant les parcelles d'une section donnée dans un registre d'état de section."@fr ;
    skos:hiddenLabel "ets_couv" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Section page cover"@en,
        "Couverture décrivant une section dans un registre d'états de sections"@fr ;
    skos:related anclass:Page .

anclass:ETSIntermediateSummary a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Intermediate summary page visible in an initial register."@en,
        "Page de récapitulatif intermédiaire dans un registre d'états de sections."@fr ;
    skos:hiddenLabel "ets_recap_inter" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Intermediate summary"@en,
        "Récapitulatif intermédiaire"@fr ;
    skos:related anclass:Page .

anclass:ETSSummary a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Final summary page located at the end of a section of an initial register, more precisly at the end of the decsription of the plots of a given section."@en,
        "Page de résumé situé à la fin d'une partie d'un registre d'états de sections décrivant les parcelles d'une section donnée."@fr ;
    skos:hiddenLabel "ets_resume" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Summary"@en,
        "Résumé final d'une section"@fr ;
    skos:related anclass:Page .

anclass:ETSTabP2 a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Last page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822."@en,
        "Seconde page du tableau principal d'un registre d'état de sections contenant la description des parcelles listées dans l'ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822."@fr ;
    skos:hiddenLabel "ets_tab_p2" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Second page of a main table in an initial register"@en,
        "Tableau principal d'état de section (seconde page si double page)"@fr ;
    skos:related anclass:Page .

anclass:MATAlphabeticTable a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Page from a mutation register containing an alphabetical list of taxpayers."@en,
        "Page d'une matrice cadastrale correspondant à une liste alphabétique des contribuables."@fr ;
    skos:hiddenLabel "mat_alpha_tab" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Alphabetical table"@en,
        "Table alphabétique"@fr ;
    skos:related anclass:Page .

anclass:MATArticleDeMutation a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to a list of 1 to n taxpayers associated with the same property taxes account."@en,
        "Zone d'image correspond à une liste de 1..n contribuables associés au même compte foncier."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "List of successive taxpayers"@en,
        "Liste de contribuables successifs"@fr .

anclass:MATCompteFoncier a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:altLabel "Ligne de tableau décrivant un état de parcelle"@fr ;
    skos:broader anclass:DocumentsTypes ;
    skos:definition "Image area corresponding to a group of lines delineating parcels associated with a list of 1 to n taxpayers located in a folio of a register."@en,
        "Zone d'une image correspondant à un groupe de lignes décrivant des parcelles associé à une liste de 1..n contribuable situé dans un folio d'une matrice."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Area corresponding to a property tax account"@en,
        "Zone correspondant à un compte foncier"@fr .

anclass:MATMainTable a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:PageClasses ;
    skos:definition "Main table page of a mutation register containing one or more property tax account."@en,
        "Page du tableau principal d'une matrice cadastrale contenant un ou plusieurs comptes fonciers."@fr ;
    skos:hiddenLabel "mat_main_tab" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Page containing property accounts"@en,
        "Page correspondant à un ou plusieurs folios"@fr ;
    skos:related anclass:Page .

anclass:NEEndTime a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value indicating the expiry date of a parcel statement."@en,
        "Valeur de colonne indiquant la date de fin de validité d'un état de parcelle."@fr ;
    skos:hiddenLabel "date_sortie" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : End date"@en,
        "Entité nommée : Date de sortie"@fr .

anclass:NENature a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value containing the plot nature."@en,
        "Valeur de colonne relative à la nature de la parcelle."@fr ;
    skos:hiddenLabel "nature" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Nature"@en,
        "Entité nommée : Nature"@fr .

anclass:NEPassedTo a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "A column value indicating either one (or more) folio numbers where the following status of the parcel is recorded, or a special value providing information about that status."@en,
        "Valeur de colonne indiquant soit un (ou plusieurs) numéro.s de folio.s où est inscrit l'état suivant de la parcelle soit une valeur spéciale renseignant sur cet état."@fr ;
    skos:hiddenLabel "porte_a" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Next folio or status"@en,
        "Entité nommée : Porté à"@fr .

anclass:NEPlotAddress a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value corresponding to the plot address."@en,
        "Valeur de colonne correspondant à l'adresse de la parcelle."@fr ;
    skos:hiddenLabel "lieu_dit" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Address"@en,
        "Entité nommée : Lieu-dit ou adresse"@fr .

anclass:NEPlotNumber a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value corresponding to the plot number."@en,
        "Valeur de colonne correspondant au numéro de la parcelle."@fr ;
    skos:hiddenLabel "numero_parcelle" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Plot Number"@en,
        "Entité nommée : Numéro de parcelle"@fr .

anclass:NEPreviousNature a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value specific to the initial register of the revised Seine land registry (1835–1845), indicating the plot nature in the previous section list."@en,
        "Valeur de colonne spécifique aux états de sections du cadastre rénové de la Seine (1835-1845), décrit la nature de la parcelle dans l'état de sections précédent."@fr ;
    skos:hiddenLabel "ancienne_nature" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Former Plot Nature"@en,
        "Entité nommée : Ancienne nature de la parcelle"@fr .

anclass:NEPreviousPlotNumber a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value specific to the initial register of the revised Seine land registry (1835–1845), indicating the plot number in the previous section list."@en,
        "Valeur de colonne spécifique aux états de sections du cadastre rénové de la Seine (1835-1845), indique le numéro de la parcelle dans l'état de sections précédent."@fr ;
    skos:hiddenLabel "ancien_numero_parcelle" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Former Plot Number"@en,
        "Entité nommée : Ancien numéro de parcelle"@fr .

anclass:NESectionIdentifier a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value containing the ID of the section in which the plot is located."@en,
        "Valeur d'une colonne contenant l'identifiant de la section dans laquelle se trouve la parcelle."@fr ;
    skos:hiddenLabel "section" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Section Identifier"@en,
        "Entité nommée : Identifiant de section"@fr .

anclass:NEStartTime a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Column value indicating the start date of validity for a parcel record."@en,
        "Valeur de colonne indiquant la date de début de validité d'un état de parcelle."@fr ;
    skos:hiddenLabel "date_entree" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Start date"@en,
        "Entité nommée : Date d'entrée"@fr .

anclass:NETakenFrom a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "A column value indicating either the folio number where the previous status of the parcel was recorded, or a special value providing information about that status."@en,
        "Valeur de colonne indiquant soit le numéro de folio où était décrit l'état précédent de la parcelle soit une valeur spéciale renseignant sur cet état."@fr ;
    skos:hiddenLabel "tire_de" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Previous folio or status"@en,
        "Entité nommée : Tiré de"@fr .

anclass:NETaxpayerActivity a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
        "Entité nommée identifiable dans une valeur de la colonne relative au contribuable."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Activity"@en,
        "Entité nommée : Activité"@fr ;
    skos:related anclass:NETaxpayer .

anclass:NETaxpayerAddress a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
        "Entité nommée identifiable dans une valeur de la colonne relative au contribuable."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Address"@en,
        "Entité nommée : Adresse"@fr ;
    skos:related anclass:NETaxpayer .

anclass:NETaxpayerBirthName a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
        "Entité nommée identifiable dans une valeur de la colonne relative au contribuable."@fr ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "Named entity : Birth name"@en,
        "Entité nommée : Nom de naissance"@fr ;
    skos:related anclass:NETaxpayer .

anclass:NETaxpayerFamilyStatus a owl:NamedIndividual,
        skos:Concept,
        tbl:AnnotationClassType ;
    skos:broader anclass:NamedEntityTypes ;
    skos:definition "Named entity that can be extracted fril within a value in the taxpayer column."@en,
