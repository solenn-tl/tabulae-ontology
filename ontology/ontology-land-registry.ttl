    skos:broader anclass:PageClasses ;
    skos:closeMatch anclass:ETSTab ;
    skos:definition "First page of the main table of an initial register containing a description of the plots listed in ascending order by number. Used only when the main table is display in a double-page. Mostly used for registers created before 1822."@en,
        "Première page (sur deux) du tableau principal d'un registre d'état de sections contenant la description des parcelles listées dans l'ordre croissant de numéro identifiant. Classe utilisée uniquement quand le tableau principal couvre une double page. Ce type de page est principalement visible dans des registres créés avant 1822."@fr ;
    skos:hiddenLabel "ets_tab_p1" ;
    skos:inScheme tbl:AnnotationClassList ;
    skos:prefLabel "First page of a main table in an initial register"@en,
        "Tableau principal d'état de section (première page si double page)"@fr ;
    skos:related anclass:Page .

