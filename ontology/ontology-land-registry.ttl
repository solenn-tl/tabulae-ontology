#    rdfs:label "identifiant Ldh/EHESS/Cassini"@fr.
#igeo:codeINSEE  a owl:DatatypeProperty .
#rico:identifier a owl:DatatypeProperty .
#rico:name a owl:DatatypeProperty .

# ---- Named Individuals ----
#Formerly tbl:CadastreAttributeList
tbl:LandRegistryAttributeList a owl:NamedIndividual,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différents rôles spécifique au cadastre pouvant être joués par un attribut, représentés comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type d'attributs spécifiques aux objets du cadastre"@fr ,
               "Type of attributes specific to land registry objects"@en ;
    skos:prefLabel "Type d'attributs spécifiques aux objets du cadastre"@fr ,
               "Type of attributes specific to land registry objects"@en .

#Formerly CadastreEventList
tbl:LandRegistryEventList a owl:NamedIndividual,
    skos:ConceptScheme ;
    rdfs:comment "Liste des types d'évènements pouvant intervenir, spécifiques au cadastre, représentés comme une liste de concepts SKOS."@fr ,
                "List of event types that can occur, specific to the land registry, represented as a list of SKOS concepts."@en ;
    rdfs:label "Type d'événement"@fr ,
               "Type of event"@en ;
    skos:prefLabel "Type d'événement"@fr ,
               "Type of event"@en .

tbl:LandRegistryLandmarkList a owl:NamedIndividual ,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différents rôles pouvant être joués par un repère spécifique au cadastre, représentés comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type de repère spécifiques au cadastre français"@fr ,
                "Type of landmark related to the land registry"@en ;
    skos:prefLabel "Type de repère spécifiques au cadastre"@fr ,
               "Type of landmark related to the land registry"@en .

tbl:LandRegistryChangeList a owl:NamedIndividual ,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différents changements spécifique au cadastre, représentés comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type de changements spécifiques au cadastre"@fr ,
              "Type of changes related to the land registry"@en ;
    skos:prefLabel "Type de changements spécifiques au cadastre"@fr ,
               "Type of changes related to the land registry"@en .

tbl:NatureList a owl:NamedIndividual ,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différentes natures de parcelles, représentés comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type de natures de parcelles"@fr ,
               "Type of plot natures"@en ;
    skos:prefLabel "Type de natures de parcelles"@fr ,
               "Type of plot natures"@en .

tbl:AnnotationClassList a owl:NamedIndividual ,
                  skos:ConceptScheme ;
                  rdfs:comment "Liste des différentes classes pouvant être attribuées à un document ou à une zone dans un document, représentés comme une liste de concepts SKOS."@fr ;
                  rdfs:label "Liste de classes"@fr ,
                             "List of classes"@en ;
                skos:prefLabel "Liste de classes"@fr ,
                             "List of classes"@en .

tbl:LandRegistrySourceList a owl:NamedIndividual ,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différentes sources de données, représentées comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type de sources"@fr ,
               "Type of sources"@en ;
    skos:prefLabel "Type de sources"@fr ,
               "Type of sources"@en .

tbl:SpecialCellValuesList a owl:NamedIndividual ,
    skos:ConceptScheme ;
    rdfs:comment "Liste des différentes valeurs spéciales liées au fonctionnement des documents cadastraux, représentés comme une liste de concepts SKOS."@fr ;
    rdfs:label "Type de valeurs spéciales"@fr ,
               "Type of special values"@en ;
    skos:prefLabel "Type de valeurs spéciales"@fr ,
               "Type of special values"@en .

# ---- SKOS Concepts ----

## ---- CadastreAttributesList ----
tblatype:PlotAddress a peg:AttributeType,
        owl:NamedIndividual,
        skos:Concept ;
    skos:altLabel "Location"@en,
        "Localisation de la parcelle"@fr ;
    skos:inScheme tbl:LandRegistryAttributeList ;
    skos:prefLabel "Plot address"@en,
        "Adresse de la parcelle"@fr .

tblatype:PlotMention a peg:AttributeType,
        owl:NamedIndividual,
        skos:Concept ;
    skos:definition "Détail des mentions précédente.s, courante et suivante.s associées à une parcelle (d'après les colonnes Tiré de, Porté et du numéro de folio courant)."@fr ;
    skos:inScheme tbl:LandRegistryAttributeList ;
    skos:prefLabel "Plot mention"@en,
        "Mention de la parcelle"@fr .

tblatype:PlotNature a peg:AttributeType,
        owl:NamedIndividual,
        skos:Concept ;
    skos:definition "Nature d'une parcelle"@fr ;
    skos:inScheme tbl:LandRegistryAttributeList ;
    skos:prefLabel "Nature"@en,
        "Nature"@fr .

tblatype:PlotTaxpayer a peg:AttributeType,
        owl:NamedIndividual,
        skos:Concept ;
    skos:altLabel "Propriétaire ou usufruitier"@fr ;
    skos:definition "Propriétaire(s) ou usufruitier(s) d'une parcelle (contribuable)"@fr ;
    skos:inScheme tbl:LandRegistryAttributeList ;
    skos:prefLabel "Taxpayer"@en,
        "Contribuable"@fr .

########## CadastreChange List
tblctype:TaxpayerAppearance a  owl:NamedIndividual ,
                                    peg:ChangeType ,
                                    skos:Concept ;
                                 skos:definition "Changement décrivant l'apparition d'un contribuable"@fr ;
                                 skos:inScheme tbl:LandRegistryChange ;
                                 skos:prefLabel "Apparition d'un contribuable"@fr ,
                                                "Appearance of a taxpayer"@en .
tblctype:TaxpayerDisappearance a  owl:NamedIndividual ,
                                          peg:ChangeType ,
                                          skos:Concept ;
                                 skos:definition "Changement décrivant la disparition d'un contribuable"@fr ;
                                 skos:inScheme tbl:LandRegistryChange ;
                                 skos:prefLabel "Disparition d'un contribuable"@fr ,
                                                "Disappearance of a taxpayer"@en .
########## LandRegistryLandmarkList

tblltype:Arrondissement a owl:NamedIndividual ,
                    peg:LandmarkType ,
                    skos:Concept ;
           skos:altLabel "Arrondissement"@en ,
                         "Arrondissement"@fr ;
           skos:broader ltype:AdministrativeUnity ;
           skos:definition "Entité administrative décrivant un arrondissement"@fr ;
           skos:inScheme tbl:LandRegistryLandmarkList ;
           skos:prefLabel "Arrondissement"@en ,
                          "Arrondissement"@fr .

tblltype:Canton a owl:NamedIndividual ,
                    peg:LandmarkType ,
                    skos:Concept ;
           skos:altLabel "Canton"@en ,
                         "Canton"@fr ;
           skos:broader ltype:AdministrativeUnity ;
           skos:definition "Entité administrative décrivant un canton (jusqu'à la loi du loi du 17 mai 2013)"@fr ;
           skos:inScheme tbl:LandRegistryLandmarkList ;
           skos:prefLabel "Canton"@en ,
                          "Canton"@fr .

tblltype:Departement a owl:NamedIndividual ,
                       peg:LandmarkType ,
                       skos:Concept ;
              skos:broader ltype:AdministrativeUnity ;
              skos:definition "Entité administrative décrivant un département "@fr ;
              skos:inScheme tbl:LandRegistryLandmarkList ;
              skos:prefLabel "Departement"@en ,
                             "Département"@fr ;
              skos:altLabel "French departement"@en .

tblltype:Plot a owl:NamedIndividual ,
                            peg:LandmarkType ,
                            skos:Concept ;
                   skos:definition "Parcelle située dans une section d'une commune"@fr ;
                   skos:inScheme tbl:LandRegistryLandmarkList ;
                   skos:prefLabel "Parcelle"@fr ,
                                  "Plot"@en .

tblltype:Section a owl:NamedIndividual ,
                            peg:LandmarkType ,
                            skos:Concept ;
                   skos:definition "Section cadastrale contentant tout ou partie des parcelles d'une commune, identifiée par une "@fr ;
                   skos:inScheme tbl:LandRegistryLandmarkList ;
                   skos:prefLabel "Section"@fr ,
                                  "Section"@en .

